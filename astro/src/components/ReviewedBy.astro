---
/**
 * Renders a "Medically reviewed by Dr. X" byline above or below directory content.
 * Silently returns null if no reviewer is linked — we never fabricate this.
 * Pair with `withProvenance(...)` in the page's JSON-LD so Schema.org `reviewedBy`
 * gets a Person, not the editorial-desk Organization fallback.
 */
import type { ReviewerRow } from "@/lib/queries";
import { localizedPath, type Locale } from "@/lib/i18n";

interface Props {
  reviewer: ReviewerRow | null;
  locale: Locale;
  variant?: "strip" | "inline";
}

const { reviewer, locale, variant = "strip" } = Astro.props;
if (!reviewer) return null;

const reviewedAt = reviewer.reviewedAt
  ? new Date(reviewer.reviewedAt).toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;

const profileHref = reviewer.profileUrl
  ? reviewer.profileUrl
  : localizedPath(locale, `/medical-board#${reviewer.slug}`);
---

{variant === "strip" ? (
  <aside
    class="reviewed-by-strip"
    aria-label="Editorial review"
    style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-paper); font-size: 13px;"
  >
    {reviewer.imageUrl ? (
      <img
        src={reviewer.imageUrl}
        alt=""
        width="40"
        height="40"
        loading="lazy"
        decoding="async"
        class="rounded-full object-cover shrink-0"
        style="width: 40px; height: 40px;"
      />
    ) : (
      <div
        aria-hidden="true"
        class="rounded-full shrink-0"
        style="width: 40px; height: 40px; background: var(--color-accent-soft); display: flex; align-items: center; justify-content: center; color: var(--color-accent); font-weight: 600;"
      >
        {reviewer.fullName
          .replace(/^Dr\.?\s*/i, "")
          .split(/\s+/)
          .map((w) => w[0])
          .slice(0, 2)
          .join("")}
      </div>
    )}
    <div style="line-height: 1.35;">
      <div
        class="mono"
        style="font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-subtle);"
      >
        Medically reviewed
      </div>
      <div style="color: var(--color-ink);">
        <a href={profileHref} style="font-weight: 600; color: var(--color-ink);">
          {reviewer.fullName}
        </a>
        {reviewer.credentials && (
          <span style="color: var(--color-ink-muted);">, {reviewer.credentials}</span>
        )}
        {reviewer.jobTitle && (
          <span style="color: var(--color-ink-subtle);"> — {reviewer.jobTitle}</span>
        )}
        {reviewedAt && (
          <span style="color: var(--color-ink-subtle);"> · last reviewed {reviewedAt}</span>
        )}
      </div>
    </div>
  </aside>
) : (
  <p
    style="font-size: 13px; color: var(--color-ink-muted); margin-top: 12px;"
  >
    Medically reviewed by
    <a href={profileHref} style="color: var(--color-ink); font-weight: 500;">
      {reviewer.fullName}{reviewer.credentials ? `, ${reviewer.credentials}` : ""}
    </a>
    {reviewedAt && <span> · {reviewedAt}</span>}
  </p>
)}
