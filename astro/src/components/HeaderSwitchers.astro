---
import { locales as LOCALES, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
  pathname: string;
}
const { locale, pathname } = Astro.props;

const CURRENCIES = [
  { code: "USD", label: "US Dollar", symbol: "$" },
  { code: "EUR", label: "Euro", symbol: "€" },
  { code: "GBP", label: "British Pound", symbol: "£" },
  { code: "INR", label: "Indian Rupee", symbol: "₹" },
  { code: "AED", label: "UAE Dirham", symbol: "د.إ" },
  { code: "SAR", label: "Saudi Riyal", symbol: "﷼" },
  { code: "TRY", label: "Turkish Lira", symbol: "₺" },
  { code: "RUB", label: "Russian Rouble", symbol: "₽" },
  { code: "BDT", label: "Bangladeshi Taka", symbol: "৳" },
];

const LOCALE_LABELS: Record<Locale, { label: string; flag: string }> = {
  en: { label: "English", flag: "🇺🇸" },
  ar: { label: "العربية", flag: "🇸🇦" },
  ru: { label: "Русский", flag: "🇷🇺" },
  fr: { label: "Français", flag: "🇫🇷" },
  pt: { label: "Português", flag: "🇵🇹" },
  bn: { label: "বাংলা", flag: "🇧🇩" },
  tr: { label: "Türkçe", flag: "🇹🇷" },
  hi: { label: "हिन्दी", flag: "🇮🇳" },
};

// Strip leading locale segment so we can rebuild with a different one.
// e.g. "/en/hospital/foo" → "/hospital/foo"
const restPath = (() => {
  const parts = pathname.split("/").filter(Boolean);
  if (parts.length > 0 && LOCALES.includes(parts[0] as Locale)) {
    return "/" + parts.slice(1).join("/");
  }
  return pathname;
})();

const menuStyle =
  "position: absolute; inset-block-start: calc(100% + 8px); inset-inline-end: 0; min-width: 220px; max-height: 340px; overflow-y: auto; background: var(--color-paper); color: var(--color-ink); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-md, 0 8px 24px rgba(0,0,0,0.15)); padding: 6px; z-index: 50;";
const itemStyle =
  "display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 8px 12px; border-radius: 6px; font-size: 13px; cursor: pointer; background: transparent; border: 0; width: 100%; text-align: start; font-family: inherit; color: inherit;";
---

{/* Currency */}
<details class="relative" data-currency-switcher>
  <summary
    class="opacity-80 hover:opacity-100 list-none cursor-pointer inline-flex items-center gap-1"
    style="background: transparent; border: 0; padding: 0; color: inherit; font-size: inherit;"
  >
    <span data-currency-label>USD $</span>
    <svg width="9" height="9" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity: 0.7;">
      <path d="M1 1l4 4 4-4" />
    </svg>
  </summary>
  <div style={menuStyle} role="menu">
    <div
      class="mono"
      style="padding: 6px 10px; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-subtle);"
    >Currency</div>
    {CURRENCIES.map((c) => (
      <button
        type="button"
        role="menuitem"
        data-set-currency={c.code}
        style={itemStyle}
      >
        <span style="font-weight: 500;">{c.code} <span style="color: var(--color-ink-subtle); font-weight: 400; margin-inline-start: 4px;">{c.symbol}</span></span>
        <span style="color: var(--color-ink-subtle); font-size: 11.5px;">{c.label}</span>
      </button>
    ))}
  </div>
</details>

<span class="opacity-40">·</span>

{/* Language */}
<details class="relative" data-locale-switcher>
  <summary
    class="opacity-80 hover:opacity-100 list-none cursor-pointer inline-flex items-center gap-1.5 uppercase tracking-wider"
    style="background: transparent; border: 0; padding: 0; color: inherit; font-size: 11px;"
  >
    <span aria-hidden="true">{LOCALE_LABELS[locale].flag}</span>
    <span>{locale}</span>
    <svg width="9" height="9" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity: 0.7;">
      <path d="M1 1l4 4 4-4" />
    </svg>
  </summary>
  <div style={menuStyle} role="menu">
    <div
      class="mono"
      style="padding: 6px 10px; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-subtle);"
    >Language</div>
    {LOCALES.map((l) => {
      const target = l === "en" ? restPath : `/${l}${restPath}`;
      const active = l === locale;
      return (
        <a
          href={target || "/"}
          role="menuitem"
          style={`${itemStyle} text-decoration: none; ${active ? "background: var(--color-accent-soft); color: var(--color-accent-strong);" : ""}`}
        >
          <span class="inline-flex items-center gap-2">
            <span aria-hidden="true">{LOCALE_LABELS[l].flag}</span>
            <span style="font-weight: 500;">{LOCALE_LABELS[l].label}</span>
          </span>
          <span style="color: var(--color-ink-subtle); font-size: 10.5px; text-transform: uppercase;">{l}</span>
        </a>
      );
    })}
  </div>
</details>

<script is:inline>
  (() => {
    // Read current currency from cookie and reflect in the label
    function getCookie(name) {
      const m = document.cookie.match(new RegExp("(?:^|; )" + name + "=([^;]*)"));
      return m ? decodeURIComponent(m[1]) : null;
    }
    function setCookie(name, value, days) {
      const d = new Date();
      d.setTime(d.getTime() + (days * 864e5));
      document.cookie = name + "=" + encodeURIComponent(value) + "; expires=" + d.toUTCString() + "; path=/; SameSite=Lax";
    }

    const CURRENCY_SYMBOLS = {
      USD: "$", EUR: "€", GBP: "£", INR: "₹", AED: "د.إ",
      SAR: "﷼", TRY: "₺", RUB: "₽", BDT: "৳",
    };

    const currentCurrency = getCookie("mc-currency") || "USD";
    document.querySelectorAll("[data-currency-label]").forEach((el) => {
      const sym = CURRENCY_SYMBOLS[currentCurrency] || "$";
      el.textContent = currentCurrency + " " + sym;
    });

    document.addEventListener("click", (e) => {
      const btn = e.target && e.target.closest && e.target.closest("[data-set-currency]");
      if (!btn) return;
      e.preventDefault();
      const code = btn.getAttribute("data-set-currency");
      if (!code) return;
      setCookie("mc-currency", code, 180);
      window.location.reload();
    });

    // Close details on outside click
    document.addEventListener("click", (e) => {
      document.querySelectorAll("details[data-currency-switcher], details[data-locale-switcher]").forEach((d) => {
        if (!d.contains(e.target)) d.removeAttribute("open");
      });
    });
  })();
</script>
