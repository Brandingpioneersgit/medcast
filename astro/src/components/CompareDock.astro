---
interface Props {
  compareHref: string;
}
const { compareHref } = Astro.props;
---

<div
  id="mc-compare-dock"
  role="region"
  aria-label="Hospitals selected for comparison"
  data-compare-href={compareHref}
  hidden
  class="fixed inset-x-0 bottom-0 z-40 pointer-events-none"
>
  <div class="mx-auto max-w-3xl px-4 pb-4 md:pb-6 pointer-events-auto">
    <div class="flex items-center gap-3 rounded-2xl border border-border bg-surface/95 backdrop-blur shadow-lg px-4 py-3 md:py-3.5">
      <div class="min-w-0 flex-1">
        <p class="font-display text-[15px] leading-tight text-ink">
          <span data-compare-count>0</span>
          <span data-compare-noun>hospitals</span> ready to compare
        </p>
        <p class="text-[12px] text-ink-subtle mt-0.5" data-compare-hint>
          Add at least 2 to compare.
        </p>
      </div>
      <button type="button" data-compare-clear class="hidden md:inline text-[12px] text-ink-subtle underline-offset-2 hover:underline">
        Clear
      </button>
      <a
        href={compareHref}
        data-compare-link
        hidden
        class="inline-flex items-center rounded-full bg-accent px-4 py-2 text-[13px] font-semibold text-accent-contrast hover:bg-accent-hover"
      >
        Compare →
      </a>
      <span data-compare-fill class="text-[12px] text-ink-subtle">Pick 1 more</span>
      <button type="button" data-compare-hide aria-label="Hide" class="text-ink-subtle hover:text-ink -me-1 px-1">×</button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = "mc-compare";
    var EVENT = "mc:compare:change";
    var MAX = 4;

    function load() {
      try {
        var raw = localStorage.getItem(KEY);
        if (!raw) return [];
        var arr = JSON.parse(raw);
        return Array.isArray(arr) ? arr.filter(function (x) { return typeof x === "string"; }) : [];
      } catch (e) {
        return [];
      }
    }
    function save(list) {
      try { localStorage.setItem(KEY, JSON.stringify(list)); } catch (e) {}
      window.dispatchEvent(new CustomEvent(EVENT, { detail: list }));
    }

    var dock = document.getElementById("mc-compare-dock");
    if (!dock) return;

    var dismissed = false;
    var countEl = dock.querySelector("[data-compare-count]");
    var nounEl = dock.querySelector("[data-compare-noun]");
    var hintEl = dock.querySelector("[data-compare-hint]");
    var linkEl = dock.querySelector("[data-compare-link]");
    var fillEl = dock.querySelector("[data-compare-fill]");
    var clearEl = dock.querySelector("[data-compare-clear]");
    var hideEl = dock.querySelector("[data-compare-hide]");
    var baseHref = dock.getAttribute("data-compare-href") || "/compare/hospitals";

    function render(list) {
      if (list.length === 0 || dismissed) {
        dock.hidden = true;
        return;
      }
      dock.hidden = false;
      if (countEl) countEl.textContent = String(list.length);
      if (nounEl) nounEl.textContent = list.length === 1 ? "hospital" : "hospitals";
      var canCompare = list.length >= 2;
      if (linkEl) {
        linkEl.hidden = !canCompare;
        linkEl.setAttribute("href", baseHref + "?ids=" + list.map(encodeURIComponent).join(","));
      }
      if (fillEl) fillEl.hidden = canCompare;
      if (hintEl) {
        hintEl.textContent = canCompare
          ? "Side-by-side: specialties, pricing, beds, accreditation."
          : "Add at least 2 to compare.";
      }
    }

    // Toggle buttons (CompareToggle.astro)
    function syncToggles(list) {
      var buttons = document.querySelectorAll("[data-compare-toggle]");
      for (var i = 0; i < buttons.length; i++) {
        var b = buttons[i];
        var slug = b.getAttribute("data-compare-slug");
        var active = slug && list.indexOf(slug) !== -1;
        var full = !active && list.length >= MAX;
        b.setAttribute("aria-pressed", active ? "true" : "false");
        b.toggleAttribute("disabled", !!full);
        var activeLabel = b.querySelector("[data-compare-label-active]");
        var idleLabel = b.querySelector("[data-compare-label-idle]");
        var check = b.querySelector("[data-compare-check]");
        if (activeLabel) activeLabel.hidden = !active;
        if (idleLabel) idleLabel.hidden = !!active;
        if (check) check.hidden = !active;
        b.classList.toggle("is-active", !!active);
        b.classList.toggle("is-full", !!full);
      }
    }

    document.addEventListener("click", function (e) {
      var target = e.target instanceof Element ? e.target.closest("[data-compare-toggle]") : null;
      if (!target) return;
      e.preventDefault();
      e.stopPropagation();
      var slug = target.getAttribute("data-compare-slug");
      if (!slug) return;
      var list = load();
      var idx = list.indexOf(slug);
      if (idx !== -1) {
        list.splice(idx, 1);
      } else {
        if (list.length >= MAX) return;
        list.push(slug);
      }
      save(list);
      render(list);
      syncToggles(list);
    });

    if (clearEl) clearEl.addEventListener("click", function () { save([]); render([]); syncToggles([]); });
    if (hideEl) hideEl.addEventListener("click", function () { dismissed = true; dock.hidden = true; });

    window.addEventListener(EVENT, function (e) {
      var detail = e && e.detail;
      var list = Array.isArray(detail) ? detail : load();
      dismissed = false;
      render(list);
      syncToggles(list);
    });
    window.addEventListener("storage", function (ev) {
      if (ev.key && ev.key !== KEY) return;
      var list = load();
      render(list);
      syncToggles(list);
    });

    var initial = load();
    render(initial);
    syncToggles(initial);
  })();
</script>
