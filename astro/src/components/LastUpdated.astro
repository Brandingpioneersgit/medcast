---
/**
 * Small footer-strip for directory pages giving a visible "last updated"
 * / "last reviewed" signal — a small but real EEAT + helpful-content cue.
 *
 * Dates are supplied from the page so they reflect the data actually
 * displayed on that page rather than a static site-wide stamp.
 */
import { localizedPath, isLocale, defaultLocale, type Locale } from "@/lib/i18n";

interface Props {
  updated?: Date | string;
  reviewed?: Date | string;
  note?: string;
  locale?: Locale | string;
  showPolicyLink?: boolean;
  class?: string;
}
const { updated, reviewed, note, locale: rawLocale = defaultLocale, showPolicyLink = true, class: className } = Astro.props;
const locale: Locale = isLocale(rawLocale) ? (rawLocale as Locale) : defaultLocale;

function fmt(d: Date | string | undefined): string | null {
  if (!d) return null;
  const date = typeof d === "string" ? new Date(d) : d;
  if (Number.isNaN(date.getTime())) return null;
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
function iso(d: Date | string | undefined): string | null {
  if (!d) return null;
  const date = typeof d === "string" ? new Date(d) : d;
  if (Number.isNaN(date.getTime())) return null;
  return date.toISOString();
}

const updatedStr = fmt(updated);
const reviewedStr = fmt(reviewed);
const updatedIso = iso(updated);
const reviewedIso = iso(reviewed);
---

{(updatedStr || reviewedStr || note) && (
  <p class:list={["text-xs text-ink-subtle mt-8 flex flex-wrap gap-x-4 gap-y-1", className]}>
    {updatedStr && (
      <span>
        Last updated: <strong class="text-ink-muted"><time datetime={updatedIso}>{updatedStr}</time></strong>
      </span>
    )}
    {reviewedStr && (
      <span>
        Last medically reviewed: <strong class="text-ink-muted"><time datetime={reviewedIso}>{reviewedStr}</time></strong>
      </span>
    )}
    {note && <span>{note}</span>}
    {showPolicyLink && (
      <a href={localizedPath(locale, "/editorial-policy")} class="underline hover:text-accent">
        How we source &amp; review
      </a>
    )}
  </p>
)}
