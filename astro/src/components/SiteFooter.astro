---
import { db } from "@/lib/db";
import {
  specialties as specialtiesTbl,
  treatments as treatmentsTbl,
  countries as countriesTbl,
} from "../../../src/lib/db/schema";
import { asc, eq, sql } from "drizzle-orm";
import { localizedPath, type Locale } from "@/lib/i18n";
import McLogo from "@/components/McLogo.astro";
import CompareDock from "@/components/CompareDock.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const isRTL = locale === "ar";

type FooterData = {
  specialties: Array<{ slug: string; name: string }>;
  treatments: Array<{ slug: string; name: string }>;
  countries: Array<{ slug: string; name: string }>;
};

const EMPTY: FooterData = { specialties: [], treatments: [], countries: [] };
let data: FooterData = EMPTY;

try {
  const [specRows, treatRows, countryRows] = await Promise.all([
    db.execute<{ slug: string; name: string }>(sql`
      SELECT sp.slug, sp.name
      FROM specialties sp
      WHERE sp.is_active = true
      ORDER BY sp.sort_order ASC NULLS LAST, sp.name ASC
      LIMIT 6
    `),
    db
      .select({ slug: treatmentsTbl.slug, name: treatmentsTbl.name })
      .from(treatmentsTbl)
      .where(eq(treatmentsTbl.isActive, true))
      .orderBy(asc(treatmentsTbl.name))
      .limit(6),
    db
      .select({ slug: countriesTbl.slug, name: countriesTbl.name })
      .from(countriesTbl)
      .where(eq(countriesTbl.isDestination, true))
      .orderBy(asc(countriesTbl.name))
      .limit(6),
  ]);
  data = {
    specialties: Array.from(specRows),
    treatments: treatRows,
    countries: Array.from(countryRows),
  };
} catch {
  data = EMPTY;
}

const companyLinks: Array<{ href: string; label: string }> = [
  { href: "/about", label: "About" },
  { href: "/for-hospitals", label: "For Hospitals" },
  { href: "/medical-board", label: "Medical Review Panel" },
  { href: "/pricing-index", label: "Price Index (data)" },
  { href: "/blog", label: "Editorial" },
  { href: "/accreditation", label: "Accreditations" },
  { href: "/glossary", label: "Glossary" },
  { href: "/contact", label: "Contact" },
  { href: "/emergency", label: "Emergency" },
];

const trustBadges = ["JCI Partner", "ISO 27001", "GDPR", "HIPAA"];
const year = new Date().getFullYear();
---

<footer
  class="mt-auto"
  style="background: var(--color-ink); color: var(--color-bg);"
>
  <div class="mx-auto max-w-[1440px] px-7" style="padding-top: 64px; padding-bottom: 32px;">
    <nav aria-label="Footer links" class="footer-grid grid gap-10 md:gap-16">
      {/* Brand column */}
      <div class="col-span-2 md:col-span-1">
        <McLogo size={34} color="var(--color-bg)" />
        <p
          class="serif"
          style="font-size: 17px; line-height: 1.4; margin-top: 20px; opacity: 0.75; max-width: 280px;"
        >
          {isRTL ? "بوصلتك في العلاج الطبي العالمي." : "Your compass for global medical care."}
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {trustBadges.map((b) => (
            <span
              class="inline-flex items-center"
              style="font-size: 11px; padding: 4px 10px; border: 1px solid rgba(246,241,230,.25); border-radius: 9999px; opacity: 0.85;"
            >
              {b}
            </span>
          ))}
        </div>
      </div>

      {/* Specialties */}
      <div>
        <div
          class="mono"
          style="font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.5; margin-bottom: 16px;"
        >
          {isRTL ? "التخصصات" : "Specialties"}
        </div>
        <ul class="flex flex-col gap-2.5">
          {data.specialties.map((s) => (
            <li>
              <a
                href={localizedPath(locale, `/specialty/${s.slug}`)}
                style="font-size: 13.5px; opacity: 0.85; transition: opacity 120ms;"
                class="hover:opacity-100"
              >
                {s.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Treatments */}
      <div>
        <div
          class="mono"
          style="font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.5; margin-bottom: 16px;"
        >
          {isRTL ? "العلاجات" : "Treatments"}
        </div>
        <ul class="flex flex-col gap-2.5">
          {data.treatments.map((t) => (
            <li>
              <a
                href={localizedPath(locale, `/treatment/${t.slug}`)}
                style="font-size: 13.5px; opacity: 0.85;"
                class="hover:opacity-100 line-clamp-1"
              >
                {t.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Destinations */}
      <div>
        <div
          class="mono"
          style="font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.5; margin-bottom: 16px;"
        >
          {isRTL ? "الوجهات" : "Destinations"}
        </div>
        <ul class="flex flex-col gap-2.5">
          {data.countries.map((c) => (
            <li>
              <a
                href={localizedPath(locale, `/country/${c.slug}`)}
                style="font-size: 13.5px; opacity: 0.85;"
                class="hover:opacity-100"
              >
                {c.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Company */}
      <div>
        <div
          class="mono"
          style="font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.5; margin-bottom: 16px;"
        >
          {isRTL ? "الشركة" : "Company"}
        </div>
        <ul class="flex flex-col gap-2.5">
          {companyLinks.map((l) => (
            <li>
              <a
                href={localizedPath(locale, l.href)}
                style="font-size: 13.5px; opacity: 0.85;"
                class="hover:opacity-100"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <div style="margin-top: 56px; margin-bottom: 20px; height: 1px; background: rgba(246,241,230,0.12);" />
    <div
      class="flex flex-col md:flex-row md:items-center md:justify-between gap-3"
      style="font-size: 12px; opacity: 0.6;"
    >
      <div>© {year} MedCasts · Patient-first medical travel · Not a substitute for medical advice.</div>
      <div class="flex flex-wrap gap-5">
        <a href={localizedPath(locale, "/privacy-policy")}>Privacy</a>
        <a href={localizedPath(locale, "/terms")}>Terms</a>
        <a href={localizedPath(locale, "/editorial-policy")}>Medical Board</a>
        <a href={localizedPath(locale, "/sitemap.xml")}>Sitemap</a>
      </div>
    </div>
  </div>
  <CompareDock compareHref={localizedPath(locale, "/compare/hospitals")} />
</footer>

<style>
  .footer-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 960px) {
    .footer-grid {
      grid-template-columns: 1.2fr 1fr 1fr 1fr 1fr;
    }
  }
</style>
