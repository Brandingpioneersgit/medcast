---
// Medcasts logo — compass-cross glyph + wordmark.
// The medical "+" wrapped in a compass-cardinals ring. Coral period on "medcasts."
interface Props {
  size?: number;
  color?: string;
  mark?: boolean;
  wordmark?: boolean;
  class?: string;
}
const { size = 36, color = "currentColor", mark = true, wordmark = true, class: className = "" } = Astro.props;
const innerDotBg =
  color === "currentColor" ? "var(--color-bg)" : color === "#F6F1E6" ? "#0E1713" : "#F6F1E6";
---

<span class:list={["inline-flex items-center gap-2.5", className]} style={`color: ${color};`}>
  {mark && (
    <svg
      width={size}
      height={size}
      viewBox="0 0 48 48"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="24" cy="24" r="22" stroke={color} stroke-width="1.25" fill="none" opacity="0.35" />
      <g stroke={color} stroke-width="1.25" opacity="0.5">
        <line x1="24" y1="3" x2="24" y2="7" />
        <line x1="24" y1="41" x2="24" y2="45" />
        <line x1="3" y1="24" x2="7" y2="24" />
        <line x1="41" y1="24" x2="45" y2="24" />
      </g>
      <path d="M24 10 L24 38 M10 24 L38 24" stroke={color} stroke-width="4.25" stroke-linecap="round" />
      <circle cx="24" cy="24" r="3.25" fill={innerDotBg} />
      <circle cx="24" cy="24" r="1.5" fill={color} />
    </svg>
  )}
  {wordmark && (
    <span
      class="display display-tight"
      style={`font-weight: 600; font-size: ${size * 0.62}px; letter-spacing: -0.03em; line-height: 1;`}
    >
      medcasts<span style="color: var(--color-coral);">.</span>
    </span>
  )}
</span>
