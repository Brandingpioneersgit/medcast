---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { type Locale } from "@/lib/i18n";
import { ChevronRight } from "lucide-react";

const match = Astro.url.pathname.match(/^\/([a-z]{2})(\/|$)/);
const locale = (match && ["en", "ar", "ru", "fr", "pt", "bn", "tr", "hi"].includes(match[1])
  ? match[1]
  : "en") as Locale;

Astro.response.status = 404;

const LINKS = [
  { href: `/${locale}/hospitals`, label: "Browse hospitals", sub: "9,000+ accredited facilities" },
  { href: `/${locale}/treatments`, label: "Treatments & pricing", sub: "80+ procedures, country-ranked" },
  { href: `/${locale}/second-opinion`, label: "Free second opinion", sub: "48 hours, written, signed" },
  { href: `/${locale}/contact`, label: "Talk to a case manager", sub: "WhatsApp, email, phone" },
];
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title="Page not found"
      description="That page doesn't exist. Find what you're looking for via hospitals, treatments, or contact below."
      path="/404"
      locale={locale}
      noindex={true}
    />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <section style="padding: 96px 0 72px;">
      <div class="mx-auto w-full max-w-[60rem] px-5 md:px-8 text-center">
        <div class="display tnum mx-auto" style="font-size: clamp(6rem, 14vw, 10rem); line-height: 0.9; font-weight: 300; color: var(--color-accent); letter-spacing: -0.04em;">
          404
        </div>
        <p class="mono uppercase mt-4" style="font-size: 11px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
          Not in the directory
        </p>
        <h1
          class="display display-tight mt-3"
          style="font-size: clamp(2rem, 4.5vw, 3.5rem); line-height: 1.02; letter-spacing: -0.03em; font-weight: 400;"
        >
          This page took a <span class="italic-display">wrong turn.</span>
        </h1>
        <p class="serif mt-5 max-w-[36rem] mx-auto" style="font-size: 17px; line-height: 1.5; color: var(--color-ink-muted);">
          The URL doesn't match anything we publish. A few places that usually have what people are looking for:
        </p>

        <ul class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-[40rem] mx-auto">
          {LINKS.map((l) => (
            <li>
              <a
                href={l.href}
                class="paper group flex items-center justify-between text-start transition hover:-translate-y-0.5"
                style="padding: 18px 20px;"
              >
                <div>
                  <div class="serif" style="font-size: 16px; line-height: 1.25; color: var(--color-ink);">
                    {l.label}
                  </div>
                  <div class="mono uppercase mt-1" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle);">
                    {l.sub}
                  </div>
                </div>
                <ChevronRight className="h-4 w-4 mirror-x text-[var(--color-ink-subtle)] group-hover:text-[var(--color-accent)] transition-colors" />
              </a>
            </li>
          ))}
        </ul>

        <p class="mt-12 mono uppercase" style="font-size: 10.5px; letter-spacing: 0.12em; color: var(--color-ink-subtle);">
          Broken hospital URL · Email <a href="mailto:corrections@medcasts.com" style="color: var(--color-accent);">corrections@medcasts.com</a> — redirects restored weekly
        </p>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
