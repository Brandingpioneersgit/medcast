---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import LastUpdated from "@/components/LastUpdated.astro";
import PhotoBlock from "@/components/PhotoBlock.astro";
import { getCityBySlug } from "@/lib/queries";
import {
  getContentBatch,
  applyTranslated,
} from "@/lib/translate";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl, itemListJsonLd, withProvenance } from "@/lib/seo";
import { ChevronRight } from "lucide-react";
import { hospitalCover } from "@/lib/images";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
const slug = Astro.params.slug;
if (!isLocale(rawLocale)) return Astro.redirect(`/en/city/${slug}`, 308);
if (!slug) return new Response("Not found", { status: 404 });

const locale = rawLocale as Locale;
const data = await getCityBySlug(slug);
if (!data) return new Response(`Not found: ${slug}`, { status: 404 });

const tc = getTranslator(locale, "common");

const { city, hospitals, specialtyCounts } = data;
const country = city.country;

const hospitalIds = hospitals.map((h) => h.id);
const hospitalMap = await getContentBatch("hospital", hospitalIds, locale);
const hospitalsXl = hospitals.map((h) => applyTranslated(h, hospitalMap[h.id] ?? {}, ["name", "description"]));

const FLAG_MAP: Record<string, string> = {
  india: "🇮🇳", turkey: "🇹🇷", thailand: "🇹🇭", uae: "🇦🇪",
  germany: "🇩🇪", singapore: "🇸🇬", "south-korea": "🇰🇷",
  malaysia: "🇲🇾", "saudi-arabia": "🇸🇦",
};
function countryFlag(s: string | undefined | null): string { return s ? (FLAG_MAP[s] ?? "🌐") : "🌐"; }
function firstWord(s: string) { const i = s.indexOf(" "); return i === -1 ? s : s.slice(0, i); }
function restOfName(s: string) { const i = s.indexOf(" "); return i === -1 ? "" : s.slice(i + 1); }

const ratedHospitals = hospitalsXl.filter((h) => h.rating && Number(h.rating) > 0);
const avgRating = ratedHospitals.length > 0
  ? ratedHospitals.reduce((s, h) => s + Number(h.rating ?? 0), 0) / ratedHospitals.length
  : null;
const totalBeds = hospitalsXl.reduce((s, h) => s + (h.bedCapacity ?? 0), 0);

const stats = [
  { l: "Hospitals", v: hospitals.length.toLocaleString() },
  { l: "Specialties", v: specialtyCounts.length.toString() },
  avgRating ? { l: "Avg rating", v: avgRating.toFixed(1) } : null,
  totalBeds > 0 ? { l: "Inpatient beds", v: totalBeds.toLocaleString() } : null,
].filter(Boolean) as Array<{ l: string; v: string }>;

const topHospitals = hospitalsXl
  .slice()
  .sort((a, b) => (Number(b.rating ?? 0) - Number(a.rating ?? 0)) || ((b.reviewCount ?? 0) - (a.reviewCount ?? 0)))
  .slice(0, 6);
const remainingHospitals = hospitalsXl.length > 6 ? hospitalsXl.slice(6) : [];

const seoTitle = `Hospitals in ${city.name}${country ? `, ${country.name}` : ""}`;
const seoDescription = `Compare ${hospitals.length} accredited hospitals in ${city.name}${country ? `, ${country.name}` : ""}. Specialist care across ${specialtyCounts.length} medical specialties. Free second opinion and treatment quotes.`.slice(0, 160);

const path = `/city/${slug}`;
const url = localeUrl(locale, path);

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  ...(country
    ? [{ name: country.name, url: localeUrl(locale, `/country/${country.slug}`) }]
    : []),
  { name: city.name, url },
]);

const itemLd = hospitalsXl.length > 0
  ? withProvenance(
      itemListJsonLd(
        hospitalsXl.map((h) => ({
          name: h.name,
          url: localeUrl(locale, `/hospital/${h.slug}`),
        })),
      ),
      { dateModified: city.createdAt ?? undefined, dateCreated: city.createdAt ?? undefined },
    )
  : null;

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} />
    {itemLd && <script type="application/ld+json" set:html={JSON.stringify(itemLd)} />}
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <div style="background: var(--color-paper); border-bottom: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8 py-4">
        <nav class="mono text-[12px]" style="color: var(--color-ink-subtle);" aria-label="Breadcrumb">
          <a href={localizedPath(locale, "/")} class="hover:text-ink">{tc("home")}</a>
          <span class="mx-1.5">/</span>
          {country && (
            <>
              <a href={localizedPath(locale, `/country/${country.slug}`)} class="hover:text-ink">{country.name}</a>
              <span class="mx-1.5">/</span>
            </>
          )}
          <span style="color: var(--color-ink);">{city.name}</span>
        </nav>
      </div>
    </div>

    <section class="pt-12 md:pt-16">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8">
        <p class="mono uppercase flex items-center gap-2" style="font-size: 11px; letter-spacing: 0.14em; color: var(--color-accent);">
          <span aria-hidden="true" style="font-size: 14px;">{countryFlag(country?.slug)}</span>
          {country?.name ?? "Destination"} · City hub
        </p>
        <div class="grid gap-10 lg:grid-cols-[1.5fr,1fr] lg:gap-14 mt-3">
          <div>
            <h1
              class="display display-tight"
              style="font-size: clamp(2.25rem, 5vw, 4.5rem); line-height: 0.98; font-weight: 400; letter-spacing: -0.03em;"
            >
              Hospitals in <span class="italic-display">{city.name}</span>
            </h1>
            <p class="serif mt-5 max-w-[44rem]" style="font-size: 19px; line-height: 1.5; color: var(--color-ink-muted);">
              {hospitals.length} accredited hospitals{country ? ` in ${city.name}, ${country.name}` : ` in ${city.name}`} serving international patients across {specialtyCounts.length} specialties. Compare facilities, pricing, and physician profiles.
            </p>
            <LastUpdated updated={city.createdAt ?? null} locale={locale} class="mt-5" />

            {stats.length > 0 && (
              <div
                class="mt-8 grid"
                style={`grid-template-columns: repeat(${stats.length}, minmax(0,1fr)); border-top: 1px solid var(--color-ink); border-bottom: 1px solid var(--color-border);`}
              >
                {stats.map((s, i) => (
                  <div
                    class="px-4 md:px-5 py-5"
                    style={i > 0 ? "border-inline-start: 1px solid var(--color-border);" : ""}
                  >
                    <div class="mono uppercase" style="font-size: 9.5px; letter-spacing: 0.1em; color: var(--color-ink-subtle);">
                      {s.l}
                    </div>
                    <div class="display tnum mt-1.5" style="font-size: 28px;">{s.v}</div>
                  </div>
                ))}
              </div>
            )}
          </div>

          <div class="lg:sticky lg:top-32 lg:self-start">
            <div
              class="map-bg relative overflow-hidden rounded-[var(--radius-lg)]"
              style="aspect-ratio: 4/3; border: 1px solid var(--color-border);"
            >
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span aria-hidden="true" style="font-size: 48px;">{countryFlag(country?.slug)}</span>
                <div class="display mt-3" style="font-size: 42px; line-height: 0.95; color: var(--color-ink); letter-spacing: -0.02em;">
                  {city.name}
                </div>
                {country && (
                  <div class="mono uppercase mt-2" style="font-size: 11px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                    {country.name}
                  </div>
                )}
              </div>
            </div>
            <div class="paper mt-4" style="padding: 16px 18px;">
              <div class="mono uppercase" style="font-size: 9.5px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                Free quote · 48 hours
              </div>
              <div class="serif mt-1.5" style="font-size: 16px; line-height: 1.4;">
                Get 3 itemised quotes from {city.name} hospitals matched to your case.
              </div>
              <a
                href={localizedPath(locale, `/contact?city=${slug}`)}
                class="mt-3 inline-flex items-center gap-1 text-sm font-semibold"
                style="background: var(--color-ink); color: var(--color-bg); padding: 10px 16px; border-radius: 9999px;"
              >
                Request quotes
                <ChevronRight className="h-3.5 w-3.5 mirror-x" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    {specialtyCounts.length > 0 && (
      <section style="padding: 72px 0; border-top: 1px solid var(--color-border-soft); margin-top: 56px;">
        <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
          <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
            <div>
              <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                01 · Specialties offered
              </div>
              <h2 class="display mt-3" style="font-size: 32px; letter-spacing: -0.02em;">
                What <span class="italic-display">{city.name}</span> is known for
              </h2>
            </div>
            <a
              href={localizedPath(locale, "/specialties")}
              class="mono text-[11px] uppercase tracking-wider hover:text-accent"
              style="color: var(--color-ink-subtle);"
            >
              All specialties →
            </a>
          </div>
          <ul class="flex flex-wrap gap-2.5">
            {specialtyCounts.map((s) => (
              <li>
                <a
                  href={localizedPath(locale, `/specialty/${s.slug}`)}
                  class="inline-flex items-center gap-2 hover:-translate-y-0.5 transition"
                  style="background: var(--color-paper); border: 1px solid var(--color-border); padding: 10px 16px; border-radius: 9999px;"
                >
                  <span class="serif" style="font-size: 14px; color: var(--color-ink);">{s.name}</span>
                  <span class="mono tnum" style="font-size: 10.5px; color: var(--color-accent); letter-spacing: 0.05em;">
                    {s.hospital_count}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    {topHospitals.length > 0 && (
      <section style="padding: 72px 0; border-top: 1px solid var(--color-border-soft);">
        <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
          <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
            <div>
              <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                02 · Top-rated
              </div>
              <h2 class="display mt-3" style="font-size: 32px; letter-spacing: -0.02em;">
                Leading hospitals in {city.name}
              </h2>
            </div>
          </div>
          <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
            {topHospitals.map((h) => (
              <li>
                <a
                  href={localizedPath(locale, `/hospital/${h.slug}`)}
                  class="paper group flex h-full flex-col overflow-hidden transition hover:-translate-y-0.5"
                  style="padding: 0;"
                >
                  <PhotoBlock
                    aspect="16/10"
                    rounded={false}
                    imgUrl={hospitalCover({ coverImageUrl: h.coverImageUrl, countrySlug: country?.slug })}
                    alt={h.name}
                  />
                  <div class="p-5 flex flex-col flex-1">
                    <div class="serif" style="font-size: 19px; line-height: 1.25; letter-spacing: -0.005em; color: var(--color-ink);">
                      {h.name}
                    </div>
                    {h.description && (
                      <p class="mt-2 serif line-clamp-2" style="font-size: 14px; line-height: 1.5; color: var(--color-ink-muted);">
                        {h.description}
                      </p>
                    )}
                    <div
                      class="mt-auto flex items-center justify-between"
                      style="border-top: 1px dashed var(--color-border); margin-top: 14px; padding-top: 12px;"
                    >
                      <div class="flex items-center gap-3 text-[12.5px]" style="color: var(--color-ink-muted);">
                        {h.rating && Number(h.rating) > 0 && (
                          <span class="inline-flex items-center gap-1">
                            <span style="color: var(--color-saffron);">★</span>
                            <span class="tnum">{Number(h.rating).toFixed(1)}</span>
                          </span>
                        )}
                        {h.bedCapacity && (
                          <span class="tnum">{h.bedCapacity.toLocaleString()} beds</span>
                        )}
                      </div>
                      <span
                        class="inline-flex items-center gap-1 text-[12px] font-semibold"
                        style="background: var(--color-ink); color: var(--color-bg); padding: 6px 12px; border-radius: 9999px;"
                      >
                        View
                        <ChevronRight className="h-3 w-3 mirror-x" />
                      </span>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    {remainingHospitals.length > 0 && (
      <section style="padding: 56px 0; border-top: 1px solid var(--color-border-soft);">
        <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
          <div class="mb-6">
            <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
              03 · Full directory
            </div>
            <h2 class="display mt-3" style="font-size: 28px; letter-spacing: -0.02em;">
              All hospitals in {city.name}
            </h2>
          </div>
          <ul>
            {remainingHospitals.map((h, i) => (
              <li
                class="grid items-center gap-4 py-4"
                style={`grid-template-columns: 28px 1fr auto auto; ${i > 0 ? "border-top: 1px dashed var(--color-border);" : "border-top: 1px dashed var(--color-border);"}`}
              >
                <div class="display tnum" style="font-size: 14px; color: var(--color-ink-subtle);">
                  {String(i + topHospitals.length + 1).padStart(2, "0")}
                </div>
                <a
                  href={localizedPath(locale, `/hospital/${h.slug}`)}
                  class="serif hover:text-accent transition-colors"
                  style="font-size: 16px; color: var(--color-ink);"
                >
                  {h.name}
                </a>
                <div class="flex items-center gap-3 text-[12px] tnum" style="color: var(--color-ink-subtle);">
                  {h.rating && Number(h.rating) > 0 && (
                    <span><span style="color: var(--color-saffron);">★</span> {Number(h.rating).toFixed(1)}</span>
                  )}
                  {h.bedCapacity && <span>{h.bedCapacity} beds</span>}
                </div>
                <ChevronRight className="h-3.5 w-3.5 mirror-x text-[var(--color-ink-subtle)]" />
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <section style="background: var(--color-ink); color: var(--color-bg); padding: 72px 0;">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="grid gap-8 lg:grid-cols-[1.5fr,1fr] items-end">
          <div>
            <div class="mono uppercase" style="font-size: 11px; letter-spacing: 0.16em; color: rgba(246,241,230,0.55);">
              Travelling to {city.name}
            </div>
            <h2 class="display mt-3" style="font-size: clamp(2rem, 4vw, 3.25rem); line-height: 1.02; letter-spacing: -0.02em; color: var(--color-bg);">
              Shortlist 3 hospitals in <span class="italic-display">{city.name}</span>, 48 hours.
            </h2>
            <p class="serif mt-4 max-w-[42rem]" style="font-size: 17px; line-height: 1.5; color: rgba(246,241,230,0.75);">
              Tell us your procedure, budget, and preferred dates. Our coordinators return itemised quotes from matched hospitals — no fee, no obligation.
            </p>
          </div>
          <div class="flex flex-wrap gap-3 lg:justify-end">
            <a
              href={localizedPath(locale, `/contact?city=${slug}`)}
              class="inline-flex items-center gap-2 font-semibold"
              style="background: var(--color-bg); color: var(--color-ink); padding: 14px 22px; border-radius: 9999px;"
            >
              Request quotes
              <ChevronRight className="h-4 w-4 mirror-x" />
            </a>
            {country && (
              <a
                href={localizedPath(locale, `/country/${country.slug}`)}
                class="inline-flex items-center gap-2 font-semibold"
                style="border: 1px solid rgba(246,241,230,0.35); color: var(--color-bg); padding: 13px 22px; border-radius: 9999px;"
              >
                {country.name} guide
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
