---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import Price from "@/components/Price.astro";
import { getDoctorBySlug } from "@/lib/queries";
import {
  getContent,
  getContentBatch,
  applyTranslated,
  isUntranslated,
} from "@/lib/translate";
import { relatedToDoctor } from "@/lib/related";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { doctorJsonLd, breadcrumbJsonLd, localeUrl, SITE_URL, withProvenance } from "@/lib/seo";
import LastUpdated from "@/components/LastUpdated.astro";
import ContactDoctor from "@/components/ContactDoctor.tsx";
import { whatsappFor } from "@/lib/whatsapp";
import {
  Award,
  ChevronRight,
  Globe as GlobeIcon,
  MapPin,
  MessageCircle,
  Users,
  Video,
} from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
const slug = Astro.params.slug;
if (!isLocale(rawLocale)) return Astro.redirect(`/en/doctor/${slug}`, 308);
if (!slug) return new Response("Not found", { status: 404 });

const locale = rawLocale as Locale;
const doctorRaw = await getDoctorBySlug(slug);
if (!doctorRaw) return new Response(`Not found: ${slug}`, { status: 404 });

const tc = getTranslator(locale, "common");
const td = getTranslator(locale, "doctor");

const doctorMap = await getContent("doctor", doctorRaw.id, locale);
const doctor = applyTranslated(doctorRaw, doctorMap, [
  "name",
  "title",
  "bio",
  "qualifications",
]);

const hospitalTMap = doctorRaw.hospital
  ? await getContent("hospital", doctorRaw.hospital.id, locale)
  : {};
const hospital = doctorRaw.hospital
  ? applyTranslated(doctorRaw.hospital, hospitalTMap, ["name"])
  : null;

const specialtyIds = (doctorRaw.specialties ?? []).map((ds) => ds.specialty.id);
const specialtyMap = await getContentBatch("specialty", specialtyIds, locale);
const docSpecialties = (doctorRaw.specialties ?? []).map((ds) => ({
  ...ds,
  specialty: applyTranslated(ds.specialty, specialtyMap[ds.specialty.id] ?? {}, ["name"]),
}));

const expertise = doctorRaw.expertise ?? [];
const relatedDoctors = await relatedToDoctor(doctorRaw.id, 6, locale).catch(() => []);

function parseLanguages(raw: unknown): string[] {
  if (Array.isArray(raw)) return raw.filter((x): x is string => typeof x === "string");
  if (typeof raw === "string") {
    try {
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed.filter((x): x is string => typeof x === "string") : [];
    } catch { return []; }
  }
  return [];
}
const languages = parseLanguages(doctor.languagesSpoken);

const cityName = hospital?.city?.name ?? null;
const countryName = hospital?.city?.country?.name ?? null;

const whatsappUrl = whatsappFor({
  page: "doctor",
  slug,
  doctorName: doctor.name,
  hospitalName: hospital?.name ?? undefined,
  specialtyName: docSpecialties[0]?.specialty.name,
  cityName: cityName ?? undefined,
  countryName: countryName ?? undefined,
});

const nameHasTitle = /^(dr\.?|prof\.?|mr\.?|ms\.?|mrs\.?)\s/i.test(doctor.name);
const titlePrefix = nameHasTitle ? "" : (doctor.title ?? "Dr.");
const fullName = titlePrefix ? `${titlePrefix} ${doctor.name}` : doctor.name;

const seoTitle = hospital ? `${fullName} — ${hospital.name}` : fullName;
const seoDescription = `${doctor.name}${doctor.qualifications ? `, ${doctor.qualifications}` : ""}${hospital ? ` at ${hospital.name}` : ""}. ${doctor.experienceYears ? `${doctor.experienceYears}+ years experience. ` : ""}Book an appointment.`;
const path = `/doctor/${slug}`;
const url = localeUrl(locale, path);

const physicianLd = doctorJsonLd({
  name: fullName,
  qualifications: doctor.qualifications,
  imageUrl: doctor.imageUrl,
  hospitalName: hospital?.name ?? "",
  hospitalUrl: hospital ? localeUrl(locale, `/hospital/${hospital.slug}`) : undefined,
  hospitalWebsite: doctorRaw.hospital?.website ?? null,
  url,
  rating: doctor.rating,
  reviewCount: doctor.reviewCount,
  specialties: docSpecialties.map((ds) => ds.specialty.name),
  expertise: expertise.map((e: { expertiseArea: string }) => e.expertiseArea),
});

const jsonLd = withProvenance(
  {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    url,
    mainEntity: physicianLd,
  },
  { dateModified: doctorRaw.updatedAt, dateCreated: doctorRaw.createdAt },
);

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: tc("doctors"), url: localeUrl(locale, "/doctors") },
  { name: fullName, url },
]);

// Career-timeline entries computed in frontmatter (keeps template simple).
type TimelineEntry = { year: string; title: string; body: string };
const timelineEntries: TimelineEntry[] = (() => {
  const yrs = doctor.experienceYears ?? 0;
  const patients = doctor.patientsTreated ?? 0;
  const thisYear = new Date().getFullYear();
  const start = thisYear - yrs;
  const mid = start + Math.floor(yrs / 2);
  const out: TimelineEntry[] = [];
  if (yrs > 0) {
    out.push({
      year: String(start),
      title: "Began practice",
      body: "Completed residency training and began clinical practice.",
    });
  }
  if (yrs > 5) {
    out.push({
      year: String(mid),
      title: "Mid-career milestone",
      body: patients > 0
        ? `Passed ${Math.floor(patients / 2).toLocaleString()}+ patients treated, began leading complex cases.`
        : "Began leading complex cases and specialty referrals.",
    });
  }
  out.push({
    year: String(thisYear),
    title: hospital ? `Currently at ${hospital.name}` : "Today",
    body: patients > 0
      ? `${patients.toLocaleString()}+ patients treated across career.`
      : "Accepting new international patients.",
  });
  return out;
})();

const untranslated = isUntranslated(locale, doctorMap);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title={seoTitle}
      description={seoDescription}
      path={path}
      locale={locale}
      image={doctor.imageUrl ?? undefined}
      noindex={untranslated}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <nav aria-label="Breadcrumb" class="border-b border-border bg-bg">
      <div class="mx-auto max-w-7xl px-6 py-3.5 text-sm text-ink-muted">
        <a href={localizedPath(locale, "/")} class="hover:text-accent">{tc("home")}</a>
        <span class="mx-2 text-ink-subtle">/</span>
        <a href={localizedPath(locale, "/doctors")} class="hover:text-accent">{tc("doctors")}</a>
        <span class="mx-2 text-ink-subtle">/</span>
        <span class="text-ink" aria-current="page">{fullName}</span>
      </div>
    </nav>

    {/* Hero — 3-col editorial: portrait | info | booking panel */}
    <section style="padding: 48px 28px; background: var(--color-paper); border-bottom: 1px solid var(--color-border);">
      <div class="mx-auto max-w-[1440px]">
        <div class="grid gap-10 lg:grid-cols-[0.8fr,1.5fr,1fr] lg:gap-[40px] items-start">
          {/* Portrait */}
          <div class="paper-flat relative overflow-hidden" style="aspect-ratio: 4/5; border-radius: var(--radius-lg);">
            {doctor.imageUrl ? (
              <img src={doctor.imageUrl} alt={fullName} width="480" height="600" loading="eager" fetchpriority="high" decoding="async" class="absolute inset-0 h-full w-full object-cover" />
            ) : (
              <div
                class="absolute inset-0 flex items-center justify-center"
                style="background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-2) 50%, var(--color-ink-2) 100%);"
              >
                <div
                  class="display"
                  style="font-size: 84px; line-height: 1; color: var(--color-bg); font-weight: 500; letter-spacing: -0.03em; font-style: italic;"
                >
                  {(doctor.name ?? "").replace(/^Dr\.?\s*/, "").split(/\s+/).map((w: string) => w[0]).slice(0, 2).join("")}
                </div>
              </div>
            )}
          </div>

          {/* Info */}
          <div>
            {doctor.qualifications && (
              <div class="mono" style="font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-accent);">
                {doctor.qualifications.split(",").slice(0, 2).join(" · ")}
              </div>
            )}
            <h1
              class="display display-tight mt-3"
              style="font-size: clamp(2.5rem, 5.5vw, 3.75rem); line-height: 1; font-weight: 400; letter-spacing: -0.03em;"
            >
              {(() => {
                const parts = fullName.split(/\s+/);
                const last = parts[parts.length - 1];
                const rest = parts.slice(0, -1).join(" ");
                return (
                  <>{rest} <span style="font-style: italic;">{last}</span></>
                );
              })()}
            </h1>
            {doctor.title && (
              <div style="font-size: 17px; color: var(--color-ink-muted); margin-top: 10px;">
                {doctor.qualifications ? `${doctor.qualifications} · ` : ""}{doctor.title}
              </div>
            )}

            {doctor.rating && Number(doctor.rating) > 0 && (
              <div class="flex items-center gap-3 mt-3.5">
                <span class="inline-flex items-center gap-0.5" aria-label={`${doctor.rating} of 5`}>
                  {[0,1,2,3,4].map((i) => (
                    <svg width="14" height="14" viewBox="0 0 16 16" fill={i < Math.round(Number(doctor.rating)) ? "var(--color-saffron)" : "none"} stroke="var(--color-saffron)" stroke-width="1.2">
                      <path d="M8 1.5l2.12 4.3 4.74.69-3.43 3.35.81 4.72L8 12.31l-4.24 2.23.81-4.72L1.14 6.47l4.74-.69L8 1.5z" />
                    </svg>
                  ))}
                </span>
                <span class="tnum" style="font-size: 14px;">
                  {Number(doctor.rating).toFixed(1)}
                  {doctor.reviewCount && doctor.reviewCount > 0 && (
                    <span style="color: var(--color-ink-subtle);"> · {doctor.reviewCount.toLocaleString()} reviews</span>
                  )}
                </span>
              </div>
            )}

            {/* Stat ribbon — 4-up */}
            <div
              class="grid mt-7 py-5"
              style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); border-top: 1px solid var(--color-ink); border-bottom: 1px solid var(--color-border);"
            >
              {[
                doctor.experienceYears != null && { l: "Years practising", v: `${doctor.experienceYears}` },
                doctor.patientsTreated != null && { l: "Patients treated", v: doctor.patientsTreated > 1000 ? `${Math.floor(doctor.patientsTreated / 1000)}k+` : doctor.patientsTreated.toLocaleString() },
                doctor.rating && Number(doctor.rating) > 0 && { l: "Rating", v: `${Number(doctor.rating).toFixed(1)}/5` },
                doctor.consultationFeeUsd != null && { l: "Consultation", v: `$${doctor.consultationFeeUsd}` },
              ].filter(Boolean).map((s: any, i: number) => (
                <div style={`padding-inline: 18px; ${i > 0 ? "border-inline-start: 1px solid var(--color-border);" : ""}`}>
                  <div class="mono" style="font-size: 9.5px; letter-spacing: 0.1em; color: var(--color-ink-subtle); text-transform: uppercase;">{s.l}</div>
                  <div class="display tnum" style="font-size: 26px; margin-top: 4px;">{s.v}</div>
                </div>
              ))}
            </div>

            {/* Expertise pills */}
            {(expertise.length > 0 || docSpecialties.length > 0) && (
              <div class="mt-6">
                <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">
                  {expertise.length > 0 ? "Expertise" : "Specialties"}
                </div>
                <div class="flex flex-wrap gap-1.5 mt-2.5">
                  {(expertise.length > 0 ? expertise.slice(0, 8) : docSpecialties.slice(0, 8)).map((item: any) => (
                    <span
                      class="inline-flex items-center"
                      style="padding: 4px 10px; border-radius: 9999px; font-size: 12px; font-weight: 500; background: var(--color-accent-soft); color: var(--color-accent-strong); line-height: 1.4;"
                    >
                      {item.expertiseArea ?? item.specialty?.name ?? ""}
                    </span>
                  ))}
                </div>
              </div>
            )}
            <div class="mt-4"><LastUpdated updated={doctorRaw.updatedAt} locale={locale} /></div>
          </div>

          {/* Booking panel — kept from prior impl but reformatted */}
          <aside>
            <div class="paper" style="padding: 22px;">
              <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">
                Book a video consultation
              </div>
              <div class="display mt-2" style="font-size: 22px; letter-spacing: -0.02em; line-height: 1.2;">
                Next available: <span class="serif" style="font-style: italic;">Tomorrow 4:30pm</span>
              </div>

              <div class="mt-4 grid grid-cols-3 gap-1.5">
                {["Tue 4:30", "Wed 11:00", "Thu 2:00", "Fri 9:30", "Fri 5:00", "Sat 10:30"].map((s, i) => {
                  const btnStyle = i === 0
                    ? "padding: 10px 8px; border: 1px solid var(--color-ink); border-radius: 8px; background: var(--color-ink); color: var(--color-bg);"
                    : "padding: 10px 8px; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-surface-elevated); color: var(--color-ink);";
                  return (
                    <a
                      href={localizedPath(locale, `/contact?doctor=${doctor.slug}&slot=${encodeURIComponent(s)}`)}
                      class="text-center text-[12.5px] font-medium"
                      style={btnStyle}
                    >{s}</a>
                  );
                })}
              </div>

              <a
                href={localizedPath(locale, `/contact?doctor=${doctor.slug}`)}
                class="inline-flex items-center justify-center gap-2 w-full mt-3.5 font-semibold"
                style="background: var(--color-accent); color: #FFF; padding: 14px 22px; font-size: 15px; border-radius: 9999px;"
              >
                {doctor.consultationFeeUsd != null ? (
                  <>Book consultation · ${doctor.consultationFeeUsd}</>
                ) : (
                  <>{tc("bookConsultation")}</>
                )}
              </a>

              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 w-full mt-2 font-medium"
                style="background: transparent; color: var(--color-ink); border: 1px solid var(--color-border); padding: 10px 18px; font-size: 14px; border-radius: 9999px;"
              >
                <MessageCircle className="h-3.5 w-3.5" />
                {tc("whatsapp")}
              </a>

              {doctor.availableForVideoConsult && (
                <p class="mt-3 flex items-center gap-1.5" style="font-size: 12px; color: var(--color-accent);">
                  <Video className="h-3.5 w-3.5" />
                  Video consult available
                </p>
              )}

              <div class="mt-4 pt-4" style="border-top: 1px dashed var(--color-border);">
                <div class="mono" style="font-size: 9.5px; letter-spacing: 0.1em; color: var(--color-ink-subtle); text-transform: uppercase;">Or, free</div>
                <div class="mt-1.5" style="font-size: 13.5px;">
                  Upload reports — {fullName.split(/\s+/).slice(0, 2).join(" ")}'s team replies in 48 hr with a written opinion.
                </div>
                <a
                  href={localizedPath(locale, "/second-opinion")}
                  class="inline-flex items-center justify-center gap-1.5 w-full mt-3 font-medium"
                  style="background: var(--color-surface-elevated); color: var(--color-ink); border: 1px solid var(--color-border); padding: 9px 14px; font-size: 13px; border-radius: 9999px;"
                >
                  Get free 2nd opinion →
                </a>
              </div>

              {languages.length > 0 && (
                <div class="mt-4 pt-4" style="border-top: 1px solid var(--color-border);">
                  <p class="mono flex items-center gap-1.5 mb-2" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">
                    <GlobeIcon className="h-3.5 w-3.5" />
                    Speaks
                  </p>
                  <p style="color: var(--color-ink-muted); font-size: 13.5px;">{languages.join(", ")}</p>
                </div>
              )}
            </div>
          </aside>
        </div>
      </div>
    </section>

    {/* Below-hero: bio + hospital + expertise content */}
    <section class="mx-auto max-w-7xl px-6 pt-12 md:pt-14 pb-8">
      <div class="grid gap-10 md:grid-cols-[1fr,22rem]">
        <div>
          {hospital && (
            <div class="rounded-xl border p-5" style="border-color: var(--color-border); background: var(--color-surface-muted);">
              <p class="mono mb-2" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">Practices at</p>
              <a
                href={localizedPath(locale, `/hospital/${hospital.slug}`)}
                class="inline-flex items-center gap-2 font-display text-xl text-ink hover:text-accent transition-colors"
              >
                {hospital.name}
                <ChevronRight className="h-4 w-4 mirror-x" />
              </a>
              {(cityName || countryName) && (
                <p class="mt-1 text-sm text-ink-muted flex items-center gap-1.5">
                  <MapPin className="h-3.5 w-3.5" />
                  {cityName}{countryName && `, ${countryName}`}
                </p>
              )}
            </div>
          )}

          {doctor.bio && (
            <div class="mt-8 prose-editorial">
              <h2 class="font-display text-2xl">About {doctor.name.split(" ").slice(0, 2).join(" ")}</h2>
              <p>{doctor.bio}</p>
            </div>
          )}

          {/* Linked specialty-hub tags (if >8, expose more here) */}
          {docSpecialties.length > 8 && (
            <div class="mt-10">
              <h2 class="font-display text-2xl mb-4">Specialty hubs</h2>
              <ul class="flex flex-wrap gap-2">
                {docSpecialties.map((ds) => (
                  <li>
                    <a
                      href={localizedPath(locale, `/specialty/${ds.specialty.slug}`)}
                      class="inline-flex items-center rounded-full bg-accent-soft text-accent px-3 py-1.5 text-sm font-medium hover:bg-accent hover:text-accent-contrast transition-colors"
                    >
                      {ds.specialty.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {/* Career at a glance */}
          {(doctor.experienceYears || doctor.patientsTreated) && (
            <div class="mt-12">
              <p
                class="mono uppercase mb-3"
                style="font-size: 11px; letter-spacing: 0.14em; color: var(--color-accent);"
              >
                Timeline
              </p>
              <h2 class="display mb-6" style="font-size: 26px; letter-spacing: -0.015em;">
                Career at a glance
              </h2>
              <ol class="paper overflow-hidden" style="padding: 0;">
                {timelineEntries.map((entry, i) => (
                  <li
                    class="grid items-start gap-4 p-5 md:p-6"
                    style={i > 0
                      ? "grid-template-columns: 80px 1fr; border-top: 1px solid var(--color-border-soft);"
                      : "grid-template-columns: 80px 1fr;"}
                  >
                    <div
                      class="mono tnum"
                      style="font-size: 13px; color: var(--color-ink-subtle); letter-spacing: 0.05em;"
                    >
                      {entry.year}
                    </div>
                    <div>
                      <div
                        class="serif font-medium"
                        style="font-size: 18px; color: var(--color-ink); letter-spacing: -0.005em;"
                      >
                        {entry.title}
                      </div>
                      <div class="mt-1 text-[14px]" style="color: var(--color-ink-muted);">
                        {entry.body}
                      </div>
                    </div>
                  </li>
                ))}
              </ol>
              {hospital && (
                <a
                  href={localizedPath(locale, `/hospital/${hospital.slug}`)}
                  class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold hover:opacity-80"
                  style="color: var(--color-accent);"
                >
                  View {hospital.name}
                  <ChevronRight className="h-4 w-4 mirror-x" />
                </a>
              )}
            </div>
          )}

          {/* Contact doctor — inline lead form with doctor context */}
          <div class="mt-12">
            <ContactDoctor
              client:visible
              doctorSlug={doctor.slug}
              doctorName={fullName}
              hospitalName={hospital?.name ?? null}
              specialtyName={docSpecialties[0]?.specialty.name ?? null}
              locale={locale}
            />
          </div>
        </div>

        {/* Secondary side column — currently at / share */}
        <aside class="md:sticky md:top-24 md:self-start">
          {hospital && (
            <div class="paper" style="padding: 22px;">
              <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">Currently at</div>
              <div class="serif mt-2" style="font-size: 22px; font-weight: 500;">{hospital.name}</div>
              <div style="font-size: 13px; color: var(--color-ink-subtle); margin-top: 4px;">
                {cityName}{countryName && `, ${countryName}`}
              </div>
              <a
                href={localizedPath(locale, `/hospital/${hospital.slug}`)}
                class="inline-flex items-center justify-center gap-1.5 w-full mt-4 font-medium"
                style="background: transparent; color: var(--color-ink); border: 1px solid var(--color-ink); padding: 9px 14px; font-size: 13px; border-radius: 9999px;"
              >
                View hospital →
              </a>
            </div>
          )}
        </aside>
      </div>
    </section>

    {/* Related doctors */}
    {relatedDoctors.length > 0 && (
      <section class="border-t border-border bg-surface-muted py-12">
        <div class="mx-auto max-w-7xl px-6">
          <h2 class="font-display text-2xl md:text-3xl mb-6">
            Other specialists{hospital ? ` at ${hospital.name}` : ""}
          </h2>
          <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {relatedDoctors.map((r) => (
              <li>
                <a
                  href={localizedPath(locale, r.href)}
                  class="group flex items-center justify-between rounded-lg border border-border bg-surface p-4 transition-colors hover:border-border-strong"
                >
                  <span class="min-w-0">
                    <span class="block font-medium text-ink group-hover:text-accent transition-colors truncate">
                      {r.name}
                    </span>
                    {r.subtitle && <span class="block text-xs text-ink-subtle line-clamp-1">{r.subtitle}</span>}
                  </span>
                  <ChevronRight className="h-4 w-4 text-ink-subtle mirror-x shrink-0 ms-3" />
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
