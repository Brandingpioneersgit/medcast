---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { getTranslator } from "@/lib/messages";
import { ChevronRight } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect("/en/referral", 308);
const locale = rawLocale as Locale;
const tc = getTranslator(locale, "common");

const seoTitle = "Refer a patient — help someone navigate medical travel";
const seoDescription = "Doctor, family member, or past patient? Refer someone who needs medical travel coordination. Your case manager reaches them within 4 hours.";
const path = "/referral";

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Refer someone", url: localeUrl(locale, path) },
]);

Astro.response.headers.set("Cache-Control", "public, s-maxage=3600, stale-while-revalidate=86400");
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh" style="background: var(--color-bg); color: var(--color-ink);">
    <SiteHeader locale={locale} />

    <div style="padding: 18px 28px; border-bottom: 1px solid var(--color-border-soft); background: var(--color-paper);">
      <nav class="mono mx-auto max-w-[1440px]" style="font-size: 12px; color: var(--color-ink-subtle);" aria-label="Breadcrumb">
        <a href={localizedPath(locale, "/")} class="hover:text-ink">{tc("home")}</a>
        <span class="mx-1.5">/</span>
        <span style="color: var(--color-ink);">Refer someone</span>
      </nav>
    </div>

    <section style="padding: 56px 28px;">
      <div class="mx-auto" style="max-width: 760px;">
        <div class="mono" style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-accent);">Referral</div>
        <h1 class="display display-tight mt-3" style="font-size: clamp(2.25rem, 5vw, 3.5rem); line-height: 1; font-weight: 400; letter-spacing: -0.03em;">
          Know someone who needs <span class="italic-display">medical travel?</span>
        </h1>
        <p class="serif mt-5" style="font-size: 19px; line-height: 1.5; color: var(--color-ink-muted);">
          Doctor, family member, or past patient — if you're helping someone navigate medical travel, send us their case. A named case manager reaches them within 4 hours with the right specialist shortlist.
        </p>

        <form action={localizedPath(locale, "/contact")} method="get" class="paper mt-10" style="padding: 32px; box-shadow: var(--shadow-md);">
          <input type="hidden" name="topic" value="referral" />

          <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase;">Your details</div>
          <div class="grid gap-4 md:grid-cols-2 mt-3">
            <label class="block">
              <span class="block mb-1.5" style="font-size: 12.5px; color: var(--color-ink-subtle);">Your name</span>
              <input name="referrer_name" required placeholder="Full name" class="w-full" style="padding: 11px 14px; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface-elevated); font-size: 14px;" />
            </label>
            <label class="block">
              <span class="block mb-1.5" style="font-size: 12.5px; color: var(--color-ink-subtle);">Your relationship</span>
              <select name="referrer_role" required class="w-full" style="padding: 11px 14px; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface-elevated); font-size: 14px;">
                <option value="">— Select —</option>
                <option value="doctor">I'm their doctor</option>
                <option value="family">Family member</option>
                <option value="friend">Friend</option>
                <option value="past-patient">Past MedCasts patient</option>
                <option value="other">Other</option>
              </select>
            </label>
          </div>
          <label class="block mt-4">
            <span class="block mb-1.5" style="font-size: 12.5px; color: var(--color-ink-subtle);">Your email</span>
            <input name="referrer_email" type="email" required placeholder="you@example.com" class="w-full" style="padding: 11px 14px; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface-elevated); font-size: 14px;" />
          </label>

          <hr style="margin-top: 28px; margin-bottom: 24px; border: 0; border-top: 1px solid var(--color-border-soft);" />

          <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase;">Patient details</div>
          <div class="grid gap-4 md:grid-cols-2 mt-3">
            <label class="block">
              <span class="block mb-1.5" style="font-size: 12.5px; color: var(--color-ink-subtle);">Patient name</span>
              <input name="name" required placeholder="Full name" class="w-full" style="padding: 11px 14px; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface-elevated); font-size: 14px;" />
            </label>
            <label class="block">
              <span class="block mb-1.5" style="font-size: 12.5px; color: var(--color-ink-subtle);">WhatsApp / phone</span>
              <input name="phone" required placeholder="+234 ..." class="w-full" style="padding: 11px 14px; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface-elevated); font-size: 14px;" />
            </label>
          </div>
          <label class="block mt-4">
            <span class="block mb-1.5" style="font-size: 12.5px; color: var(--color-ink-subtle);">Email (optional)</span>
            <input name="email" type="email" placeholder="patient@example.com" class="w-full" style="padding: 11px 14px; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface-elevated); font-size: 14px;" />
          </label>
          <label class="block mt-4">
            <span class="block mb-1.5" style="font-size: 12.5px; color: var(--color-ink-subtle);">Clinical situation</span>
            <textarea name="description" rows="4" required placeholder="Diagnosis, current treatment plan, what specifically they need help with" class="w-full" style="padding: 11px 14px; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface-elevated); font-size: 14px; font-family: inherit; resize: vertical;"></textarea>
          </label>

          <label class="block mt-4" style="font-size: 13px; color: var(--color-ink-muted);">
            <input type="checkbox" name="consent" required style="margin-inline-end: 8px;" />
            I have the patient's consent to share their information with MedCasts.
          </label>

          <button type="submit" class="inline-flex items-center justify-center gap-2 w-full mt-6 font-semibold" style="background: var(--color-ink); color: var(--color-bg); padding: 14px 22px; font-size: 15px; border-radius: 9999px;">
            Send referral <ChevronRight className="h-3.5 w-3.5 mirror-x" />
          </button>

          <p class="mono mt-4 text-center" style="font-size: 11px; color: var(--color-ink-subtle);">
            Free for the patient · no fee to you · your relationship stays confidential
          </p>
        </form>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
