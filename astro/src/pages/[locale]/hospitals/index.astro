---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import Pagination from "@/components/Pagination.astro";
import { listHospitals, getHospitalFilterOptions } from "@/lib/queries";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { getTranslator } from "@/lib/messages";
import { Bed, X } from "lucide-react";
import { hospitalCover } from "@/lib/images";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect("/en/hospitals", 308);
const locale = rawLocale as Locale;

const url = new URL(Astro.request.url);
const pageParam = parseInt(url.searchParams.get("page") ?? "1", 10);
const page = Number.isFinite(pageParam) && pageParam > 0 ? pageParam : 1;
const sortParam = url.searchParams.get("sort");
const sort =
  sortParam === "rating" || sortParam === "reviews" || sortParam === "beds"
    ? sortParam
    : "featured";
const countryFilter = url.searchParams.get("country") ?? undefined;
const specialtyFilter = url.searchParams.get("specialty") ?? undefined;

const [{ rows, total, totalPages }, options] = await Promise.all([
  listHospitals({ page, sort, country: countryFilter, specialty: specialtyFilter }),
  getHospitalFilterOptions({ country: countryFilter, specialty: specialtyFilter }),
]);

const tc = getTranslator(locale, "common");
const seoTitle = `${total > 0 ? total.toLocaleString() : "All"} accredited hospitals`;
const seoDescription = `Browse ${total.toLocaleString()} accredited hospitals worldwide. Compare specialties, ratings, costs. Transparent pricing, multilingual care.`;
const path = "/hospitals";

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: tc("hospitals"), url: localeUrl(locale, path) },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=600, stale-while-revalidate=3600",
);

type Patch = { sort?: string; country?: string; specialty?: string };
function buildHref(patch: Patch): string {
  const params = new URLSearchParams();
  const s = patch.sort ?? sort;
  const c = patch.country !== undefined ? patch.country : countryFilter;
  const sp = patch.specialty !== undefined ? patch.specialty : specialtyFilter;
  if (s && s !== "featured") params.set("sort", s);
  if (c) params.set("country", c);
  if (sp) params.set("specialty", sp);
  const qs = params.toString();
  const base = localizedPath(locale, path);
  return qs ? `${base}?${qs}` : base;
}

const SORTS = [
  { value: "featured", label: "Featured" },
  { value: "rating", label: "Top rated" },
  { value: "reviews", label: "Most reviewed" },
  { value: "beds", label: "Largest" },
];

const activeChips: Array<{ label: string; remove: string }> = [];
if (countryFilter) {
  const c = options.countries.find((x) => x.slug === countryFilter);
  activeChips.push({ label: c?.name ?? countryFilter, remove: buildHref({ country: "" }) });
}
if (specialtyFilter) {
  const s = options.specialties.find((x) => x.slug === specialtyFilter);
  activeChips.push({ label: s?.name ?? specialtyFilter, remove: buildHref({ specialty: "" }) });
}

const paginationBase = buildHref({});
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <section style="border-bottom: 1px solid var(--color-border);">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8 py-10 md:py-14">
        <p
          class="mono uppercase mb-3 tnum"
          style="font-size: 11px; letter-spacing: 0.12em; color: var(--color-ink-subtle);"
        >
          {total.toLocaleString()} accredited · {options.countries.length} countries
        </p>
        <h1
          class="display display-tight"
          style="font-size: clamp(2.25rem, 5vw, 3.75rem); line-height: 1; font-weight: 400; letter-spacing: -0.03em;"
        >
          Browse <span class="italic-display">hospitals</span>
        </h1>
        <p class="lede mt-4 max-w-[44rem]">
          Every listing is verified for active accreditation, outcomes reporting and price
          transparency — and continuously re-vetted by our medical panel.
        </p>
      </div>
    </section>

    <section class="mx-auto w-full max-w-[90rem] px-5 md:px-8 pt-8 pb-12">
      <div class="grid gap-10 lg:grid-cols-[16rem,1fr] xl:grid-cols-[18rem,1fr]">
        {/* Filter rail (desktop) */}
        <aside class="hidden lg:block sticky top-24 self-start">
          <div class="space-y-8">
            {options.countries.length > 0 && (
              <div>
                <p
                  class="mono uppercase mb-3"
                  style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);"
                >
                  Country
                </p>
                <ul class="space-y-1.5">
                  {options.countries.slice(0, 12).map((c) => {
                    const active = c.slug === countryFilter;
                    return (
                      <li>
                        <a
                          href={buildHref({ country: active ? "" : c.slug })}
                          class="flex items-center justify-between text-sm hover:text-accent transition-colors"
                          style={active ? "color: var(--color-accent); font-weight: 600;" : "color: var(--color-ink-muted);"}
                        >
                          <span>{c.name}</span>
                          <span class="tnum text-xs" style="color: var(--color-ink-subtle);">
                            {c.n.toLocaleString()}
                          </span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            )}

            {options.specialties.length > 0 && (
              <div>
                <p
                  class="mono uppercase mb-3"
                  style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);"
                >
                  Specialty
                </p>
                <ul class="space-y-1.5">
                  {options.specialties.slice(0, 12).map((s) => {
                    const active = s.slug === specialtyFilter;
                    return (
                      <li>
                        <a
                          href={buildHref({ specialty: active ? "" : s.slug })}
                          class="flex items-center justify-between text-sm hover:text-accent transition-colors"
                          style={active ? "color: var(--color-accent); font-weight: 600;" : "color: var(--color-ink-muted);"}
                        >
                          <span>{s.name}</span>
                          <span class="tnum text-xs" style="color: var(--color-ink-subtle);">
                            {s.n.toLocaleString()}
                          </span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            )}
          </div>
        </aside>

        <div class="min-w-0">
          {/* Sort bar */}
          <div
            class="mb-6 flex flex-wrap items-center justify-between gap-3 pb-4"
            style="border-bottom: 1px solid var(--color-border);"
          >
            <span class="text-sm" style="color: var(--color-ink-muted);">
              <span class="font-semibold text-ink">{total.toLocaleString()}</span> hospitals
            </span>

            <div class="flex items-center gap-1 -mx-1 overflow-x-auto">
              <span
                class="text-[11px] uppercase tracking-wider px-1 whitespace-nowrap"
                style="color: var(--color-ink-subtle);"
              >
                Sort
              </span>
              {SORTS.map((o) => {
                const active = sort === o.value;
                return (
                  <a
                    href={buildHref({ sort: o.value })}
                    class="rounded-full px-3 py-1 text-xs font-medium transition-colors whitespace-nowrap"
                    style={active
                      ? "background: var(--color-ink); color: var(--color-bg);"
                      : "color: var(--color-ink-muted);"}
                  >
                    {o.label}
                  </a>
                );
              })}
            </div>
          </div>

          {/* Active filter chips */}
          {activeChips.length > 0 && (
            <div class="mb-5 flex flex-wrap items-center gap-2">
              {activeChips.map((chip) => (
                <a
                  href={chip.remove}
                  class="inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-xs font-medium hover:border-border-strong"
                  style="background: var(--color-subtle); border-color: var(--color-border); color: var(--color-ink);"
                >
                  {chip.label}
                  <X className="h-3 w-3" />
                </a>
              ))}
              <a
                href={localizedPath(locale, path)}
                class="text-xs font-medium hover:text-ink hover:underline underline-offset-2"
                style="color: var(--color-ink-muted);"
              >
                Clear all
              </a>
            </div>
          )}

          {/* Card grid */}
          {rows.length === 0 ? (
            <div
              class="paper text-center py-20"
              style="color: var(--color-ink-muted);"
            >
              <p class="serif text-lg mb-2">No hospitals match these filters.</p>
              <a
                href={localizedPath(locale, path)}
                class="inline-block mt-2 text-sm font-semibold"
                style="color: var(--color-accent);"
              >
                Clear filters →
              </a>
            </div>
          ) : (
            <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
              {rows.map((h) => (
                <li>
                  <a
                    href={localizedPath(locale, `/hospital/${h.slug}`)}
                    class="group block h-full overflow-hidden rounded-2xl border border-border bg-surface transition hover:-translate-y-0.5 hover:border-border-strong hover:shadow-md"
                  >
                    <div class="relative aspect-[4/3] overflow-hidden bg-subtle">
                      <img
                        src={hospitalCover({ coverImageUrl: h.coverImageUrl })}
                        alt={h.name}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                        loading="lazy"
                      />
                      {h.rating && Number(h.rating) > 0 && (
                        <div class="absolute left-3 top-3 rounded-full bg-surface/95 px-2 py-1 text-[11px] font-semibold text-ink backdrop-blur">
                          ★ {Number(h.rating).toFixed(1)}
                        </div>
                      )}
                    </div>
                    <div class="p-5">
                      <p
                        class="mono uppercase"
                        style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);"
                      >
                        {h.cityName}, {h.countryName}
                      </p>
                      <h3 class="mt-1.5 font-display text-lg leading-snug text-ink group-hover:text-accent transition-colors line-clamp-2">
                        {h.name}
                      </h3>
                      <div class="mt-3 flex gap-3 text-xs" style="color: var(--color-ink-muted);">
                        {h.bedCapacity && (
                          <span class="inline-flex items-center gap-1">
                            <Bed className="h-3.5 w-3.5" />
                            {h.bedCapacity.toLocaleString()} beds
                          </span>
                        )}
                        {h.reviewCount && h.reviewCount > 0 && (
                          <span class="tnum">{h.reviewCount.toLocaleString()} reviews</span>
                        )}
                      </div>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          )}

          <Pagination page={page} totalPages={totalPages} basePath={paginationBase} />
        </div>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
