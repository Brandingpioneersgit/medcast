---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import EntityListingHero from "@/components/EntityListingHero.astro";
import PhotoBlock from "@/components/PhotoBlock.astro";
import Pagination from "@/components/Pagination.astro";
import { listHospitals, getHospitalFilterOptions } from "@/lib/queries";
import { db } from "@/lib/db";
import { sql } from "drizzle-orm";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl, itemListJsonLd } from "@/lib/seo";
import { getTranslator } from "@/lib/messages";
import { ChevronRight, X } from "lucide-react";
import { hospitalCover } from "@/lib/images";
import CompareToggle from "@/components/CompareToggle.astro";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect("/en/hospitals", 308);
const locale = rawLocale as Locale;

const url = new URL(Astro.request.url);
const pageParam = parseInt(url.searchParams.get("page") ?? "1", 10);
const page = Number.isFinite(pageParam) && pageParam > 0 ? pageParam : 1;
const sortParam = url.searchParams.get("sort");
const sort =
  sortParam === "rating" || sortParam === "reviews" || sortParam === "beds"
    ? sortParam
    : "featured";
const countryFilter = url.searchParams.get("country") ?? undefined;
const specialtyFilter = url.searchParams.get("specialty") ?? undefined;

const [{ rows, total, totalPages }, options] = await Promise.all([
  listHospitals({ page, sort, country: countryFilter, specialty: specialtyFilter }),
  getHospitalFilterOptions({ country: countryFilter, specialty: specialtyFilter }),
]);

// Batch-fetch accreditation chips for visible rows
const hospitalIds = rows.map((h) => h.id);
const accreditationMap = new Map<number, string[]>();
if (hospitalIds.length > 0) {
  try {
    const accr = await db.execute<{ hospital_id: number; codes: string[] }>(sql`
      SELECT ha.hospital_id, ARRAY_AGG(DISTINCT COALESCE(a.acronym, a.name)) AS codes
      FROM hospital_accreditations ha
      INNER JOIN accreditations a ON a.id = ha.accreditation_id
      WHERE ha.hospital_id = ANY(${hospitalIds}::int[])
      GROUP BY ha.hospital_id
    `);
    for (const r of Array.from(accr)) accreditationMap.set(r.hospital_id, r.codes);
  } catch {
    // non-fatal
  }
}

const FLAG_MAP: Record<string, string> = {
  india: "🇮🇳", turkey: "🇹🇷", thailand: "🇹🇭", uae: "🇦🇪",
  germany: "🇩🇪", singapore: "🇸🇬", "south-korea": "🇰🇷",
  malaysia: "🇲🇾", "saudi-arabia": "🇸🇦",
};
function countryFlag(s: string | null | undefined): string { return s ? (FLAG_MAP[s] ?? "🌐") : "🌐"; }

const tc = getTranslator(locale, "common");
const seoTitle = `${total > 0 ? total.toLocaleString() : "All"} accredited hospitals`;
const seoDescription = `Browse ${total.toLocaleString()} accredited hospitals worldwide. Compare specialties, ratings, costs. Transparent pricing, multilingual care.`;
const path = "/hospitals";

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: tc("hospitals"), url: localeUrl(locale, path) },
]);

const itemLd = page === 1 && rows.length > 0
  ? itemListJsonLd(
      rows.map((h) => ({ name: h.name, url: localeUrl(locale, `/hospital/${h.slug}`) })),
    )
  : null;

Astro.response.headers.set("Cache-Control", "public, s-maxage=600, stale-while-revalidate=3600");

type Patch = { sort?: string; country?: string; specialty?: string };
function buildHref(patch: Patch): string {
  const params = new URLSearchParams();
  const s = patch.sort ?? sort;
  const c = patch.country !== undefined ? patch.country : countryFilter;
  const sp = patch.specialty !== undefined ? patch.specialty : specialtyFilter;
  if (s && s !== "featured") params.set("sort", s);
  if (c) params.set("country", c);
  if (sp) params.set("specialty", sp);
  const qs = params.toString();
  const base = localizedPath(locale, path);
  return qs ? `${base}?${qs}` : base;
}

const SORTS = [
  { value: "featured", label: "Featured" },
  { value: "rating", label: "Top rated" },
  { value: "reviews", label: "Most reviewed" },
  { value: "beds", label: "Largest" },
];

const activeChips: Array<{ label: string; remove: string }> = [];
if (countryFilter) {
  const c = options.countries.find((x) => x.slug === countryFilter);
  activeChips.push({ label: c?.name ?? countryFilter, remove: buildHref({ country: "" }) });
}
if (specialtyFilter) {
  const s = options.specialties.find((x) => x.slug === specialtyFilter);
  activeChips.push({ label: s?.name ?? specialtyFilter, remove: buildHref({ specialty: "" }) });
}

const paginationBase = buildHref({});

const selfCanonicalFilter = countryFilter && !specialtyFilter;
const shouldNoindex = page > 1 || !!specialtyFilter;
const canonicalQuery = selfCanonicalFilter
  ? new URLSearchParams({ country: countryFilter! }).toString()
  : "";

const stats = page === 1 && !countryFilter && !specialtyFilter ? [
  { l: "Accredited", v: total.toLocaleString() },
  { l: "Countries", v: options.countries.length.toString() },
  { l: "Specialties", v: options.specialties.length.toString() },
  { l: "Reply time", v: "9 min" },
] : [];
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title={seoTitle}
      description={seoDescription}
      path={path}
      locale={locale}
      noindex={shouldNoindex}
      pathQuery={canonicalQuery}
    />
    {itemLd && <script type="application/ld+json" set:html={JSON.stringify(itemLd)} />}
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <div style="background: var(--color-paper); border-bottom: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8 py-4">
        <nav class="mono text-[12px]" style="color: var(--color-ink-subtle);" aria-label="Breadcrumb">
          <a href={localizedPath(locale, "/")} class="hover:text-ink">{tc("home")}</a>
          <span class="mx-1.5">/</span>
          <span style="color: var(--color-ink);">Hospitals</span>
        </nav>
      </div>
    </div>

    <EntityListingHero
      eyebrow={`${total.toLocaleString()} accredited · ${options.countries.length} countries`}
      h1First="Browse"
      h1Italic="hospitals"
      lede="Every listing is verified for active accreditation, outcomes reporting and price transparency — and continuously re-vetted by our medical panel."
      stats={stats}
    />

    <section class="mx-auto w-full max-w-[90rem] px-5 md:px-8 pt-8 pb-12">
      <div class="grid gap-10 lg:grid-cols-[16rem,1fr] xl:grid-cols-[18rem,1fr]">
        <aside class="hidden lg:block sticky top-24 self-start">
          <div class="space-y-8">
            {options.countries.length > 0 && (
              <div>
                <p class="mono uppercase mb-3" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                  Country
                </p>
                <ul class="space-y-1.5">
                  {options.countries.slice(0, 12).map((c) => {
                    const active = c.slug === countryFilter;
                    return (
                      <li>
                        <a
                          href={buildHref({ country: active ? "" : c.slug })}
                          class="flex items-center justify-between text-sm hover:text-accent transition-colors"
                          style={active ? "color: var(--color-accent); font-weight: 600;" : "color: var(--color-ink-muted);"}
                        >
                          <span class="flex items-center gap-2"><span aria-hidden="true">{countryFlag(c.slug)}</span> {c.name}</span>
                          <span class="tnum text-xs" style="color: var(--color-ink-subtle);">
                            {c.n.toLocaleString()}
                          </span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            )}

            {options.specialties.length > 0 && (
              <div>
                <p class="mono uppercase mb-3" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                  Specialty
                </p>
                <ul class="space-y-1.5">
                  {options.specialties.slice(0, 12).map((s) => {
                    const active = s.slug === specialtyFilter;
                    return (
                      <li>
                        <a
                          href={buildHref({ specialty: active ? "" : s.slug })}
                          class="flex items-center justify-between text-sm hover:text-accent transition-colors"
                          style={active ? "color: var(--color-accent); font-weight: 600;" : "color: var(--color-ink-muted);"}
                        >
                          <span>{s.name}</span>
                          <span class="tnum text-xs" style="color: var(--color-ink-subtle);">
                            {s.n.toLocaleString()}
                          </span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            )}
          </div>
        </aside>

        <div class="min-w-0">
          <div
            class="mb-6 flex flex-wrap items-center justify-between gap-3 pb-4"
            style="border-bottom: 1px solid var(--color-border);"
          >
            <span class="serif text-[14px]" style="color: var(--color-ink-muted);">
              <span class="display tnum text-ink">{total.toLocaleString()}</span> hospital{total === 1 ? "" : "s"}
            </span>
            <div class="flex items-center gap-1 -mx-1 overflow-x-auto">
              <span class="mono uppercase px-1 whitespace-nowrap" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                Sort
              </span>
              {SORTS.map((o) => {
                const active = sort === o.value;
                return (
                  <a
                    href={buildHref({ sort: o.value })}
                    class="rounded-full px-3 py-1 text-xs font-medium transition-colors whitespace-nowrap"
                    style={active
                      ? "background: var(--color-ink); color: var(--color-bg);"
                      : "color: var(--color-ink-muted);"}
                  >
                    {o.label}
                  </a>
                );
              })}
            </div>
          </div>

          {activeChips.length > 0 && (
            <div class="mb-5 flex flex-wrap items-center gap-2">
              {activeChips.map((chip) => (
                <a
                  href={chip.remove}
                  class="inline-flex items-center gap-1.5 mono uppercase hover:border-ink"
                  style="font-size: 10px; letter-spacing: 0.12em; border: 1px solid var(--color-border); background: var(--color-paper); color: var(--color-ink); padding: 6px 12px; border-radius: 9999px;"
                >
                  {chip.label}
                  <X className="h-3 w-3" />
                </a>
              ))}
              <a
                href={localizedPath(locale, path)}
                class="mono text-[10px] uppercase tracking-wider hover:text-ink"
                style="color: var(--color-ink-muted);"
              >
                Clear all →
              </a>
            </div>
          )}

          {rows.length === 0 ? (
            <div class="paper text-center py-20" style="color: var(--color-ink-muted);">
              <p class="serif text-lg mb-2">No hospitals match these filters.</p>
              <a
                href={localizedPath(locale, path)}
                class="inline-block mt-2 mono uppercase text-[11px]"
                style="color: var(--color-accent); letter-spacing: 0.12em;"
              >
                Clear filters →
              </a>
            </div>
          ) : (
            <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
              {rows.map((h) => {
                const codes = accreditationMap.get(h.id) ?? [];
                return (
                  <li class="relative h-full">
                    <a
                      href={localizedPath(locale, `/hospital/${h.slug}`)}
                      class="paper group block h-full overflow-hidden transition hover:-translate-y-0.5"
                      style="padding: 0;"
                    >
                      <PhotoBlock
                        aspect="4/3"
                        rounded={false}
                        imgUrl={hospitalCover({ coverImageUrl: h.coverImageUrl, countrySlug: h.countrySlug })}
                        alt={h.name}
                      >
                        {h.rating && Number(h.rating) > 0 && (
                          <div
                            class="absolute"
                            style="top: 12px; inset-inline-start: 12px; background: rgba(246,241,230,0.95); color: var(--color-ink); padding: 4px 10px; border-radius: 9999px; font-size: 11px; backdrop-filter: blur(4px);"
                          >
                            <span style="color: var(--color-saffron);">★</span>
                            <span class="tnum ms-1">{Number(h.rating).toFixed(1)}</span>
                          </div>
                        )}
                      </PhotoBlock>
                      <div class="p-5">
                        <p class="mono uppercase flex items-center gap-1.5" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                          <span aria-hidden="true">{countryFlag(h.countrySlug)}</span>
                          {h.cityName}, {h.countryName}
                        </p>
                        <h3 class="mt-1.5 serif group-hover:text-accent transition-colors line-clamp-2" style="font-size: 19px; line-height: 1.22; letter-spacing: -0.005em; color: var(--color-ink);">
                          {h.name}
                        </h3>
                        {codes.length > 0 && (
                          <div class="mt-3 flex flex-wrap gap-1.5">
                            {codes.slice(0, 3).map((c) => (
                              <span
                                class="mono uppercase"
                                style="font-size: 9.5px; letter-spacing: 0.1em; border: 1px solid var(--color-accent); color: var(--color-accent); padding: 2px 7px; border-radius: 9999px;"
                              >
                                {c}
                              </span>
                            ))}
                          </div>
                        )}
                        <div
                          class="mt-auto flex items-center justify-between"
                          style="border-top: 1px dashed var(--color-border); margin-top: 14px; padding-top: 12px;"
                        >
                          <div class="flex items-center gap-3 text-[12px]" style="color: var(--color-ink-muted);">
                            {h.bedCapacity && <span class="tnum">{h.bedCapacity.toLocaleString()} beds</span>}
                            {h.reviewCount && h.reviewCount > 0 && (
                              <span class="tnum">{h.reviewCount.toLocaleString()} reviews</span>
                            )}
                          </div>
                          <ChevronRight className="h-3.5 w-3.5 mirror-x text-[var(--color-ink-subtle)] group-hover:text-[var(--color-accent)] transition-colors" />
                        </div>
                      </div>
                    </a>
                    <div class="absolute end-3 top-3 z-10">
                      <CompareToggle slug={h.slug} name={h.name} />
                    </div>
                  </li>
                );
              })}
            </ul>
          )}

          <Pagination page={page} totalPages={totalPages} basePath={paginationBase} />
        </div>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
