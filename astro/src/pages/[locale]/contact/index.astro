---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { Mail, Phone, MessageCircle, ChevronRight } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect(`/en/contact`, 308);
const locale = rawLocale as Locale;
const tc = getTranslator(locale, "common");

const path = "/contact";
const url = localeUrl(locale, path);

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Contact", url },
]);

// Pre-fill values from query string — passed from various CTAs across the site.
const reqUrl = new URL(Astro.request.url);
const prefillTreatment = reqUrl.searchParams.get("treatment") ?? "";
const prefillSpecialty = reqUrl.searchParams.get("specialty") ?? "";
const prefillCity = reqUrl.searchParams.get("city") ?? "";
const prefillCountry = reqUrl.searchParams.get("country") ?? "";
const prefillHospital = reqUrl.searchParams.get("hospital") ?? "";
const prefillCondition = reqUrl.searchParams.get("condition") ?? "";
const prefillDoctor = reqUrl.searchParams.get("doctor") ?? "";

const prefillContext =
  prefillTreatment ||
  prefillSpecialty ||
  prefillHospital ||
  prefillDoctor ||
  prefillCondition ||
  prefillCity ||
  prefillCountry;

const STEPS = [
  { n: "01", t: "You submit case details", d: "Form, WhatsApp, or email — whatever's easier. Include imaging if available." },
  { n: "02", t: "Case manager assigned · ~9 min", d: "A named coordinator replies with clarifying questions and routes your case to 3 matched surgeons." },
  { n: "03", t: "Three itemised quotes · 48 h", d: "You get line-item quotes (surgery, anaesthesia, implants, stay, transfers) so you can compare cleanly." },
  { n: "04", t: "Video consult before booking", d: "Talk to the surgeon on video before committing. We coordinate timing and interpretation if needed." },
];

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title="Contact MedCasts"
      description="Reach our international patient desk. Free treatment quotes, second opinions, and case coordination across 9 destinations. Response within 9 minutes during office hours."
      path={path}
      locale={locale}
    />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <div style="background: var(--color-paper); border-bottom: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8 py-4">
        <nav class="mono text-[12px]" style="color: var(--color-ink-subtle);" aria-label="Breadcrumb">
          <a href={localizedPath(locale, "/")} class="hover:text-ink">{tc("home")}</a>
          <span class="mx-1.5">/</span>
          <span style="color: var(--color-ink);">Contact</span>
        </nav>
      </div>
    </div>

    <section class="pt-12 md:pt-16">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8">
        <p class="mono uppercase flex items-center gap-2" style="font-size: 11px; letter-spacing: 0.14em; color: var(--color-accent);">
          <span class="inline-block w-1.5 h-1.5 rounded-full live-dot" style="background: var(--color-accent);" aria-hidden="true" />
          Coordinators online · avg reply 9 min
        </p>

        <div class="grid gap-10 lg:grid-cols-[1.35fr,1fr] lg:gap-14 mt-3">
          <div>
            <h1
              class="display display-tight"
              style="font-size: clamp(2.25rem, 5vw, 4.5rem); line-height: 0.98; font-weight: 400; letter-spacing: -0.03em;"
            >
              Speak with a <span class="italic-display">case manager</span>
            </h1>
            <p class="serif mt-5 max-w-[44rem]" style="font-size: 19px; line-height: 1.5; color: var(--color-ink-muted);">
              Free treatment quotes, second opinions, and end-to-end case coordination across 9 destinations. Named coordinators reply within the day — usually within minutes.
            </p>

            <form
              action="/api/v1/inquiry"
              method="POST"
              class="paper mt-8"
              style="padding: 28px 28px 26px;"
            >
              {prefillContext && (
                <div class="mb-5 mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-accent); padding: 10px 14px; border: 1px dashed var(--color-accent); border-radius: 9999px; display: inline-flex; align-items: center; gap: 8px;">
                  Pre-filled for:&nbsp;
                  <span style="color: var(--color-ink);">{prefillHospital || prefillDoctor || prefillTreatment || prefillSpecialty || prefillCondition || prefillCity || prefillCountry}</span>
                </div>
              )}

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="mono uppercase block mb-2" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);" for="name">Full name</label>
                  <input
                    type="text" id="name" name="name" required
                    class="w-full serif focus:outline-none"
                    style="background: var(--color-bg); border: 1px solid var(--color-border); padding: 12px 14px; border-radius: 10px; font-size: 15px; color: var(--color-ink);"
                  />
                </div>
                <div>
                  <label class="mono uppercase block mb-2" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);" for="email">Email</label>
                  <input
                    type="email" id="email" name="email" required
                    class="w-full serif focus:outline-none"
                    style="background: var(--color-bg); border: 1px solid var(--color-border); padding: 12px 14px; border-radius: 10px; font-size: 15px; color: var(--color-ink);"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                <div>
                  <label class="mono uppercase block mb-2" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);" for="phone">Phone · WhatsApp</label>
                  <input
                    type="tel" id="phone" name="phone"
                    class="w-full serif focus:outline-none"
                    style="background: var(--color-bg); border: 1px solid var(--color-border); padding: 12px 14px; border-radius: 10px; font-size: 15px; color: var(--color-ink);"
                  />
                </div>
                <div>
                  <label class="mono uppercase block mb-2" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);" for="countryCode">Your country</label>
                  <input
                    type="text" id="countryCode" name="countryCode"
                    class="w-full serif focus:outline-none"
                    style="background: var(--color-bg); border: 1px solid var(--color-border); padding: 12px 14px; border-radius: 10px; font-size: 15px; color: var(--color-ink);"
                  />
                </div>
              </div>

              <div class="mt-4">
                <label class="mono uppercase block mb-2" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);" for="treatment">Treatment you need</label>
                <input
                  type="text" id="treatment" name="treatment"
                  value={prefillTreatment}
                  placeholder="e.g. CABG · hair transplant · IVF · knee replacement"
                  class="w-full serif focus:outline-none"
                  style="background: var(--color-bg); border: 1px solid var(--color-border); padding: 12px 14px; border-radius: 10px; font-size: 15px; color: var(--color-ink);"
                />
              </div>

              <div class="mt-4">
                <label class="mono uppercase block mb-2" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);" for="message">Brief case summary</label>
                <textarea
                  id="message" name="message" rows="4"
                  placeholder="Diagnosis, current treatment, what you're hoping we can help with. Attach imaging separately by email if preferred."
                  class="w-full serif focus:outline-none"
                  style="background: var(--color-bg); border: 1px solid var(--color-border); padding: 12px 14px; border-radius: 10px; font-size: 15px; color: var(--color-ink); font-family: inherit;"
                ></textarea>
              </div>

              {prefillSpecialty && <input type="hidden" name="specialty" value={prefillSpecialty} />}
              {prefillCity && <input type="hidden" name="city" value={prefillCity} />}
              {prefillCountry && <input type="hidden" name="country" value={prefillCountry} />}
              {prefillHospital && <input type="hidden" name="hospital" value={prefillHospital} />}
              {prefillCondition && <input type="hidden" name="condition" value={prefillCondition} />}
              {prefillDoctor && <input type="hidden" name="doctor" value={prefillDoctor} />}

              <div class="mt-6 flex flex-wrap items-center gap-4">
                <button
                  type="submit"
                  class="inline-flex items-center gap-2 font-semibold"
                  style="background: var(--color-ink); color: var(--color-bg); padding: 13px 24px; border-radius: 9999px; font-size: 14px;"
                >
                  Send to case manager
                  <ChevronRight className="h-4 w-4 mirror-x" />
                </button>
                <p class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                  Shared only with coordinators on your case · No marketing lists
                </p>
              </div>
            </form>
          </div>

          <aside class="lg:sticky lg:top-32 lg:self-start space-y-4">
            {/* What happens next */}
            <div class="paper" style="padding: 24px 26px;">
              <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                What happens next
              </div>
              <ol class="mt-5 space-y-5">
                {STEPS.map((s) => (
                  <li class="grid gap-3" style="grid-template-columns: 40px 1fr;">
                    <div class="display tnum" style="font-size: 22px; line-height: 1; color: var(--color-accent); letter-spacing: -0.02em;">
                      {s.n}
                    </div>
                    <div>
                      <div class="serif" style="font-size: 16px; line-height: 1.3; color: var(--color-ink);">
                        {s.t}
                      </div>
                      <p class="mt-1.5 serif" style="font-size: 13.5px; line-height: 1.5; color: var(--color-ink-muted);">
                        {s.d}
                      </p>
                    </div>
                  </li>
                ))}
              </ol>
            </div>

            {/* Direct channels */}
            <div class="paper" style="padding: 24px 26px;">
              <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                Prefer to skip the form
              </div>
              <ul class="mt-4 space-y-3.5">
                <li class="flex items-start gap-3">
                  <MessageCircle className="h-4 w-4 mt-1 shrink-0" style={{color: "var(--color-accent)"}} />
                  <div>
                    <div class="serif" style="font-size: 15px; color: var(--color-ink);">WhatsApp · fastest</div>
                    <a href="https://wa.me/918006210000" class="mono uppercase" style="font-size: 11px; letter-spacing: 0.1em; color: var(--color-ink-muted);">+91 800 621 000 →</a>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <Mail className="h-4 w-4 mt-1 shrink-0" style={{color: "var(--color-accent)"}} />
                  <div>
                    <div class="serif" style="font-size: 15px; color: var(--color-ink);">Email</div>
                    <a href="mailto:care@medcasts.com" class="mono uppercase" style="font-size: 11px; letter-spacing: 0.1em; color: var(--color-ink-muted);">care@medcasts.com →</a>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <Phone className="h-4 w-4 mt-1 shrink-0" style={{color: "var(--color-accent)"}} />
                  <div>
                    <div class="serif" style="font-size: 15px; color: var(--color-ink);">Phone</div>
                    <a href="tel:+918006210000" class="mono uppercase" style="font-size: 11px; letter-spacing: 0.1em; color: var(--color-ink-muted);">+91 800 621 000 →</a>
                  </div>
                </li>
              </ul>
              <div class="mt-5 pt-4 mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); border-top: 1px dashed var(--color-border);">
                08:00–22:00 GMT+5:30 · Emergency desk 24/7
              </div>
            </div>

            {/* Emergency nudge */}
            <a
              href={localizedPath(locale, "/emergency")}
              class="group flex items-center justify-between gap-4"
              style="background: var(--color-coral); color: var(--color-bg); padding: 18px 22px; border-radius: var(--radius-lg);"
            >
              <div>
                <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; opacity: 0.8;">
                  Medical emergency
                </div>
                <div class="serif mt-1" style="font-size: 17px; line-height: 1.3;">
                  24/7 air-ambulance + critical-care desk
                </div>
              </div>
              <ChevronRight className="h-5 w-5 mirror-x shrink-0" />
            </a>
          </aside>
        </div>
      </div>
    </section>

    <section style="padding: 96px 0 88px;">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="grid gap-6 md:grid-cols-4" style="border-top: 1px solid var(--color-ink); border-bottom: 1px solid var(--color-border);">
          {[
            { l: "Coordinators online", v: "Now" },
            { l: "Median reply", v: "9 min" },
            { l: "Language support", v: "8" },
            { l: "No fee", v: "For patients" },
          ].map((s, i) => (
            <div
              class="px-5 py-6"
              style={i > 0 ? "border-inline-start: 1px solid var(--color-border);" : ""}
            >
              <div class="mono uppercase" style="font-size: 9.5px; letter-spacing: 0.12em; color: var(--color-ink-subtle);">
                {s.l}
              </div>
              <div class="display tnum mt-1.5" style="font-size: 26px;">{s.v}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
