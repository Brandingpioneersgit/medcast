---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { Mail, Phone, MapPin, MessageCircle, Clock, ChevronRight } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect(`/en/contact`, 308);
const locale = rawLocale as Locale;
const tc = getTranslator(locale, "common");

const path = "/contact";
const url = localeUrl(locale, path);

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Contact", url },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title="Contact MedCasts"
      description="Reach our international patient desk. Free treatment quotes, second opinions, and case coordination across 9 destinations. Response within 11 minutes during office hours."
      path={path}
      locale={locale}
    />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <section class="mx-auto max-w-7xl px-6 pt-12 md:pt-20 pb-12">
      <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-accent">Get in touch</p>
      <h1 class="mt-4 font-display text-4xl md:text-5xl leading-[1.05]">
        Speak with a case manager
      </h1>
      <p class="lede mt-5 max-w-3xl">
        Free treatment quotes, second opinions, and end-to-end case coordination.
        We respond within 11 minutes during office hours (08:00-22:00 GMT+5:30).
      </p>

      <div class="mt-12 grid lg:grid-cols-[1.2fr_1fr] gap-10 items-start">
        {/* Form */}
        <form
          action="/api/v1/inquiry"
          method="POST"
          class="rounded-2xl border border-border bg-surface p-6 md:p-8 space-y-5"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1.5" for="name">Full name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm focus:outline-none focus:border-accent"
              />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1.5" for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm focus:outline-none focus:border-accent"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1.5" for="phone">Phone / WhatsApp</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm focus:outline-none focus:border-accent"
              />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1.5" for="countryCode">Your country</label>
              <input
                type="text"
                id="countryCode"
                name="countryCode"
                class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm focus:outline-none focus:border-accent"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5" for="treatment">Treatment you need</label>
            <input
              type="text"
              id="treatment"
              name="treatment"
              placeholder="e.g. CABG, hair transplant, IVF, knee replacement"
              class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm focus:outline-none focus:border-accent"
            />
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5" for="message">Brief case summary</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Diagnosis, current treatment, and what you're hoping we can help with."
              class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm focus:outline-none focus:border-accent"
            ></textarea>
          </div>

          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-lg bg-accent text-white font-semibold px-6 py-3 hover:bg-accent-hover transition"
          >
            Send to case manager
            <ChevronRight className="h-4 w-4 mirror-x" />
          </button>

          <p class="text-xs text-ink-subtle">
            No spam. Your details are shared only with the hospital coordinators assigned to your case.
          </p>
        </form>

        {/* Side panel */}
        <aside class="space-y-4">
          <div class="rounded-2xl border border-border bg-surface p-6">
            <h3 class="font-display text-lg mb-4">Direct channels</h3>
            <ul class="space-y-4 text-sm">
              <li class="flex items-start gap-3">
                <MessageCircle className="h-5 w-5 text-accent shrink-0 mt-0.5" />
                <div>
                  <p class="font-medium">WhatsApp (fastest)</p>
                  <a href="https://wa.me/" class="text-ink-muted hover:text-accent">Message the desk →</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <Mail className="h-5 w-5 text-accent shrink-0 mt-0.5" />
                <div>
                  <p class="font-medium">Email</p>
                  <a href="mailto:care@medcasts.com" class="text-ink-muted hover:text-accent">care@medcasts.com</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <Phone className="h-5 w-5 text-accent shrink-0 mt-0.5" />
                <div>
                  <p class="font-medium">Phone</p>
                  <a href="tel:+918000000000" class="text-ink-muted hover:text-accent">+91 80000 00000</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <Clock className="h-5 w-5 text-accent shrink-0 mt-0.5" />
                <div>
                  <p class="font-medium">Hours</p>
                  <p class="text-ink-muted">08:00-22:00 GMT+5:30 · Emergency desk 24/7</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="rounded-2xl border border-border bg-accent-soft p-6">
            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-accent">Medical emergency?</p>
            <p class="mt-2 font-medium">Call the 24/7 desk instead.</p>
            <a
              href={localizedPath(locale, "/emergency")}
              class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-accent hover:text-accent-hover"
            >
              Emergency desk
              <ChevronRight className="h-4 w-4 mirror-x" />
            </a>
          </div>
        </aside>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
