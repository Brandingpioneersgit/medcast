---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import LastUpdated from "@/components/LastUpdated.astro";
import { listSurgeonsForSpecialty } from "@/lib/queries";
import { getContent, getContentBatch, applyTranslated } from "@/lib/translate";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl, itemListJsonLd, withProvenance } from "@/lib/seo";
import { Award, ChevronRight, MapPin, Users } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
const specialtyParam = Astro.params.specialty;
if (!isLocale(rawLocale)) return Astro.redirect(`/en/surgeons/${specialtyParam}`, 308);
if (!specialtyParam) return new Response("Not found", { status: 404 });
const locale = rawLocale as Locale;

const data = await listSurgeonsForSpecialty(specialtyParam, { limit: 24 });
if (!data.specialty) return new Response(`Not found: ${specialtyParam}`, { status: 404 });
if (data.doctors.length === 0) return new Response(`No surgeons listed for ${specialtyParam}`, { status: 404 });

const specialtyMap = await getContent("specialty", data.specialty.id, locale);
const specialty = applyTranslated(data.specialty, specialtyMap, ["name", "description"]);

const doctorMap = await getContentBatch("doctor", data.doctors.map((d) => d.id), locale);
const doctors = data.doctors.map((d) => ({
  ...d,
  ...applyTranslated({ name: d.name, qualifications: d.qualifications }, doctorMap[d.id] ?? {}, ["name", "qualifications"]),
}));

const tc = getTranslator(locale, "common");

function bucketFor(d: (typeof doctors)[number]): "senior" | "established" | "early" {
  const yrs = d.experience_years ?? 0;
  const patients = d.patients_treated ?? 0;
  if (yrs >= 20 || patients >= 5000) return "senior";
  if (yrs >= 10 || patients >= 1000) return "established";
  return "early";
}

const buckets = {
  senior: doctors.filter((d) => bucketFor(d) === "senior"),
  established: doctors.filter((d) => bucketFor(d) === "established"),
  early: doctors.filter((d) => bucketFor(d) === "early"),
};

const BUCKET_COPY: Record<"senior" | "established" | "early", { title: string; note: string }> = {
  senior: {
    title: "Senior consultants",
    note: "20+ years in practice or 5,000+ cases — typically leading complex referrals.",
  },
  established: {
    title: "Established specialists",
    note: "10+ years in practice or 1,000+ cases handled.",
  },
  early: {
    title: "Practising specialists",
    note: "Earlier-career consultants, still actively operating and available for consults.",
  },
};

const seoTitle = `${specialty.name} surgeons — rankings by volume & experience`;
const seoDescription =
  `${data.total.toLocaleString()} surgeons practising at hospitals credentialed for ${specialty.name}, ordered by patient volume and experience. Request a surgeon shortlist matched to your case.`.slice(0, 160);
const path = `/surgeons/${specialtyParam}`;
const url = localeUrl(locale, path);

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Surgeons", url: localeUrl(locale, "/surgeons") },
  { name: specialty.name, url },
]);

const itemLd = withProvenance(
  itemListJsonLd(
    doctors.slice(0, 10).map((d) => ({
      name: d.title ? `${d.title} ${d.name}`.replace(/^Dr\. Dr\./i, "Dr.") : d.name,
      url: localeUrl(locale, `/doctor/${d.slug}`),
    })),
  ),
  { dateModified: new Date() },
);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemLd)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <nav aria-label="Breadcrumb" class="border-b border-border bg-bg">
      <div class="mx-auto max-w-7xl px-6 py-3.5 text-sm text-ink-muted">
        <a href={localizedPath(locale, "/")} class="hover:text-accent">{tc("home")}</a>
        <span class="mx-2 text-ink-subtle">/</span>
        <a href={localizedPath(locale, "/surgeons")} class="hover:text-accent">Surgeons</a>
        <span class="mx-2 text-ink-subtle">/</span>
        <span class="text-ink" aria-current="page">{specialty.name}</span>
      </div>
    </nav>

    <section class="mx-auto max-w-7xl px-6 pt-10 md:pt-14 pb-8">
      <p class="mono uppercase" style="font-size: 11px; letter-spacing: 0.18em; color: var(--color-accent);">
        {specialty.name}
      </p>
      <h1 class="mt-2 display display-tight" style="font-size: clamp(2rem, 4.5vw, 3.5rem); letter-spacing: -0.025em; line-height: 1.02;">
        {specialty.name} surgeons we'd shortlist for you
      </h1>
      <p class="lede mt-5 max-w-[44rem]">
        {data.total.toLocaleString()} practising specialists at hospitals credentialed for {specialty.name.toLowerCase()}, ranked by patient volume and years in practice. Not every doctor here operates exclusively in this specialty — our case manager refines this list to your specific condition.
      </p>
      <div class="mt-5"><LastUpdated updated={new Date()} locale={locale} /></div>

      {/* Country scope selector */}
      {data.countryBreakdown.length > 0 && (
        <div class="mt-6 flex flex-wrap items-center gap-2">
          <span class="mono uppercase text-[11px]" style="letter-spacing: 0.12em; color: var(--color-ink-subtle);">Scope</span>
          <a
            href={localizedPath(locale, `/surgeons/${specialtyParam}`)}
            class="rounded-full px-3 py-1 text-[13px] font-medium"
            style="background: var(--color-ink); color: var(--color-bg);"
          >
            All countries · {data.total.toLocaleString()}
          </a>
          {data.countryBreakdown.map((c) => (
            <a
              href={localizedPath(locale, `/surgeons/${specialtyParam}/${c.slug}`)}
              class="rounded-full border border-border bg-surface px-3 py-1 text-[13px] font-medium text-ink hover:border-border-strong"
            >
              {c.name} · <span class="tnum">{c.n.toLocaleString()}</span>
            </a>
          ))}
        </div>
      )}
    </section>

    {(["senior", "established", "early"] as const).map((key) => (
      buckets[key].length > 0 && (
        <section class="mx-auto max-w-7xl px-6 py-8 border-t border-border-soft">
          <div class="flex items-baseline justify-between flex-wrap gap-2">
            <h2 class="font-display text-2xl md:text-3xl">{BUCKET_COPY[key].title}</h2>
            <span class="text-[13px] text-ink-subtle">{buckets[key].length} listed</span>
          </div>
          <p class="mt-2 text-sm text-ink-muted max-w-[44rem]">{BUCKET_COPY[key].note}</p>

          <ul class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {buckets[key].map((d) => {
              const nameHasTitle = /^(dr\.?|prof\.?|mr\.?|ms\.?|mrs\.?)\s/i.test(d.name);
              const titlePrefix = nameHasTitle ? "" : (d.title ?? "Dr.");
              const fullName = titlePrefix ? `${titlePrefix} ${d.name}` : d.name;
              return (
                <li>
                  <a
                    href={localizedPath(locale, `/doctor/${d.slug}`)}
                    class="group flex h-full gap-4 rounded-xl border border-border bg-surface p-4 transition-colors hover:border-border-strong"
                  >
                    {d.image_url ? (
                      <img src={d.image_url} alt={d.name} width="64" height="64" loading="lazy" decoding="async" class="h-16 w-16 shrink-0 rounded-full object-cover ring-1 ring-border" />
                    ) : (
                      <div class="h-16 w-16 shrink-0 rounded-full bg-accent-soft text-accent inline-flex items-center justify-center font-display text-lg">
                        {d.name.slice(0, 1)}
                      </div>
                    )}
                    <div class="min-w-0 flex-1">
                      <span class="block font-display text-[17px] leading-tight text-ink group-hover:text-accent line-clamp-1">{fullName}</span>
                      {d.qualifications && <span class="mt-1 block text-[12.5px] text-ink-muted line-clamp-1">{d.qualifications}</span>}
                      <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-[12px] text-ink-subtle">
                        {d.experience_years != null && (
                          <span class="inline-flex items-center gap-1"><Award className="h-3 w-3 text-accent" />{d.experience_years} yrs</span>
                        )}
                        {d.patients_treated != null && d.patients_treated > 0 && (
                          <span class="inline-flex items-center gap-1"><Users className="h-3 w-3 text-accent" />{d.patients_treated.toLocaleString()}</span>
                        )}
                        {d.rating && Number(d.rating) > 0 && (
                          <span class="inline-flex items-center gap-1"><span class="text-gold-500">★</span><span class="tnum">{Number(d.rating).toFixed(1)}</span></span>
                        )}
                      </div>
                      <div class="mt-2 text-[12px] text-ink-subtle inline-flex items-center gap-1">
                        <MapPin className="h-3 w-3" />{d.hospital_name} · {d.city}, {d.country}
                      </div>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      )
    ))}

    {/* CTA */}
    <section class="mx-auto max-w-7xl px-6 pt-8 pb-20">
      <div class="paper p-6 md:p-8 flex flex-col md:flex-row md:items-center md:justify-between gap-5">
        <div class="max-w-[36rem]">
          <p class="mono uppercase" style="font-size: 11px; letter-spacing: 0.14em; color: var(--color-accent);">Human shortlist</p>
          <h3 class="mt-2 font-display text-2xl md:text-3xl">
            Want us to match one of these surgeons to your case?
          </h3>
          <p class="mt-2 text-sm text-ink-muted">
            Send your reports and we'll come back with 3 specific names, availability, and a quote — no fee.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a
            href={localizedPath(locale, `/calculator`)}
            class="inline-flex items-center rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-accent-contrast hover:bg-accent-hover"
          >
            Start the shortlist
          </a>
          <a
            href={localizedPath(locale, `/specialty/${specialty.slug}`)}
            class="inline-flex items-center rounded-lg border border-border px-5 py-2.5 text-sm font-semibold hover:border-border-strong"
          >
            About {specialty.name}
            <ChevronRight className="ml-1 h-4 w-4" />
          </a>
        </div>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
