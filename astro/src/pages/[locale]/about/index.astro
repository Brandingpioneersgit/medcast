---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import EntityListingHero from "@/components/EntityListingHero.astro";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl, SITE_URL } from "@/lib/seo";
import { ChevronRight } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect(`/en/about`, 308);
const locale = rawLocale as Locale;
const tc = getTranslator(locale, "common");

const path = "/about";
const url = localeUrl(locale, path);

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "About", url },
]);

const orgLd = {
  "@context": "https://schema.org",
  "@type": ["MedicalOrganization", "Organization"],
  name: "MedCasts",
  url: SITE_URL,
  logo: `${SITE_URL}/logo.svg`,
  description: "Medical-travel coordinator. Matches international patients with accredited hospitals and surgeons in 9 destinations.",
  foundingDate: "2024",
  contactPoint: [
    { "@type": "ContactPoint", contactType: "Customer Service", email: "care@medcasts.com", availableLanguage: ["en", "ar", "ru", "fr", "pt", "bn", "tr", "hi"] },
  ],
};

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=86400, stale-while-revalidate=604800",
);

const stats = [
  { l: "Founded", v: "2024" },
  { l: "Destinations", v: "9" },
  { l: "Languages", v: "8" },
  { l: "Patient fee", v: "$0" },
];

const TOC = [
  { id: "what-we-do", label: "What we do" },
  { id: "what-we-dont", label: "What we don't" },
  { id: "vetting", label: "How we vet hospitals" },
  { id: "records", label: "How we handle records" },
  { id: "content", label: "How content is written" },
  { id: "base", label: "Where we're based" },
  { id: "contact", label: "Talk to us" },
];
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title="About MedCasts — medical-travel coordination, not a brochure"
      description="Who we are, how we work, and why transparent pricing and named specialists matter. Medical-travel coordination across 9 destinations."
      path={path}
      locale={locale}
    />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <div style="background: var(--color-paper); border-bottom: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8 py-4">
        <nav class="mono text-[12px]" style="color: var(--color-ink-subtle);" aria-label="Breadcrumb">
          <a href={localizedPath(locale, "/")} class="hover:text-ink">{tc("home")}</a>
          <span class="mx-1.5">/</span>
          <span style="color: var(--color-ink);">About</span>
        </nav>
      </div>
    </div>

    <EntityListingHero
      eyebrow="About · Medical travel coordinator"
      h1First="MedCasts, in"
      h1Italic="plain English."
      lede="We're a medical-travel coordinator — not a hospital, not an insurer, not an advertising network. Patients come to us when they need surgery or a second opinion abroad, and we sit between them and the hospitals so the paperwork, the pricing, and the logistics don't become someone's second full-time job."
      stats={stats}
    />

    <section style="padding: 56px 0 88px;">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="grid gap-12 lg:grid-cols-[1fr,0.28fr]">
          <article class="min-w-0">
            <div class="about-prose prose-editorial">
              <h2 id="what-we-do">What we actually do</h2>
              <p>
                When a patient contacts us, we match them with 3-5 hospitals that fit their condition, budget, and visa situation. We request written quotes, present them side-by-side, and hand-hold visa paperwork, travel booking, and post-discharge follow-up. The hospital bills the patient directly; we take a coordination fee from the hospital, disclosed up front. No markups, no hidden commissions layered onto the treatment price.
              </p>

              <h2 id="what-we-dont">What we don't do</h2>
              <p>
                We don't practise medicine. We don't diagnose. We don't pick your surgery. When our medical panel writes a second opinion, it's written and signed by a named board-certified specialist at a partner hospital — not by us, and not by a language model. If a case is outside our panel's expertise, we say so and decline it the same day.
              </p>

              <h2 id="vetting">How we vet hospitals</h2>
              <p>
                Every hospital on MedCasts is either JCI-accredited, NABH-accredited (for India), or holds the equivalent national certification. We cross-check against the accrediting body's live registry at listing time and re-check annually. Hospitals that lose accreditation are removed within 30 days of the status change.
              </p>
              <p>
                Pricing is requested in writing per case; we don't publish numbers that haven't been confirmed by the hospital's own IPD (International Patient Department). The price bands you see on destination and cost pages are sampled from partner-hospital quote sheets across a rolling six-month window.
              </p>

              <h2 id="records">How we handle your records</h2>
              <p>
                Medical files you upload are encrypted in transit and at rest. Access is limited to the specific case manager and the reviewing physicians assigned to your case. Records are purged 30 days after we deliver an opinion or after your treatment is complete, whichever is later. We'll sign an NDA on request and support data-export requests within 7 working days. Regulatory posture: GDPR-aligned for EU patients, HIPAA-adjacent for US patients (we're not a Covered Entity, but our Business Associate agreements with US hospital partners cover the handover).
              </p>

              <h2 id="content">How content is written</h2>
              <p>
                Our pages fall into two buckets. First: structured directory data — hospitals, doctors, treatments, prices. This is sourced from hospital websites, public registries (Wikipedia, Wikidata, government portals), and hospital-supplied quote sheets, then templated into reading copy. Second: editorial content — blog posts, visa guides, destination overviews, second-opinion FAQs. Editorial content is drafted in-house and reviewed by a practising specialist before it ships. See our <a href={localizedPath(locale, "/editorial-policy")}>Editorial Policy</a> for the full process.
              </p>

              <h2 id="base">Where we're based</h2>
              <p>
                Operations run out of offices in India and the UAE, with local contract coordinators in Turkey, Thailand, Germany, and Singapore. Most case managers are clustered in Bangalore and Dubai, so response times outside 08:00-22:00 IST are slower on non-emergency inquiries.
              </p>

              <h2 id="contact">Talk to us</h2>
              <ul>
                <li><strong>Patient desk:</strong> <a href="mailto:care@medcasts.com">care@medcasts.com</a></li>
                <li><strong>Press and partnerships:</strong> <a href="mailto:hello@medcasts.com">hello@medcasts.com</a></li>
                <li><strong>Hospital tie-ups:</strong> <a href={localizedPath(locale, "/for-hospitals")}>For hospitals</a></li>
                <li><strong>Emergency desk (24/7):</strong> <a href={localizedPath(locale, "/emergency")}>Emergency &amp; air ambulance</a></li>
              </ul>
            </div>

            <div
              class="mt-12"
              style="padding: 20px 24px; border: 1px dashed var(--color-border); border-radius: var(--radius-lg);"
            >
              <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                A word on limits
              </div>
              <p class="mt-2 serif" style="font-size: 15.5px; line-height: 1.55; color: var(--color-ink-muted);">
                MedCasts is a coordinator, not a clinician. Information on these pages is general. Anything specific to your case — surgery risk, prognosis, medication interactions — comes from the treating physician, in writing, signed. We'll help you get that in front of you. We won't replace it.
              </p>
            </div>
          </article>

          <aside class="hidden lg:block">
            <div class="lg:sticky lg:top-28 lg:self-start space-y-6">
              <nav
                aria-label="On this page"
                style="padding: 18px 0; border-top: 1px solid var(--color-ink);"
              >
                <div class="mono uppercase" style="font-size: 9.5px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                  On this page
                </div>
                <ol class="mt-3 space-y-2 tnum">
                  {TOC.map((item, i) => (
                    <li class="flex gap-2.5">
                      <span class="mono" style="font-size: 11px; color: var(--color-ink-subtle);">{String(i + 1).padStart(2, "0")}</span>
                      <a
                        href={`#${item.id}`}
                        class="serif hover:text-accent transition-colors"
                        style="font-size: 13.5px; line-height: 1.4; color: var(--color-ink);"
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>

              <a
                href={localizedPath(locale, "/editorial-policy")}
                class="paper group block transition hover:-translate-y-0.5"
                style="padding: 18px 20px;"
              >
                <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-accent);">
                  Editorial policy
                </div>
                <div class="serif mt-2" style="font-size: 16px; line-height: 1.3; color: var(--color-ink);">
                  How content is sourced, reviewed, and <span class="italic-display">corrected.</span>
                </div>
                <div class="mt-3 mono uppercase inline-flex items-center gap-1 group-hover:text-accent transition-colors" style="font-size: 10.5px; letter-spacing: 0.14em; color: var(--color-ink-muted);">
                  Read the policy
                  <ChevronRight className="h-3 w-3 mirror-x" />
                </div>
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <style is:global>
      .about-prose > p:first-of-type::first-letter {
        font-family: var(--font-display);
        font-weight: 300;
        font-size: 5em;
        line-height: 0.92;
        float: inline-start;
        margin-inline-end: 10px;
        margin-block-start: 0.08em;
        color: var(--color-ink);
      }
      .about-prose h2 {
        scroll-margin-top: 120px;
      }
    </style>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
