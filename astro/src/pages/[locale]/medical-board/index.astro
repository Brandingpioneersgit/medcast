---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { listActiveReviewers } from "@/lib/queries";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl, SITE_URL, SITE_NAME } from "@/lib/seo";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect("/en/medical-board", 308);
const locale = rawLocale as Locale;

const reviewers = await listActiveReviewers();

const path = "/medical-board";
const url = localeUrl(locale, path);
const title = "Medical Review Panel";
const description = `The physicians who review MedCasts directory and editorial content for clinical accuracy. ${reviewers.length > 0 ? `Currently ${reviewers.length} practicing specialists.` : "Panel onboarding in progress."}`;

const crumbs = breadcrumbJsonLd([
  { name: "Home", url: localeUrl(locale, "/") },
  { name: title, url },
]);

// Schema.org — list the panel so AEO/GEO engines can cite credentialed reviewers
const panelLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: `${SITE_NAME} Medical Review Panel`,
  url,
  parentOrganization: { "@type": "Organization", name: SITE_NAME, url: SITE_URL },
  member: reviewers.map((r) => ({
    "@type": "Person",
    name: r.credentials ? `${r.fullName}, ${r.credentials}` : r.fullName,
    ...(r.jobTitle ? { jobTitle: r.jobTitle } : {}),
    ...(r.imageUrl ? { image: r.imageUrl } : {}),
    ...(r.linkedinUrl ? { sameAs: [r.linkedinUrl] } : {}),
  })),
};

Astro.response.headers.set("Cache-Control", "public, s-maxage=3600, stale-while-revalidate=86400");
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={title} description={description} path={path} locale={locale} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
    <script type="application/ld+json" set:html={JSON.stringify(panelLd)} />
  </Fragment>

  <main class="min-h-dvh" style="background: var(--color-bg); color: var(--color-ink);">
    <SiteHeader locale={locale} />

    <section style="border-bottom: 1px solid var(--color-border); padding: 64px 28px;">
      <div class="mx-auto max-w-[80rem]">
        <p class="mono uppercase" style="font-size: 11px; letter-spacing: 0.14em; color: var(--color-accent);">
          Editorial integrity
        </p>
        <h1 class="display display-tight mt-3" style="font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1; font-weight: 400; letter-spacing: -0.03em;">
          Medical <span class="italic-display">review panel.</span>
        </h1>
        <p class="lede mt-6 max-w-[46rem]">
          MedCasts is a coordinator, not a medical provider. Every directory and editorial page that touches clinical detail is reviewed by a practicing specialist before publication and re-checked quarterly. This page lists who they are, what they review, and how we verify their credentials.
        </p>
      </div>
    </section>

    {reviewers.length === 0 ? (
      <section style="padding: 64px 28px;">
        <div class="mx-auto max-w-[80rem]">
          <div class="paper" style="padding: 40px; max-width: 56rem;">
            <div class="mono uppercase" style="font-size: 11px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
              Panel onboarding in progress
            </div>
            <h2 class="display mt-3" style="font-size: 28px; line-height: 1.2;">
              We are actively recruiting our permanent review panel.
            </h2>
            <p class="mt-4" style="color: var(--color-ink-muted); line-height: 1.6;">
              Until the panel is finalized, directory pages are reviewed by the MedCasts editorial desk against our <a href={localizedPath(locale, "/editorial-policy")} style="color: var(--color-accent); text-decoration: underline;">published methodology</a>. We will not attribute clinical review to a named physician who has not given written consent and whose license we have not independently verified.
            </p>
            <p class="mt-4" style="color: var(--color-ink-muted); line-height: 1.6;">
              If you are a practicing specialist interested in serving on the panel, write to
              <a href="mailto:partnerships@medcasts.com" style="color: var(--color-ink); font-weight: 500;"> partnerships@medcasts.com</a> with your registration details and specialty. Panel members receive a modest honorarium and a permanent profile here.
            </p>
          </div>
        </div>
      </section>
    ) : (
      <section style="padding: 64px 28px;">
        <div class="mx-auto max-w-[80rem]">
          <ul class="grid gap-6" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
            {reviewers.map((r) => (
              <li id={r.slug} class="paper" style="padding: 24px;">
                <div class="flex items-start gap-4">
                  {r.imageUrl ? (
                    <img
                      src={r.imageUrl}
                      alt=""
                      width="56"
                      height="56"
                      loading="lazy"
                      decoding="async"
                      class="rounded-full object-cover shrink-0"
                      style="width: 56px; height: 56px;"
                    />
                  ) : (
                    <div
                      class="rounded-full shrink-0"
                      style="width: 56px; height: 56px; background: var(--color-accent-soft); display: flex; align-items: center; justify-content: center; color: var(--color-accent); font-weight: 600; font-size: 18px;"
                      aria-hidden="true"
                    >
                      {r.fullName.replace(/^Dr\.?\s*/i, "").split(/\s+/).map((w) => w[0]).slice(0, 2).join("")}
                    </div>
                  )}
                  <div class="min-w-0">
                    <div class="font-display" style="font-size: 17px; line-height: 1.25;">
                      {r.fullName}{r.credentials ? `, ${r.credentials}` : ""}
                    </div>
                    {r.jobTitle && (
                      <div style="font-size: 13px; color: var(--color-ink-muted); margin-top: 2px;">
                        {r.jobTitle}
                      </div>
                    )}
                  </div>
                </div>
                {r.bio && (
                  <p style="font-size: 14px; line-height: 1.55; color: var(--color-ink-muted); margin-top: 14px;">
                    {r.bio}
                  </p>
                )}
                {r.specialties && r.specialties.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {r.specialties.slice(0, 6).map((s) => (
                      <span style="padding: 3px 9px; border-radius: 9999px; font-size: 11px; background: var(--color-accent-soft); color: var(--color-accent);">
                        {s.replace(/-/g, " ")}
                      </span>
                    ))}
                  </div>
                )}
                <div class="mt-4 flex items-center gap-3" style="font-size: 12px; color: var(--color-ink-subtle);">
                  {r.licenseCountry && <span>Licensed in {r.licenseCountry}</span>}
                  {r.linkedinUrl && (
                    <a href={r.linkedinUrl} rel="noopener" target="_blank" style="color: var(--color-accent);">
                      LinkedIn ↗
                    </a>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <section style="padding: 48px 28px 96px; border-top: 1px solid var(--color-border-soft);">
      <div class="mx-auto max-w-[80rem] grid gap-10 md:grid-cols-2">
        <div>
          <h2 class="display" style="font-size: 24px; line-height: 1.2;">How we verify reviewers</h2>
          <ol style="margin-top: 16px; padding-inline-start: 20px; font-size: 14.5px; line-height: 1.6; color: var(--color-ink-muted);">
            <li>Independent verification of medical license in their registration country (NMC / GMC / NPI / equivalent).</li>
            <li>Written consent to appear as a named reviewer, renewable annually.</li>
            <li>Conflict-of-interest disclosure — any hospital equity, consulting, or speaker arrangements are declared on this page.</li>
            <li>Each reviewed page is re-checked at least every 12 months, sooner for fast-moving topics (oncology, transplant, fertility).</li>
          </ol>
        </div>
        <div>
          <h2 class="display" style="font-size: 24px; line-height: 1.2;">What we don't do</h2>
          <ul style="margin-top: 16px; padding-inline-start: 20px; font-size: 14.5px; line-height: 1.6; color: var(--color-ink-muted);">
            <li>Attribute clinical review to any physician who has not given written consent.</li>
            <li>Publish reviewer credentials without independent license verification.</li>
            <li>Use reviewer names as a marketing prop on pages they have not actually reviewed.</li>
            <li>Accept payment from hospitals or clinics in exchange for editorial review outcomes.</li>
          </ul>
        </div>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
