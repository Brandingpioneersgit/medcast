---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { getHospitalBySlug } from "@/lib/queries";
import {
  getContent,
  getContentBatch,
  applyTranslated,
} from "@/lib/translate";
import { relatedToHospital } from "@/lib/related";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { hospitalJsonLd, breadcrumbJsonLd, localeUrl, SITE_URL } from "@/lib/seo";
import { getWhatsAppUrl, getHospitalInquiryMessage } from "@/lib/whatsapp";
import { hospitalCover } from "@/lib/images";
import {
  Bed,
  Calendar,
  ChevronRight,
  Globe,
  Mail,
  MapPin,
  MessageCircle,
  Phone,
  Plane,
  ShieldCheck,
} from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
const slug = Astro.params.slug;

if (!isLocale(rawLocale)) return Astro.redirect(`/en/hospital/${slug}`, 308);
if (!slug) return new Response("Not found", { status: 404 });

const locale = rawLocale as Locale;

const hospitalRaw = await getHospitalBySlug(slug);
if (!hospitalRaw) return new Response(`Not found: ${slug}`, { status: 404 });

const tc = getTranslator(locale, "common");
const th = getTranslator(locale, "hospital");

// Translate entity + nested refs
const hospitalMap = await getContent("hospital", hospitalRaw.id, locale);
const hospital = applyTranslated(hospitalRaw, hospitalMap, ["name", "description"]);

const specialtyIds = (hospitalRaw.specialties ?? []).map((hs) => hs.specialty.id);
const specialtyMap = await getContentBatch("specialty", specialtyIds, locale);
const hospitalSpecialties = (hospitalRaw.specialties ?? []).map((hs) => ({
  ...hs,
  specialty: applyTranslated(hs.specialty, specialtyMap[hs.specialty.id] ?? {}, ["name"]),
}));

const doctorIds = (hospitalRaw.doctors ?? []).map((d) => d.id);
const doctorMap = await getContentBatch("doctor", doctorIds, locale);
const hospitalDoctors = (hospitalRaw.doctors ?? []).map((d) =>
  applyTranslated(d, doctorMap[d.id] ?? {}, ["name", "qualifications"]),
);

const relatedHospitals = await relatedToHospital(hospitalRaw.id, 6).catch(() => []);

const accreditations = hospitalRaw.hospitalAccreditations ?? [];
const amenities = hospitalRaw.hospitalAmenities ?? [];
const images = hospitalRaw.images ?? [];

const cityName = hospital.city?.name ?? null;
const countryName = hospital.city?.country?.name ?? null;

// SEO
const title = `${hospital.name}${cityName ? ` — ${cityName}` : ""}`;
const description =
  hospital.description?.slice(0, 160) ??
  `${hospital.name}${cityName ? ` in ${cityName}` : ""}. ${hospital.bedCapacity ? `${hospital.bedCapacity} beds, ` : ""}${accreditations.length} accreditations. Transparent pricing, multilingual care.`;
const path = `/hospital/${slug}`;
const url = localeUrl(locale, path);

const jsonLd = hospitalJsonLd({
  name: hospital.name,
  description: hospital.description,
  address: hospital.address,
  city: cityName,
  country: countryName,
  lat: hospital.latitude,
  lng: hospital.longitude,
  phone: hospital.phone,
  email: hospital.email,
  website: hospital.website,
  rating: hospital.rating,
  reviewCount: hospital.reviewCount,
  imageUrl: hospital.coverImageUrl,
  url,
  bedCapacity: hospital.bedCapacity,
  medicalSpecialties: hospitalSpecialties.map((hs) => hs.specialty.name),
});

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: tc("hospitals"), url: localeUrl(locale, "/hospitals") },
  { name: hospital.name, url },
]);

// CDN cache: 1h fresh, 24h stale-while-revalidate (replaces ISR)
Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title={title}
      description={description}
      path={path}
      locale={locale}
      image={hospital.coverImageUrl ?? undefined}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    {/* Breadcrumb */}
    <div class="border-b border-border bg-bg">
      <div class="mx-auto max-w-7xl px-6 py-3.5 text-sm text-ink-muted">
        <a href={localizedPath(locale, "/")} class="hover:text-accent">{tc("home")}</a>
        <span class="mx-2 text-ink-subtle">/</span>
        <a href={localizedPath(locale, "/hospitals")} class="hover:text-accent">{tc("hospitals")}</a>
        <span class="mx-2 text-ink-subtle">/</span>
        <span class="text-ink">{hospital.name}</span>
      </div>
    </div>

    {/* Hero */}
    <section class="mx-auto max-w-7xl px-6 pt-8 pb-8 md:pt-12">
      <div class="grid gap-10 md:grid-cols-[1fr,22rem] xl:grid-cols-[1fr,24rem]">
        <div>
          <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle mb-3 flex items-center gap-1.5">
            <MapPin className="h-3.5 w-3.5" />
            {cityName}{countryName && `, ${countryName}`}
          </p>
          <h1 class="font-display text-3xl leading-[1.05] md:text-5xl">{hospital.name}</h1>

          <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-3">
            {hospital.rating && Number(hospital.rating) > 0 && (
              <span class="inline-flex items-center gap-1.5 text-sm">
                <span class="text-gold-500">★</span>
                <span class="font-semibold">{Number(hospital.rating).toFixed(1)}</span>
                {hospital.reviewCount && hospital.reviewCount > 0 && (
                  <span class="text-ink-muted">({hospital.reviewCount.toLocaleString()} reviews)</span>
                )}
              </span>
            )}
            {accreditations.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {accreditations.slice(0, 4).map((a) => (
                  <span class="inline-flex items-center rounded-full bg-accent-soft text-accent px-2.5 py-1 text-[11px] font-semibold">
                    {a.accreditation.acronym ?? a.accreditation.name}
                  </span>
                ))}
              </div>
            )}
          </div>

          {/* Gallery */}
          <div class="mt-6 grid gap-2 overflow-hidden rounded-2xl md:grid-cols-[2fr,1fr]">
            <div class="relative aspect-[16/10] overflow-hidden bg-subtle md:aspect-auto md:h-full">
              <img
                src={hospitalCover({ coverImageUrl: hospital.coverImageUrl, countrySlug: hospital.city?.country?.slug })}
                alt={hospital.name}
                class="h-full w-full object-cover"
              />
            </div>
            {images.length > 0 && (
              <div class="grid grid-cols-2 gap-2 md:grid-cols-1">
                {images.slice(0, 2).map((img) => (
                  <div class="relative aspect-[4/3] overflow-hidden rounded-xl bg-subtle md:aspect-auto">
                    <img src={img.url} alt={img.altText ?? hospital.name} class="h-full w-full object-cover" loading="lazy" />
                  </div>
                ))}
              </div>
            )}
          </div>

          {/* Key stats */}
          <div class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-4">
            {hospital.bedCapacity && (
              <div class="rounded-lg border border-border bg-surface px-4 py-3">
                <div class="mb-1 inline-flex items-center gap-1.5 text-xs text-ink-subtle">
                  <Bed className="h-4 w-4" />
                  {th("beds")}
                </div>
                <div class="font-display text-xl text-ink leading-tight">{hospital.bedCapacity.toLocaleString()}</div>
              </div>
            )}
            {hospital.establishedYear && (
              <div class="rounded-lg border border-border bg-surface px-4 py-3">
                <div class="mb-1 inline-flex items-center gap-1.5 text-xs text-ink-subtle">
                  <Calendar className="h-4 w-4" />
                  {th("established")}
                </div>
                <div class="font-display text-xl text-ink leading-tight">{hospital.establishedYear}</div>
              </div>
            )}
            {accreditations.length > 0 && (
              <div class="rounded-lg border border-border bg-surface px-4 py-3">
                <div class="mb-1 inline-flex items-center gap-1.5 text-xs text-ink-subtle">
                  <ShieldCheck className="h-4 w-4" />
                  {th("accreditation")}
                </div>
                <div class="font-display text-xl text-ink leading-tight">{accreditations.length}</div>
              </div>
            )}
            {hospital.airportDistanceKm != null && (
              <div class="rounded-lg border border-border bg-surface px-4 py-3">
                <div class="mb-1 inline-flex items-center gap-1.5 text-xs text-ink-subtle">
                  <Plane className="h-4 w-4" />
                  {th("airportDistance")}
                </div>
                <div class="font-display text-xl text-ink leading-tight">{hospital.airportDistanceKm} km</div>
              </div>
            )}
          </div>
        </div>

        {/* Sidebar */}
        <aside class="md:sticky md:top-24 md:self-start">
          <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
            <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-ink-subtle">
              Plan your visit
            </p>
            <p class="font-display text-lg leading-snug">
              Get a named case manager and a written plan in 11 minutes.
            </p>
            <div class="mt-5 flex flex-col gap-2">
              <a
                href={localizedPath(locale, `/contact?hospital=${hospital.slug}`)}
                class="inline-flex items-center justify-center rounded-lg bg-accent text-accent-contrast px-4 py-2.5 text-sm font-semibold hover:bg-accent-hover transition-colors"
              >
                {tc("getQuote")}
              </a>
              <a
                href={getWhatsAppUrl(getHospitalInquiryMessage(hospital.name))}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 rounded-lg border border-border px-4 py-2.5 text-sm font-semibold hover:border-border-strong hover:bg-subtle transition-colors"
              >
                <MessageCircle className="h-4 w-4" />
                {tc("whatsapp")}
              </a>
            </div>

            <dl class="mt-6 space-y-3 border-t border-border pt-5 text-sm">
              {hospital.phone && (
                <div class="flex items-start gap-3">
                  <dt class="shrink-0 inline-flex h-6 w-6 items-center justify-center rounded-full bg-subtle text-ink-muted">
                    <Phone className="h-3.5 w-3.5" />
                  </dt>
                  <dd>
                    <a href={`tel:${hospital.phone}`} class="text-ink hover:text-accent">
                      {hospital.phone}
                    </a>
                  </dd>
                </div>
              )}
              {hospital.email && (
                <div class="flex items-start gap-3">
                  <dt class="shrink-0 inline-flex h-6 w-6 items-center justify-center rounded-full bg-subtle text-ink-muted">
                    <Mail className="h-3.5 w-3.5" />
                  </dt>
                  <dd>
                    <a href={`mailto:${hospital.email}`} class="text-ink hover:text-accent break-all">
                      {hospital.email}
                    </a>
                  </dd>
                </div>
              )}
              {hospital.website && (
                <div class="flex items-start gap-3">
                  <dt class="shrink-0 inline-flex h-6 w-6 items-center justify-center rounded-full bg-subtle text-ink-muted">
                    <Globe className="h-3.5 w-3.5" />
                  </dt>
                  <dd>
                    <a href={hospital.website} target="_blank" rel="noopener noreferrer" class="text-ink hover:text-accent break-all">
                      {(() => { try { return new URL(hospital.website).host.replace(/^www\./, ""); } catch { return hospital.website; } })()}
                    </a>
                  </dd>
                </div>
              )}
              {hospital.address && (
                <div class="flex items-start gap-3">
                  <dt class="shrink-0 inline-flex h-6 w-6 items-center justify-center rounded-full bg-subtle text-ink-muted">
                    <MapPin className="h-3.5 w-3.5" />
                  </dt>
                  <dd class="text-ink-muted">{hospital.address}</dd>
                </div>
              )}
            </dl>
          </div>
        </aside>
      </div>
    </section>

    {/* Section nav */}
    <nav class="sticky top-[65px] z-30 border-y border-border bg-bg/95 backdrop-blur">
      <div class="mx-auto max-w-7xl px-6 py-3 flex gap-6 overflow-x-auto text-sm">
        <a href="#overview" class="text-ink hover:text-accent whitespace-nowrap">Overview</a>
        {hospitalSpecialties.length > 0 && <a href="#specialties" class="text-ink-muted hover:text-accent whitespace-nowrap">Specialties</a>}
        {hospitalDoctors.length > 0 && <a href="#doctors" class="text-ink-muted hover:text-accent whitespace-nowrap">Doctors</a>}
        {amenities.length > 0 && <a href="#amenities" class="text-ink-muted hover:text-accent whitespace-nowrap">Amenities</a>}
        <a href="#faq" class="text-ink-muted hover:text-accent whitespace-nowrap">Questions</a>
      </div>
    </nav>

    {/* Overview */}
    <section id="overview" class="mx-auto max-w-7xl px-6 py-12 scroll-mt-32">
      <div class="grid gap-10 md:grid-cols-[1.4fr,1fr]">
        <div>
          {hospital.description ? (
            <div class="prose-editorial">
              <p>{hospital.description}</p>
            </div>
          ) : (
            <p class="text-ink-muted">
              {hospital.name} is an accredited international medical destination.
            </p>
          )}
        </div>
        <div class="rounded-2xl bg-surface-muted p-6">
          <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-ink-subtle">
            Why international patients choose it
          </p>
          <ul class="space-y-3 text-sm text-ink-muted">
            <li class="flex gap-3">
              <ShieldCheck className="h-4 w-4 shrink-0 text-accent mt-0.5" />
              <span>Accredited by international bodies for patient safety and outcomes.</span>
            </li>
            <li class="flex gap-3">
              <Phone className="h-4 w-4 shrink-0 text-accent mt-0.5" />
              <span>24/7 multilingual case manager, WhatsApp and phone.</span>
            </li>
            <li class="flex gap-3">
              <Plane className="h-4 w-4 shrink-0 text-accent mt-0.5" />
              <span>Full travel concierge — visa letter, airport pickup, recovery stays.</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    {/* Specialties */}
    {hospitalSpecialties.length > 0 && (
      <section id="specialties" class="border-t border-border bg-surface-muted py-12 scroll-mt-32">
        <div class="mx-auto max-w-7xl px-6">
          <h2 class="font-display text-2xl md:text-3xl mb-6">Specialties</h2>
          <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {hospitalSpecialties.map((hs) => (
              <li>
                <a
                  href={localizedPath(locale, `/hospital/${hospital.slug}/${hs.specialty.slug}`)}
                  class="group flex items-center justify-between rounded-lg border border-border bg-surface p-4 transition-colors hover:border-border-strong hover:bg-bg"
                >
                  <span>
                    <span class="block font-medium text-ink group-hover:text-accent transition-colors">
                      {hs.specialty.name}
                    </span>
                    {hs.isCenterOfExcellence && (
                      <span class="inline-block mt-1.5 rounded-full bg-accent-soft text-accent px-2 py-0.5 text-[10px] font-semibold">
                        Center of excellence
                      </span>
                    )}
                  </span>
                  <ChevronRight className="h-4 w-4 text-ink-subtle mirror-x" />
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    {/* Doctors */}
    {hospitalDoctors.length > 0 && (
      <section id="doctors" class="border-t border-border py-12 scroll-mt-32">
        <div class="mx-auto max-w-7xl px-6">
          <h2 class="font-display text-2xl md:text-3xl mb-6">Doctors</h2>
          <ul class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {hospitalDoctors.map((doc) => (
              <li>
                <a
                  href={localizedPath(locale, `/doctor/${doc.slug}`)}
                  class="group flex items-start gap-4 rounded-lg border border-border bg-surface p-5 transition-colors hover:border-border-strong"
                >
                  {doc.imageUrl ? (
                    <img src={doc.imageUrl} alt={doc.name} class="h-14 w-14 rounded-full object-cover" />
                  ) : (
                    <div class="h-14 w-14 rounded-full bg-accent-soft text-accent inline-flex items-center justify-center font-semibold">
                      {doc.name.slice(0, 1)}
                    </div>
                  )}
                  <div class="min-w-0">
                    <p class="font-display text-base leading-tight text-ink group-hover:text-accent transition-colors">
                      {doc.title ? `${doc.title} ` : ""}{doc.name}
                    </p>
                    {doc.qualifications && (
                      <p class="mt-1 text-xs text-ink-muted line-clamp-2">{doc.qualifications}</p>
                    )}
                    {doc.experienceYears && (
                      <p class="mt-2 text-xs text-ink-subtle">{doc.experienceYears}+ years experience</p>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    {/* Amenities */}
    {amenities.length > 0 && (
      <section id="amenities" class="border-t border-border bg-surface-muted py-12 scroll-mt-32">
        <div class="mx-auto max-w-7xl px-6">
          <h2 class="font-display text-2xl md:text-3xl mb-6">Amenities</h2>
          <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
            {amenities.map((ha) => (
              <li class="flex items-center gap-2.5 rounded-md border border-border bg-surface px-3 py-2.5">
                <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent-soft text-accent text-sm">✓</span>
                <span class="text-sm text-ink">{ha.amenity.name}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    {/* FAQ — native details, zero JS */}
    <section id="faq" class="border-t border-border py-12 scroll-mt-32">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="font-display text-2xl md:text-3xl mb-6">Common questions</h2>
        <div class="space-y-3">
          <details class="group rounded-lg border border-border bg-surface p-5 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between font-medium text-ink">
              How does a MedCasts case manager work with this hospital?
              <ChevronRight className="h-4 w-4 text-ink-subtle transition-transform group-open:rotate-90" />
            </summary>
            <p class="mt-3 text-sm text-ink-muted leading-relaxed">
              A named case manager sends your reports to the hospital's international desk, negotiates the treatment plan and price, and stays with you through discharge and follow-up.
            </p>
          </details>
          <details class="group rounded-lg border border-border bg-surface p-5 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between font-medium text-ink">
              Are prices negotiated?
              <ChevronRight className="h-4 w-4 text-ink-subtle transition-transform group-open:rotate-90" />
            </summary>
            <p class="mt-3 text-sm text-ink-muted leading-relaxed">
              Yes — published prices are indicative. Your case manager secures the final package price, including surgeon, stay, and post-op follow-up.
            </p>
          </details>
          <details class="group rounded-lg border border-border bg-surface p-5 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between font-medium text-ink">
              Do you help with the medical visa?
              <ChevronRight className="h-4 w-4 text-ink-subtle transition-transform group-open:rotate-90" />
            </summary>
            <p class="mt-3 text-sm text-ink-muted leading-relaxed">
              We issue the invitation letter the hospital needs for your medical visa, and coordinate airport pickup and recovery-stay bookings.
            </p>
          </details>
        </div>
      </div>
    </section>

    {/* Related hospitals */}
    {relatedHospitals.length > 0 && (
      <section class="border-t border-border bg-surface-muted py-12">
        <div class="mx-auto max-w-7xl px-6">
          <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink-subtle">Nearby</p>
          <h2 class="mt-2 font-display text-2xl md:text-3xl mb-6">
            Other hospitals in {cityName ?? "this city"}.
          </h2>
          <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {relatedHospitals.map((r) => (
              <li>
                <a
                  href={localizedPath(locale, r.href)}
                  class="group flex items-center justify-between rounded-lg border border-border bg-surface p-4 transition-colors hover:border-border-strong"
                >
                  <span>
                    <span class="block font-medium text-ink group-hover:text-accent transition-colors">
                      {r.name}
                    </span>
                    {r.subtitle && <span class="block text-xs text-ink-subtle">{r.subtitle}</span>}
                  </span>
                  <ChevronRight className="h-4 w-4 text-ink-subtle mirror-x" />
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>

