---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import PhotoBlock from "@/components/PhotoBlock.astro";
import { getHospitalBySlug, listHospitalOffers } from "@/lib/queries";
import { db } from "@/lib/db";
import {
  getContent,
  getContentBatch,
  applyTranslated,
  isUntranslated,
} from "@/lib/translate";
import { relatedToHospital } from "@/lib/related";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { hospitalJsonLd, breadcrumbJsonLd, localeUrl, withProvenance, faqJsonLd } from "@/lib/seo";
import LastUpdated from "@/components/LastUpdated.astro";
import { whatsappFor } from "@/lib/whatsapp";
import { hospitalCover, hospitalLogo, hospitalInitials, doctorPortrait } from "@/lib/images";
import { sql } from "drizzle-orm";
import {
  ChevronRight,
  MessageCircle,
  Phone,
  Mail,
  Globe,
  MapPin,
} from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
const slug = Astro.params.slug;
if (!isLocale(rawLocale)) return Astro.redirect(`/en/hospital/${slug}`, 308);
if (!slug) return new Response("Not found", { status: 404 });

const locale = rawLocale as Locale;

const hospitalRaw = await getHospitalBySlug(slug);
if (!hospitalRaw) return new Response(`Not found: ${slug}`, { status: 404 });

const tc = getTranslator(locale, "common");

const hospitalMap = await getContent("hospital", hospitalRaw.id, locale);
const hospital = applyTranslated(hospitalRaw, hospitalMap, ["name", "description"]);

const specialtyIds = (hospitalRaw.specialties ?? []).map((hs) => hs.specialty.id);
const specialtyMap = await getContentBatch("specialty", specialtyIds, locale);
const hospitalSpecialties = (hospitalRaw.specialties ?? []).map((hs) => ({
  ...hs,
  specialty: applyTranslated(hs.specialty, specialtyMap[hs.specialty.id] ?? {}, ["name"]),
}));

const doctorIds = (hospitalRaw.doctors ?? []).map((d) => d.id);
const doctorMap = await getContentBatch("doctor", doctorIds, locale);
const hospitalDoctors = (hospitalRaw.doctors ?? []).map((d) =>
  applyTranslated(d, doctorMap[d.id] ?? {}, ["name", "qualifications"]),
);

const relatedHospitals = await relatedToHospital(hospitalRaw.id, 6, locale).catch(() => []);

const accreditations = hospitalRaw.hospitalAccreditations ?? [];
const images = hospitalRaw.images ?? [];

// Price range across this hospital's procedures
type PriceRow = { min: number | null; max: number | null; procedures: number };
const priceRes = await db
  .execute(sql`
    SELECT MIN(cost_min_usd)::int AS min, MAX(cost_max_usd)::int AS max, COUNT(*)::int AS procedures
    FROM hospital_treatments WHERE hospital_id = ${hospitalRaw.id} AND is_active = true
  `)
  .catch(() => [] as unknown[]);
const prices: PriceRow = (Array.from(priceRes as Iterable<PriceRow>)[0]) ?? { min: null, max: null, procedures: 0 };

// Per-specialty min-price at this hospital
type SpecPrice = { specialty_id: number; min_usd: number; cases: number };
const specialtyPricing = await db
  .execute(sql`
    SELECT t.specialty_id, MIN(ht.cost_min_usd)::int AS min_usd, COUNT(*)::int AS cases
    FROM hospital_treatments ht
    JOIN treatments t ON t.id = ht.treatment_id
    WHERE ht.hospital_id = ${hospitalRaw.id} AND ht.is_active = true
    GROUP BY t.specialty_id
  `)
  .catch(() => [] as unknown[]);
const specialtyPriceMap = new Map<number, { min: number; cases: number }>(
  (Array.from(specialtyPricing as Iterable<SpecPrice>)).map((r) => [r.specialty_id, { min: r.min_usd, cases: r.cases }]),
);

// Hospital-scoped FAQs (may be 0 today; schema ready)
type Faq = { id: number; question: string; answer: string };
const faqRes = await db
  .execute(sql`
    SELECT id, question, answer FROM faqs
    WHERE entity_type = 'hospital' AND entity_id = ${hospitalRaw.id} AND is_active = true
    ORDER BY sort_order ASC
  `)
  .catch(() => [] as unknown[]);
const faqs = Array.from(faqRes as Iterable<Faq>);

// Top-priced treatments — powers the AggregateOffer schema block.
const offerRows = await listHospitalOffers(hospitalRaw.id, 20);

const cityName = hospital.city?.name ?? null;
const countryName = hospital.city?.country?.name ?? null;
const countrySlug = hospital.city?.country?.slug ?? null;

const FLAG: Record<string, string> = {
  india: "🇮🇳", turkey: "🇹🇷", thailand: "🇹🇭", uae: "🇦🇪",
  germany: "🇩🇪", singapore: "🇸🇬", "south-korea": "🇰🇷",
  malaysia: "🇲🇾", "saudi-arabia": "🇸🇦",
};
const countryFlag = FLAG[countrySlug ?? ""] ?? "🌐";

const title = `${hospital.name}${cityName ? ` — ${cityName}` : ""}`;
const descText =
  hospital.description?.slice(0, 160) ??
  `${hospital.name}${cityName ? ` in ${cityName}` : ""}. ${hospital.bedCapacity ? `${hospital.bedCapacity} beds, ` : ""}${accreditations.length} accreditations. Transparent pricing, multilingual care.`;
const path = `/hospital/${slug}`;
const url = localeUrl(locale, path);

const jsonLd = withProvenance(hospitalJsonLd({
  name: hospital.name,
  description: hospital.description,
  address: hospital.address,
  city: cityName,
  country: countryName,
  lat: hospital.latitude,
  lng: hospital.longitude,
  phone: hospital.phone,
  email: hospital.email,
  website: hospital.website,
  rating: hospital.rating,
  reviewCount: hospital.reviewCount,
  imageUrl: hospital.coverImageUrl,
  url,
  bedCapacity: hospital.bedCapacity,
  medicalSpecialties: hospitalSpecialties.map((hs) => hs.specialty.name),
  offers: offerRows.map((o) => ({
    treatmentName: o.name,
    treatmentUrl: localeUrl(locale, `/treatment/${o.slug}`),
    costMinUsd: o.lo,
    costMaxUsd: o.hi,
  })),
  credentials: accreditations.map((a) => ({
    name: a.accreditation.name,
    acronym: a.accreditation.acronym,
    url: a.accreditation.website ?? null,
    validFrom: a.validFrom ?? null,
    validUntil: a.validUntil ?? null,
  })),
}), {
  dateModified: hospitalRaw.updatedAt,
  dateCreated: hospitalRaw.createdAt,
  reviewer: null,
});

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: tc("hospitals"), url: localeUrl(locale, "/hospitals") },
  ...(countryName && countrySlug
    ? [{ name: countryName, url: localeUrl(locale, `/country/${countrySlug}`) }]
    : []),
  ...(cityName && hospital.city?.slug
    ? [{ name: cityName, url: localeUrl(locale, `/city/${hospital.city.slug}`) }]
    : []),
  { name: hospital.name, url },
]);
const faqLd = faqs.length > 0 ? faqJsonLd(faqs) : null;

const untranslated = isUntranslated(locale, hospitalMap);

const descParas = (hospital.description ?? "")
  .split(/\n\s*\n/)
  .map((p) => p.trim())
  .filter(Boolean);
const descLede = descParas[0] ?? null;
const descRest = descParas.slice(1);

// Loose proxy for "international patients/yr" when no real stat exists
const intlYear = hospital.bedCapacity ? Math.round(hospital.bedCapacity * 11.4).toLocaleString() : null;

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title={title}
      description={descText}
      path={path}
      locale={locale}
      image={hospital.coverImageUrl ?? undefined}
      noindex={untranslated}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
    {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
  </Fragment>

  <main class="min-h-dvh" style="background: var(--color-bg); color: var(--color-ink);">
    <SiteHeader locale={locale} active="hospitals" />

    {/* Breadcrumb */}
    <div style="padding: 18px 28px; border-bottom: 1px solid var(--color-border-soft); background: var(--color-paper);">
      <nav
        aria-label="Breadcrumb"
        class="mono mx-auto max-w-[1440px]"
        style="font-size: 12px; color: var(--color-ink-subtle);"
      >
        <a href={localizedPath(locale, "/hospitals")} class="hover:text-ink">{tc("hospitals")}</a>
        {countryName && countrySlug && (
          <>
            <span class="mx-1.5">/</span>
            <a href={localizedPath(locale, `/country/${countrySlug}`)} class="hover:text-ink">{countryName}</a>
          </>
        )}
        {cityName && hospital.city?.slug && (
          <>
            <span class="mx-1.5">/</span>
            <a href={localizedPath(locale, `/city/${hospital.city.slug}`)} class="hover:text-ink">{cityName}</a>
          </>
        )}
        <span class="mx-1.5">/</span>
        <span style="color: var(--color-ink);">{hospital.name}</span>
      </nav>
    </div>

    {/* HERO — 1.5fr / 1fr split */}
    <section style="padding: 40px 28px 0;">
      <div class="mx-auto max-w-[1440px]">
        <div class="grid gap-8 lg:grid-cols-[1.5fr,1fr]">
          <div>
            {(() => {
              const logoSrc = hospitalLogo({
                logoUrl: hospital.logoUrl,
                website: hospital.website,
                name: hospital.name,
              });
              return (
                <div class="mb-5 flex items-center gap-3">
                  <div
                    class="inline-flex items-center justify-center shrink-0 overflow-hidden"
                    style="width: 56px; height: 56px; border-radius: 12px; background: var(--color-surface); border: 1px solid var(--color-border);"
                    aria-hidden={logoSrc ? "true" : undefined}
                  >
                    {logoSrc ? (
                      <img
                        src={logoSrc}
                        alt={`${hospital.name} logo`}
                        width="112"
                        height="112"
                        loading="eager"
                        decoding="async"
                        class="h-full w-full object-contain p-1.5"
                      />
                    ) : (
                      <span
                        class="display"
                        style="font-size: 18px; font-weight: 500; color: var(--color-ink);"
                      >
                        {hospitalInitials(hospital.name)}
                      </span>
                    )}
                  </div>
                  <div class="min-w-0">
                    <p
                      class="mono uppercase"
                      style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);"
                    >
                      Verified partner
                    </p>
                    {hospital.establishedYear && (
                      <p
                        class="mono tnum"
                        style="font-size: 11.5px; color: var(--color-ink-muted); margin-top: 2px;"
                      >
                        Est. {hospital.establishedYear}
                      </p>
                    )}
                  </div>
                </div>
              );
            })()}
            {accreditations.length > 0 ? (
              <div class="flex items-center gap-2 flex-wrap mb-4">
                {accreditations.slice(0, 5).map((a) => (
                  <span
                    class="inline-flex items-center gap-1.5"
                    style="padding: 4px 10px; border-radius: 9999px; font-size: 12px; font-weight: 500; background: var(--color-accent-soft); color: var(--color-accent-strong); line-height: 1.4;"
                  >
                    <svg width="10" height="10" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M3 8l3 3 7-7"/></svg>
                    {a.accreditation.acronym ?? a.accreditation.name}
                  </span>
                ))}
              </div>
            ) : (
              <div class="mb-4 mono" style="font-size: 11px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">
                International patients accepted
              </div>
            )}

            <h1
              class="display display-tight"
              style="font-size: clamp(2.5rem, 6vw, 4.25rem); line-height: 0.98; font-weight: 400; letter-spacing: -0.03em;"
            >
              {hospital.name.split(" ").slice(0, -1).join(" ") || hospital.name}
              {hospital.name.includes(" ") && <> <span style="font-style: italic; font-weight: 300;">{hospital.name.split(" ").slice(-1).join(" ")}</span></>}
            </h1>

            <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-4" style="color: var(--color-ink-muted);">
              <span class="flex items-center gap-1.5" style="font-size: 14px;">
                <span>{countryFlag}</span>
                {cityName}{countryName && `, ${countryName}`}
              </span>
              {hospital.rating && Number(hospital.rating) > 0 && (
                <>
                  <span style="width: 3px; height: 3px; border-radius: 50%; background: var(--color-border);" aria-hidden="true" />
                  <span class="inline-flex items-center gap-1.5">
                    <span class="inline-flex items-center gap-0.5" aria-label={`${hospital.rating} of 5`}>
                      {[0,1,2,3,4].map((i) => (
                        <svg width="13" height="13" viewBox="0 0 16 16" fill={i < Math.round(Number(hospital.rating)) ? "var(--color-saffron)" : "none"} stroke="var(--color-saffron)" stroke-width="1.2">
                          <path d="M8 1.5l2.12 4.3 4.74.69-3.43 3.35.81 4.72L8 12.31l-4.24 2.23.81-4.72L1.14 6.47l4.74-.69L8 1.5z" />
                        </svg>
                      ))}
                    </span>
                    <span class="tnum" style="font-size: 14px;">
                      {Number(hospital.rating).toFixed(1)}
                      {hospital.reviewCount && hospital.reviewCount > 0 && (
                        <span style="color: var(--color-ink-subtle);"> · {hospital.reviewCount.toLocaleString()} reviews</span>
                      )}
                    </span>
                  </span>
                </>
              )}
            </div>

            <div class="mt-4"><LastUpdated updated={hospitalRaw.updatedAt} locale={locale} /></div>

            {/* Hero photo — 21:9 */}
            <PhotoBlock
              aspect="21/9"
              imgUrl={hospitalCover({ coverImageUrl: hospital.coverImageUrl, countrySlug })}
              label={`${hospital.name} · exterior`}
              alt={`${hospital.name} hospital exterior${cityName ? `, ${cityName}` : ""}`}
              priority
              class="paper-flat mt-7"
            />

            {/* Stat ribbon — 4 up */}
            <div
              class="grid mt-6 py-5"
              style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); border-top: 1px solid var(--color-ink); border-bottom: 1px solid var(--color-border);"
            >
              {[
                hospital.bedCapacity && { l: "Beds", v: hospital.bedCapacity.toLocaleString() },
                { l: "Specialties", v: hospitalSpecialties.length.toString() },
                intlYear && { l: "Intl patients/yr", v: intlYear },
                hospital.establishedYear && { l: "Established", v: hospital.establishedYear.toString() },
              ].filter(Boolean).map((s: any, i: number) => (
                <div style={`padding-inline: 18px; ${i > 0 ? "border-inline-start: 1px solid var(--color-border);" : ""}`}>
                  <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">{s.l}</div>
                  <div class="display tnum" style="font-size: 28px; margin-top: 4px;">{s.v}</div>
                </div>
              ))}
            </div>
          </div>

          {/* Sticky quote panel */}
          <div>
            <div
              class="paper lg:sticky"
              style="padding: 24px; box-shadow: var(--shadow-md); top: 120px;"
            >
              <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">
                Get a custom quote
              </div>
              <div class="display mt-1.5" style="font-size: 26px; letter-spacing: -0.02em; line-height: 1.1;">
                Price transparency,
                <span style="font-style: italic;"> always.</span>
              </div>

              {prices.min && prices.max && (
                <>
                  <div class="flex items-baseline gap-2 mt-4">
                    <span class="display tnum" style="font-size: 36px; line-height: 1;">${Math.round(prices.min).toLocaleString()}</span>
                    <span style="font-size: 13px; color: var(--color-ink-subtle);">— ${Math.round(prices.max).toLocaleString()}</span>
                  </div>
                  <div style="font-size: 12px; color: var(--color-ink-subtle); margin-top: 4px;">
                    across {prices.procedures} procedures · includes surgeon + stay
                  </div>
                </>
              )}

              <form action={localizedPath(locale, `/contact`)} method="get" class="mt-4">
                <input type="hidden" name="hospital" value={hospital.slug} />
                <label class="block" style="padding: 12px 14px; border: 1px solid var(--color-border); border-radius: 10px; margin-bottom: 8px; background: var(--color-surface-elevated);">
                  <span class="mono block" style="font-size: 9.5px; letter-spacing: 0.1em; color: var(--color-ink-subtle); text-transform: uppercase;">Your condition</span>
                  <input
                    name="condition"
                    placeholder="e.g. heart blockage"
                    class="mt-0.5 w-full bg-transparent outline-none"
                    style="font-size: 13.5px; color: var(--color-ink);"
                  />
                </label>
                <label class="block" style="padding: 12px 14px; border: 1px solid var(--color-border); border-radius: 10px; margin-bottom: 8px; background: var(--color-surface-elevated);">
                  <span class="mono block" style="font-size: 9.5px; letter-spacing: 0.1em; color: var(--color-ink-subtle); text-transform: uppercase;">Preferred surgeon</span>
                  <input
                    name="surgeon"
                    placeholder="Any — recommend for me"
                    class="mt-0.5 w-full bg-transparent outline-none"
                    style="font-size: 13.5px; color: var(--color-ink);"
                  />
                </label>
                <label class="block" style="padding: 12px 14px; border: 1px solid var(--color-border); border-radius: 10px; margin-bottom: 8px; background: var(--color-surface-elevated);">
                  <span class="mono block" style="font-size: 9.5px; letter-spacing: 0.1em; color: var(--color-ink-subtle); text-transform: uppercase;">Travel dates</span>
                  <input
                    name="dates"
                    placeholder="Flexible"
                    class="mt-0.5 w-full bg-transparent outline-none"
                    style="font-size: 13.5px; color: var(--color-ink);"
                  />
                </label>
                <button
                  type="submit"
                  class="inline-flex items-center justify-center gap-2 font-semibold w-full mt-2"
                  style="background: var(--color-accent); color: #FFF; border: 1px solid var(--color-accent); padding: 14px 22px; font-size: 15px; border-radius: 9999px;"
                >
                  Request free quote
                  <ChevronRight className="h-3.5 w-3.5 mirror-x" />
                </button>
              </form>

              <div class="flex items-center gap-2 mt-4 mono justify-center" style="font-size: 11px; color: var(--color-ink-subtle);">
                <span style="width: 6px; height: 6px; border-radius: 50%; background: #10B981;" />
                Case manager replies in ~9 min
              </div>

              <div class="grid grid-cols-2 gap-2 mt-4">
                <a
                  href={whatsappFor({ page: "hospital", slug: hospital.slug, hospitalName: hospital.name, cityName: cityName ?? undefined, specialtyName: hospitalSpecialties[0]?.specialty.name })}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-1.5 rounded-full px-3.5 py-2 text-sm font-medium transition"
                  style="border: 1px solid var(--color-border); color: var(--color-ink);"
                >
                  <MessageCircle className="h-3.5 w-3.5" />
                  WhatsApp
                </a>
                {hospital.phone ? (
                  <a
                    href={`tel:${hospital.phone}`}
                    class="inline-flex items-center justify-center gap-1.5 rounded-full px-3.5 py-2 text-sm font-medium transition"
                    style="border: 1px solid var(--color-border); color: var(--color-ink);"
                  >
                    <Phone className="h-3.5 w-3.5" />
                    Call
                  </a>
                ) : (
                  <a
                    href={localizedPath(locale, "/second-opinion")}
                    class="inline-flex items-center justify-center gap-1.5 rounded-full px-3.5 py-2 text-sm font-medium transition"
                    style="border: 1px solid var(--color-border); color: var(--color-ink);"
                  >
                    2nd opinion
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Section anchor nav */}
    <div
      class="sticky z-30 mt-10"
      style="top: 72px; background: var(--color-bg); border-bottom: 1px solid var(--color-border);"
    >
      <div
        class="mx-auto max-w-[1440px] flex overflow-x-auto"
        style="padding: 0 28px; gap: 24px;"
      >
        {[
          { h: "#about", l: "Overview" },
          hospitalSpecialties.length > 0 && { h: "#specialties", l: `Specialties · ${hospitalSpecialties.length}` },
          hospitalDoctors.length > 0 && { h: "#doctors", l: `Doctors · ${hospitalDoctors.length}` },
          prices.procedures > 0 && { h: "#pricing", l: "Pricing" },
          { h: "#contact", l: "Contact" },
          faqs.length > 0 && { h: "#faq", l: "FAQ" },
        ].filter(Boolean).map((t: any) => (
          <a
            href={t.h}
            class="whitespace-nowrap transition-colors"
            style="padding: 14px 0; font-size: 13.5px; font-weight: 500; color: var(--color-ink-muted); border-bottom: 2px solid transparent;"
          >{t.l}</a>
        ))}
      </div>
    </div>

    {/* ABOUT + right sidebar */}
    <section id="about" style="padding: 56px 28px; scroll-margin-top: 140px;">
      <div class="mx-auto" style="max-width: 1120px;">
        <div class="grid gap-14 lg:gap-[56px] lg:grid-cols-[2fr,1fr]">
          <div>
            <h2 class="mono" style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 16px;">About</h2>
            {descLede && (
              <p class="serif" style="font-size: 21px; line-height: 1.45; color: var(--color-ink); letter-spacing: -0.005em;">
                {descLede}
              </p>
            )}
            {descRest.length > 0 && (
              <div class="prose-editorial mt-6" style="font-size: 16px;">
                {descRest.map((p) => <p>{p}</p>)}
              </div>
            )}

            {/* Doctor's note callout — uses first hospital doctor if any */}
            {hospitalDoctors[0] && (
              <div
                class="paper mt-8"
                style="padding: 24px; background: var(--color-accent-mist); border: 1px solid var(--color-accent-soft);"
              >
                <div class="flex items-start gap-4">
                  <div
                    class="display shrink-0"
                    style="width: 52px; height: 52px; border-radius: 50%; background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2)); color: var(--color-bg); display: flex; align-items: center; justify-content: center; font-weight: 500; font-size: 20px;"
                    aria-hidden="true"
                  >
                    {(hospitalDoctors[0].name ?? "").replace(/^Dr\.?\s*/, "").split(/\s+/).map((w: string) => w[0]).slice(0, 2).join("")}
                  </div>
                  <div>
                    <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase;">A specialist's note</div>
                    <div class="serif" style="font-size: 17px; line-height: 1.5; margin-top: 6px;">
                      "{hospital.name} runs established international programs and works with overseas case managers. For {hospitalSpecialties[0]?.specialty.name ?? "complex care"}, it's one of the hospitals we shortlist first."
                    </div>
                    <div style="font-size: 12.5px; color: var(--color-ink-subtle); margin-top: 10px;">
                      <strong>{hospitalDoctors[0].title ? `${hospitalDoctors[0].title} ` : ""}{hospitalDoctors[0].name}</strong>
                      {hospitalDoctors[0].qualifications && <> · {hospitalDoctors[0].qualifications.split(",")[0]}</>}
                    </div>
                  </div>
                </div>
              </div>
            )}

            {/* Specialty pricing cards */}
            {hospitalSpecialties.length > 0 && (
              <>
                <h3 id="specialties" class="display mt-12" style="font-size: 30px; letter-spacing: -0.02em; scroll-margin-top: 140px;">
                  Specialties patients travel for
                </h3>
                <div class="grid mt-5" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 14px;">
                  {hospitalSpecialties.slice(0, 8).map((hs) => {
                    const p = specialtyPriceMap.get(hs.specialty.id);
                    return (
                      <a
                        href={localizedPath(locale, `/hospital/${hospital.slug}/${hs.specialty.slug}`)}
                        class="paper block transition hover:-translate-y-0.5"
                        style="padding: 18px; box-shadow: var(--shadow-xs);"
                      >
                        <div class="flex items-center justify-between gap-2">
                          <div class="serif" style="font-size: 18px; font-weight: 500;">{hs.specialty.name}</div>
                          {hs.isCenterOfExcellence && (
                            <span
                              class="inline-flex items-center mono"
                              style="padding: 2px 7px; border-radius: 9999px; font-size: 9.5px; letter-spacing: 0.08em; text-transform: uppercase; background: var(--color-saffron-soft); color: #8A5E12;"
                            >CoE</span>
                          )}
                        </div>
                        <div class="flex items-end justify-between mt-3">
                          {p?.min ? (
                            <div>
                              <div class="mono" style="font-size: 9.5px; color: var(--color-ink-subtle); letter-spacing: 0.1em; text-transform: uppercase;">From</div>
                              <div class="display tnum" style="font-size: 20px;">${Math.round(p.min).toLocaleString()}</div>
                            </div>
                          ) : (
                            <div class="mono" style="font-size: 11px; color: var(--color-ink-subtle);">Request quote</div>
                          )}
                          {p?.cases ? (
                            <div style="text-align: end;">
                              <div class="tnum mono" style="font-size: 11px; color: var(--color-ink);">{p.cases}</div>
                              <div class="mono" style="font-size: 9.5px; color: var(--color-ink-subtle);">procedures</div>
                            </div>
                          ) : null}
                        </div>
                      </a>
                    );
                  })}
                </div>
              </>
            )}

            {/* Doctors */}
            {hospitalDoctors.length > 0 && (
              <>
                <h3 id="doctors" class="display mt-12" style="font-size: 30px; letter-spacing: -0.02em; scroll-margin-top: 140px;">Doctors who work here</h3>
                <ul class="grid gap-4 mt-5" style="grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));">
                  {hospitalDoctors.map((doc: any) => (
                    <li>
                      <a
                        href={localizedPath(locale, `/doctor/${doc.slug}`)}
                        class="paper flex items-start gap-4 transition hover:-translate-y-0.5"
                        style="padding: 18px; box-shadow: var(--shadow-xs);"
                      >
                        <img
                          src={doctorPortrait({ imageUrl: doc.imageUrl, id: doc.id }, 112)}
                          alt={doc.name}
                          width="56"
                          height="56"
                          loading="lazy"
                          decoding="async"
                          class="h-14 w-14 rounded-full object-cover shrink-0"
                        />
                        <div class="min-w-0">
                          <div class="serif" style="font-size: 16px; font-weight: 500;">
                            {doc.title ? `${doc.title} ` : ""}{doc.name}
                          </div>
                          {doc.qualifications && (
                            <div style="font-size: 12px; color: var(--color-ink-subtle); margin-top: 2px;" class="line-clamp-1">{doc.qualifications}</div>
                          )}
                          {doc.experienceYears && (
                            <div class="mono mt-2" style="font-size: 11px; color: var(--color-ink-muted);">{doc.experienceYears}+ yrs experience</div>
                          )}
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            )}
          </div>

          {/* Right sidebar */}
          <aside>
            <div class="paper" style="padding: 20px;">
              <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">Location</div>
              <div class="map-bg mt-3" style="aspect-ratio: 1 / 1; border-radius: var(--radius-md); border: 1px solid var(--color-border);" />
              <div class="mt-3" style="font-size: 13.5px; line-height: 1.5;">
                {hospital.address && <>{hospital.address}<br/></>}
                {cityName}{countryName && `, ${countryName}`}
                {hospital.airportDistanceKm != null && (
                  <><br/><span style="color: var(--color-ink-subtle);">Nearest airport · {hospital.airportDistanceKm} km</span></>
                )}
              </div>
            </div>

            <div class="paper mt-3.5" style="padding: 20px;">
              <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">Get in touch</div>
              <dl class="mt-3 space-y-3 text-sm">
                {hospital.phone && (
                  <div class="flex items-start gap-2.5">
                    <Phone className="h-3.5 w-3.5 mt-1 shrink-0" />
                    <a href={`tel:${hospital.phone}`} class="hover:text-accent">{hospital.phone}</a>
                  </div>
                )}
                {hospital.email && (
                  <div class="flex items-start gap-2.5">
                    <Mail className="h-3.5 w-3.5 mt-1 shrink-0" />
                    <a href={`mailto:${hospital.email}`} class="break-all hover:text-accent">{hospital.email}</a>
                  </div>
                )}
                {hospital.website && (
                  <div class="flex items-start gap-2.5">
                    <Globe className="h-3.5 w-3.5 mt-1 shrink-0" />
                    <a href={hospital.website} target="_blank" rel="noopener noreferrer" class="break-all hover:text-accent">
                      {(() => { try { return new URL(hospital.website).host.replace(/^www\./, ""); } catch { return hospital.website; } })()}
                    </a>
                  </div>
                )}
                {hospital.address && (
                  <div class="flex items-start gap-2.5">
                    <MapPin className="h-3.5 w-3.5 mt-1 shrink-0" />
                    <span style="color: var(--color-ink-muted);">{hospital.address}</span>
                  </div>
                )}
              </dl>
            </div>

            <div class="paper mt-3.5" style="padding: 20px; background: var(--color-ink); color: var(--color-bg);">
              <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; opacity: 0.6; text-transform: uppercase;">Compare</div>
              <div class="serif mt-2" style="font-size: 17px;">Add to comparison</div>
              <div style="font-size: 12.5px; opacity: 0.7; margin-top: 4px;">
                Side-by-side with other {cityName ?? countryName ?? "regional"} hospitals.
              </div>
              <a
                href={localizedPath(locale, `/compare/hospitals?a=${hospital.slug}`)}
                class="inline-flex items-center gap-1 mt-3.5"
                style="padding: 7px 12px; background: transparent; color: var(--color-bg); border: 1px solid rgba(246,241,230,0.3); border-radius: 9999px; font-size: 12.5px; font-weight: 500;"
              >+ Compare</a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    {prices.procedures > 0 && (
      <section
        id="pricing"
        style="padding: 56px 28px; border-top: 1px solid var(--color-border); background: var(--color-paper); scroll-margin-top: 140px;"
      >
        <div class="mx-auto" style="max-width: 1120px;">
          <div class="flex items-end justify-between flex-wrap gap-6 mb-8">
            <div>
              <div class="mono" style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-accent);">Transparent pricing</div>
              <h2 class="display mt-2" style="font-size: 32px; letter-spacing: -0.02em;">
                Across {prices.procedures} procedures,
                <span style="font-style: italic;"> starting ${Math.round(prices.min ?? 0).toLocaleString()}</span>
              </h2>
            </div>
            <a
              href={localizedPath(locale, `/contact?hospital=${hospital.slug}`)}
              class="inline-flex items-center gap-1.5"
              style="background: var(--color-accent); color: #FFF; padding: 10px 18px; font-size: 14px; border-radius: 9999px; font-weight: 500;"
            >
              Request itemized quote
              <ChevronRight className="h-3.5 w-3.5 mirror-x" />
            </a>
          </div>
          <p class="serif" style="font-size: 17px; line-height: 1.55; color: var(--color-ink-muted); max-width: 720px;">
            These ranges include the surgeon fee, anesthesia, standard ward stay, and typical consumables. Complex cases may add ICU days, revisions, or implants; your case manager breaks down the quote line-by-line before you commit.
          </p>
        </div>
      </section>
    )}

    {faqs.length > 0 && (
      <section
        id="faq"
        style="padding: 56px 28px; border-top: 1px solid var(--color-border); scroll-margin-top: 140px;"
      >
        <div class="mx-auto" style="max-width: 1120px;">
          <div class="grid gap-10 lg:grid-cols-[0.35fr,1fr]">
            <div>
              <div class="mono" style="font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-ink-subtle);">FAQ</div>
              <h2 class="display mt-3" style="font-size: 28px; line-height: 1.1; letter-spacing: -0.015em;">
                Common questions about {hospital.name}
              </h2>
            </div>
            <div class="divide-y" style="border-color: var(--color-border-soft);">
              {faqs.map((f) => (
                <details class="group py-5">
                  <summary class="flex cursor-pointer items-start justify-between gap-6">
                    <span class="serif" style="font-size: 17px; font-weight: 500; line-height: 1.4;">{f.question}</span>
                    <span
                      class="mt-1 shrink-0 transition-transform group-open:rotate-45"
                      style="color: var(--color-ink-subtle); font-size: 20px; line-height: 1;"
                      aria-hidden="true"
                    >+</span>
                  </summary>
                  <p class="serif mt-3" style="color: var(--color-ink-muted); font-size: 15.5px; line-height: 1.6;">{f.answer}</p>
                </details>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <section id="contact" style="padding: 72px 28px; border-top: 1px solid var(--color-border); background: var(--color-ink); color: var(--color-bg); scroll-margin-top: 140px;">
      <div class="mx-auto max-w-[1120px]">
        <div class="grid gap-10 lg:grid-cols-[1fr,auto] lg:items-end">
          <div>
            <div class="mono" style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.7;">Ready to plan</div>
            <h2 class="display mt-3" style="font-size: clamp(2rem, 4vw, 2.75rem); line-height: 1.05; letter-spacing: -0.025em; font-weight: 400;">
              Get a written plan for {hospital.name}
              <span style="font-style: italic;"> in 11 minutes.</span>
            </h2>
            <p class="serif mt-4" style="font-size: 17px; line-height: 1.55; max-width: 560px; opacity: 0.85;">
              Share your reports. A named case manager sends back an itemized quote, recommended surgeon, and a 5-day travel plan.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a
              href={localizedPath(locale, `/contact?hospital=${hospital.slug}`)}
              class="inline-flex items-center gap-2 font-semibold"
              style="background: var(--color-accent); color: #FFF; padding: 13px 22px; font-size: 15px; border-radius: 9999px;"
            >
              Request free quote
              <ChevronRight className="h-4 w-4 mirror-x" />
            </a>
            <a
              href={localizedPath(locale, "/second-opinion")}
              class="inline-flex items-center gap-2 font-semibold"
              style="background: transparent; color: var(--color-bg); border: 1px solid rgba(246,241,230,0.3); padding: 13px 22px; font-size: 15px; border-radius: 9999px;"
            >
              Free 2nd opinion
            </a>
          </div>
        </div>
      </div>
    </section>

    {relatedHospitals.length > 0 && (
      <section style="padding: 56px 28px; border-top: 1px solid var(--color-border);">
        <div class="mx-auto max-w-[1120px]">
          <div class="mono mb-2" style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-accent);">Nearby</div>
          <h2 class="display" style="font-size: 28px; letter-spacing: -0.02em;">
            Other hospitals in {cityName ?? "this city"}
          </h2>
          <ul class="grid mt-6 gap-3" style="grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));">
            {relatedHospitals.map((r) => (
              <li>
                <a
                  href={localizedPath(locale, r.href)}
                  class="paper flex items-center justify-between transition hover:-translate-y-0.5"
                  style="padding: 14px 16px;"
                >
                  <span>
                    <span class="serif block" style="font-size: 16px; font-weight: 500;">{r.name}</span>
                    {r.subtitle && <span class="mono block mt-0.5" style="font-size: 10.5px; color: var(--color-ink-subtle);">{r.subtitle}</span>}
                  </span>
                  <ChevronRight className="h-4 w-4 mirror-x" />
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
