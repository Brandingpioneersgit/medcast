---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { getSpecialtyBySlug } from "@/lib/queries";
import {
  getContent,
  getContentBatch,
  applyTranslated,
} from "@/lib/translate";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl, SITE_URL } from "@/lib/seo";
import { ChevronRight } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
const slug = Astro.params.slug;
if (!isLocale(rawLocale)) return Astro.redirect(`/en/specialty/${slug}`, 308);
if (!slug) return new Response("Not found", { status: 404 });

const locale = rawLocale as Locale;
const specialtyRaw = await getSpecialtyBySlug(slug);
if (!specialtyRaw) return new Response(`Not found: ${slug}`, { status: 404 });

const tc = getTranslator(locale, "common");

const specialtyMap = await getContent("specialty", specialtyRaw.id, locale);
const specialty = applyTranslated(specialtyRaw, specialtyMap, ["name", "description"]);

const treatmentIds = (specialtyRaw.treatments ?? []).map((t) => t.id);
const treatmentMap = await getContentBatch("treatment", treatmentIds, locale);
const specialtyTreatments = (specialtyRaw.treatments ?? []).map((t) =>
  applyTranslated(t, treatmentMap[t.id] ?? {}, ["name"]),
);

const seoTitle = specialty.name;
const seoDescription =
  specialty.description?.slice(0, 160) ??
  `${specialty.name} specialty care — ${specialtyTreatments.length} treatments across accredited hospitals worldwide.`;

const path = `/specialty/${slug}`;
const url = localeUrl(locale, path);

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: tc("specialties"), url: localeUrl(locale, "/specialties") },
  { name: specialty.name, url },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <div class="border-b border-border bg-bg">
      <div class="mx-auto max-w-7xl px-6 py-3.5 text-sm text-ink-muted">
        <a href={localizedPath(locale, "/")} class="hover:text-accent">{tc("home")}</a>
        <span class="mx-2 text-ink-subtle">/</span>
        <a href={localizedPath(locale, "/specialties")} class="hover:text-accent">{tc("specialties")}</a>
        <span class="mx-2 text-ink-subtle">/</span>
        <span class="text-ink">{specialty.name}</span>
      </div>
    </div>

    <section class="mx-auto max-w-7xl px-6 pt-10 md:pt-14 pb-10">
      <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink-subtle">
        {tc("specialties")}
      </p>
      <h1 class="mt-2 font-display text-3xl md:text-5xl leading-[1.05]">{specialty.name}</h1>
      {specialty.description && <p class="lede mt-5 max-w-3xl">{specialty.description}</p>}
    </section>

    {specialtyTreatments.length > 0 && (
      <section class="border-t border-border py-12">
        <div class="mx-auto max-w-7xl px-6">
          <h2 class="font-display text-2xl md:text-3xl mb-6">Treatments in {specialty.name}</h2>
          <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {specialtyTreatments.map((t) => (
              <li>
                <a
                  href={localizedPath(locale, `/treatment/${t.slug}`)}
                  class="group flex items-center justify-between rounded-lg border border-border bg-surface p-4 transition-colors hover:border-border-strong"
                >
                  <span class="min-w-0">
                    <span class="block font-medium text-ink group-hover:text-accent transition-colors">{t.name}</span>
                    {t.hospitalStayDays && (
                      <span class="block text-xs text-ink-subtle">{t.hospitalStayDays}d stay · {t.recoveryDays ?? "—"}d recovery</span>
                    )}
                  </span>
                  <ChevronRight className="h-4 w-4 text-ink-subtle mirror-x shrink-0 ml-3" />
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
