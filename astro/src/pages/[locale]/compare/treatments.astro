---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import EntityListingHero from "@/components/EntityListingHero.astro";
import PriceRange from "@/components/PriceRange.astro";
import { compareTreatments } from "@/lib/queries";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { ChevronRight } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect(`/en/compare/treatments`, 308);
const locale = rawLocale as Locale;
const tc = getTranslator(locale, "common");

const rows = await compareTreatments();

const path = "/compare/treatments";
const url = localeUrl(locale, path);

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Compare treatments", url },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);

const specialtyCount = new Set(rows.map((r) => r.specialty).filter(Boolean)).size;
const withPrice = rows.filter((r) => r.lo != null);
const lowestFrom = withPrice.reduce(
  (m, r) => (!m || (Number(r.lo) < m)) ? Number(r.lo) : m,
  null as number | null,
);
const withSuccess = rows.filter((r) => r.success_rate_percent != null);
const avgSuccess = withSuccess.length > 0
  ? withSuccess.reduce((s, r) => s + Number(r.success_rate_percent), 0) / withSuccess.length
  : null;

const stats = [
  { l: "Procedures", v: rows.length.toString() },
  { l: "Specialties", v: specialtyCount.toString() },
  lowestFrom ? { l: "From", v: `$${(lowestFrom / 1000).toFixed(1)}k` } : null,
  avgSuccess ? { l: "Avg success", v: `${avgSuccess.toFixed(0)}%` } : null,
].filter(Boolean) as Array<{ l: string; v: string }>;

function successTone(pct: number | null): string {
  if (pct == null) return "color: var(--color-ink-subtle);";
  if (pct >= 90) return "color: var(--color-accent);";
  if (pct >= 75) return "color: var(--color-saffron);";
  return "color: var(--color-coral);";
}
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title="Compare Medical Treatments"
      description="Side-by-side comparison of surgical treatments: cost ranges, hospital stay, recovery time, success rate, and hospital coverage across 9 countries."
      path={path}
      locale={locale}
    />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <div style="background: var(--color-paper); border-bottom: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8 py-4">
        <nav class="mono text-[12px]" style="color: var(--color-ink-subtle);" aria-label="Breadcrumb">
          <a href={localizedPath(locale, "/")} class="hover:text-ink">{tc("home")}</a>
          <span class="mx-1.5">/</span>
          <span style="color: var(--color-ink);">Compare treatments</span>
        </nav>
      </div>
    </div>

    <EntityListingHero
      eyebrow={`Compare · ${rows.length} procedures`}
      h1First="Treatments"
      h1Italic="side-by-side"
      lede={`Cost, stay, recovery, and success-rate data for ${rows.length} surgical treatments, aggregated across partner hospitals. Open any row for the full page.`}
      stats={stats}
    />

    <section style="padding: 32px 0 88px;">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8">
        <div class="paper overflow-x-auto" style="padding: 0;">
          <table class="w-full" style="border-collapse: collapse;">
            <thead>
              <tr style="border-bottom: 1px solid var(--color-ink);">
                <th class="text-start mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); padding: 16px 20px; font-weight: normal;">Treatment</th>
                <th class="text-start mono uppercase whitespace-nowrap" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); padding: 16px 20px; font-weight: normal;">Specialty</th>
                <th class="text-start mono uppercase whitespace-nowrap" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); padding: 16px 20px; font-weight: normal;">Price range</th>
                <th class="text-start mono uppercase whitespace-nowrap" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); padding: 16px 20px; font-weight: normal;">Stay</th>
                <th class="text-start mono uppercase whitespace-nowrap" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); padding: 16px 20px; font-weight: normal;">Recovery</th>
                <th class="text-start mono uppercase whitespace-nowrap" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); padding: 16px 20px; font-weight: normal;">Success</th>
                <th class="text-start mono uppercase whitespace-nowrap" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); padding: 16px 20px; font-weight: normal;">Hospitals</th>
                <th style="padding: 16px 20px;"></th>
              </tr>
            </thead>
            <tbody>
              {rows.map((r, i) => (
                <tr
                  class="group"
                  style={`${i > 0 ? "border-top: 1px dashed var(--color-border);" : ""}`}
                >
                  <td style="padding: 16px 20px;">
                    <a
                      href={localizedPath(locale, `/treatment/${r.slug}`)}
                      class="serif group-hover:text-accent transition-colors"
                      style="font-size: 16px; letter-spacing: -0.005em; color: var(--color-ink);"
                    >
                      {r.name}
                    </a>
                  </td>
                  <td class="mono uppercase whitespace-nowrap" style="font-size: 10.5px; letter-spacing: 0.1em; color: var(--color-ink-muted); padding: 16px 20px;">
                    {r.specialty ?? "—"}
                  </td>
                  <td class="whitespace-nowrap" style="padding: 16px 20px;">
                    {r.lo ? (
                      <span class="display tnum" style="font-size: 15px; color: var(--color-ink);">
                        <PriceRange min={r.lo} max={r.hi} />
                      </span>
                    ) : (
                      <span style="color: var(--color-ink-subtle);">—</span>
                    )}
                  </td>
                  <td class="tnum whitespace-nowrap" style="font-size: 13.5px; color: var(--color-ink-muted); padding: 16px 20px;">
                    {r.hospital_stay_days ? `${r.hospital_stay_days}d` : "—"}
                  </td>
                  <td class="tnum whitespace-nowrap" style="font-size: 13.5px; color: var(--color-ink-muted); padding: 16px 20px;">
                    {r.recovery_days ? `${r.recovery_days}d` : "—"}
                  </td>
                  <td class="whitespace-nowrap" style="padding: 16px 20px;">
                    {r.success_rate_percent != null ? (
                      <span class="display tnum" style={`font-size: 14px; ${successTone(Number(r.success_rate_percent))}`}>
                        {Number(r.success_rate_percent).toFixed(0)}%
                      </span>
                    ) : (
                      <span style="color: var(--color-ink-subtle);">—</span>
                    )}
                  </td>
                  <td class="tnum whitespace-nowrap" style="font-size: 13.5px; color: var(--color-ink-muted); padding: 16px 20px;">
                    {r.hospital_count.toLocaleString()}
                  </td>
                  <td style="padding: 16px 20px; text-align: end;">
                    <a
                      href={localizedPath(locale, `/treatment/${r.slug}`)}
                      class="inline-flex items-center gap-1 mono uppercase"
                      style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle);"
                    >
                      Open
                      <ChevronRight className="h-3 w-3 mirror-x" />
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p class="mt-4 mono uppercase" style="font-size: 10.5px; letter-spacing: 0.12em; color: var(--color-ink-subtle);">
          USD · Aggregated from partner hospital quote sheets · Excludes flights + hotel
        </p>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
