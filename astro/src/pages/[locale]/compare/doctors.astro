---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { getDoctorsForCompare } from "@/lib/queries";
import { getContentBatch, applyTranslated } from "@/lib/translate";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { getTranslator } from "@/lib/messages";
import { doctorPortrait } from "@/lib/images";
import { ChevronRight, X } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect("/en/compare/doctors", 308);
const locale = rawLocale as Locale;

const url = new URL(Astro.request.url);
const idsParam = url.searchParams.get("ids") ?? "";
const slugs = idsParam.split(",").map((s) => s.trim()).filter(Boolean).slice(0, 4);

const doctorsRaw = slugs.length > 0 ? await getDoctorsForCompare(slugs) : [];
const tMap = doctorsRaw.length > 0
  ? await getContentBatch("doctor", doctorsRaw.map((d) => d.id), locale)
  : {};
const docs = doctorsRaw.map((d) => ({
  ...d,
  ...applyTranslated({ name: d.name, title: d.title, qualifications: d.qualifications }, tMap[d.id] ?? {}, [
    "name", "title", "qualifications",
  ]),
}));

function parseLanguages(raw: unknown): string[] {
  if (Array.isArray(raw)) return raw.filter((x): x is string => typeof x === "string");
  if (typeof raw === "string") {
    try {
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed.filter((x): x is string => typeof x === "string") : [];
    } catch { return []; }
  }
  return [];
}

const tc = getTranslator(locale, "common");

const seoTitle = docs.length > 0
  ? `Compare ${docs.map((d) => d.name).join(" vs ")}`
  : "Compare doctors side-by-side";
const seoDescription = docs.length > 0
  ? `Side-by-side comparison of ${docs.length} doctors — experience, patients treated, consultation fees, and specialties.`
  : "Shortlist up to 4 doctors and compare experience, volume, specialties, and consultation fees side-by-side.";
const path = "/compare/doctors";

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: tc("doctors"), url: localeUrl(locale, "/doctors") },
  { name: "Compare", url: localeUrl(locale, path) },
]);

Astro.response.headers.set("Cache-Control", "private, no-store");

type Row = { key: string; label: string; render: (d: (typeof docs)[number]) => string };
const rows: Row[] = [
  { key: "hospital", label: "Practices at",
    render: (d) => d.hospital ? `${d.hospital.name} · ${d.hospital.cityName ?? ""}` : "—" },
  { key: "experience", label: "Years practising",
    render: (d) => d.experienceYears ? `${d.experienceYears}+ years` : "—" },
  { key: "patients", label: "Patients treated",
    render: (d) => d.patientsTreated
      ? d.patientsTreated > 1000 ? `${Math.floor(d.patientsTreated / 1000)}k+` : d.patientsTreated.toLocaleString()
      : "—" },
  { key: "rating", label: "Rating",
    render: (d) => d.rating && Number(d.rating) > 0
      ? `★ ${Number(d.rating).toFixed(1)}${d.reviewCount ? ` (${d.reviewCount.toLocaleString()})` : ""}`
      : "—" },
  { key: "qualifications", label: "Qualifications",
    render: (d) => d.qualifications ?? "—" },
  { key: "specialties", label: "Specialties",
    render: (d) => d.specialties.length > 0 ? d.specialties.map((s) => s.name).join(", ") : "—" },
  { key: "expertise", label: "Expertise",
    render: (d) => d.expertise.length > 0 ? d.expertise.slice(0, 5).join(", ") : "—" },
  { key: "languages", label: "Languages",
    render: (d) => parseLanguages(d.languagesSpoken).join(", ") || "—" },
  { key: "fee", label: "Consultation fee",
    render: (d) => d.consultationFeeUsd != null ? `$${d.consultationFeeUsd}` : "On request" },
  { key: "video", label: "Video consult",
    render: (d) => d.availableForVideoConsult ? "Available" : "—" },
];

function removeHref(slug: string) {
  const remaining = slugs.filter((s) => s !== slug);
  const qs = remaining.length > 0 ? `?ids=${remaining.join(",")}` : "";
  return localizedPath(locale, `${path}${qs}`);
}
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} noindex />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh" style="background: var(--color-bg); color: var(--color-ink);">
    <SiteHeader locale={locale} />

    <div style="padding: 18px 28px; border-bottom: 1px solid var(--color-border-soft); background: var(--color-paper);">
      <nav class="mono mx-auto max-w-[1440px]" style="font-size: 12px; color: var(--color-ink-subtle);" aria-label="Breadcrumb">
        <a href={localizedPath(locale, "/doctors")} class="hover:text-ink">{tc("doctors")}</a>
        <span class="mx-1.5">/</span>
        <span style="color: var(--color-ink);">Compare</span>
      </nav>
    </div>

    <section style="padding: 48px 28px;">
      <div class="mx-auto max-w-[1440px]">
        <div class="mono" style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-accent);">
          Comparison basket
        </div>
        <h1
          class="display display-tight mt-3"
          style="font-size: clamp(2rem, 4.5vw, 3rem); line-height: 1; font-weight: 400; letter-spacing: -0.03em;"
        >
          Doctors side-by-side
        </h1>
        <p class="serif mt-4" style="font-size: 17px; line-height: 1.5; color: var(--color-ink-muted); max-width: 680px;">
          Shortlist 2–4 surgeons. We surface experience, patient volume, specialties, and consultation fees in one view.
        </p>

        {docs.length === 0 ? (
          <div class="paper mt-8" style="padding: 40px; text-align: center;">
            <div class="serif" style="font-size: 22px;">No doctors selected yet</div>
            <p class="mt-3" style="font-size: 14px; color: var(--color-ink-muted);">
              Browse the <a href={localizedPath(locale, "/doctors")} class="underline">doctor directory</a> or specialty pages, use the Compare chip on each profile, then return here.
            </p>
            <a
              href={localizedPath(locale, "/doctors")}
              class="inline-flex items-center gap-2 mt-6 font-semibold"
              style="background: var(--color-accent); color: #FFF; padding: 12px 20px; font-size: 14px; border-radius: 9999px;"
            >
              Browse doctors <ChevronRight className="h-3.5 w-3.5 mirror-x" />
            </a>
          </div>
        ) : (
          <div class="mt-8 overflow-x-auto">
            <table class="w-full" style="border-collapse: separate; border-spacing: 0; min-width: 760px;">
              {/* Header row with doctor cards */}
              <thead>
                <tr>
                  <th scope="col" style="width: 180px; text-align: start; padding: 20px 20px 20px 0;">
                    <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">
                      Attribute
                    </div>
                  </th>
                  {docs.map((d) => (
                    <th scope="col" style="padding: 0 10px; text-align: start; vertical-align: top; min-width: 220px;">
                      <div class="paper" style="padding: 18px; position: relative;">
                        <a
                          href={removeHref(d.slug)}
                          class="absolute"
                          style="top: 10px; inset-inline-end: 10px; color: var(--color-ink-subtle);"
                          aria-label={`Remove ${d.name}`}
                        >
                          <X className="h-4 w-4" />
                        </a>
                        <div class="flex items-start gap-3">
                          <img
                            src={doctorPortrait({ imageUrl: d.imageUrl, id: d.id }, 96)}
                            alt={d.name}
                            width="48"
                            height="48"
                            loading="lazy"
                            decoding="async"
                            class="h-12 w-12 rounded-full object-cover shrink-0"
                          />
                          <div class="min-w-0 flex-1 pr-4">
                            <a
                              href={localizedPath(locale, `/doctor/${d.slug}`)}
                              class="serif font-medium hover:text-accent block"
                              style="font-size: 15px; letter-spacing: -0.005em; line-height: 1.25;"
                            >
                              {d.title ? `${d.title} ` : "Dr. "}{d.name}
                            </a>
                            {d.specialties[0] && (
                              <div class="mono mt-1" style="font-size: 10px; color: var(--color-ink-subtle); letter-spacing: 0.08em;">
                                {d.specialties[0].name}
                              </div>
                            )}
                          </div>
                        </div>
                      </div>
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {rows.map((row, rowIdx) => (
                  <tr>
                    <th
                      scope="row"
                      class="mono"
                      style={`text-align: start; padding: 14px 20px 14px 0; font-size: 11px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase; font-weight: 500; ${rowIdx > 0 ? "border-top: 1px solid var(--color-border-soft);" : ""}`}
                    >
                      {row.label}
                    </th>
                    {docs.map((d) => (
                      <td
                        style={`padding: 14px 10px; vertical-align: top; font-size: 13.5px; line-height: 1.5; color: var(--color-ink); ${rowIdx > 0 ? "border-top: 1px solid var(--color-border-soft);" : ""}`}
                      >
                        {row.render(d)}
                      </td>
                    ))}
                  </tr>
                ))}
                {/* CTA row */}
                <tr>
                  <td style="padding: 22px 20px 10px 0;"></td>
                  {docs.map((d) => (
                    <td style="padding: 22px 10px 10px;">
                      <a
                        href={localizedPath(locale, `/contact?doctor=${d.slug}`)}
                        class="inline-flex items-center gap-1 font-semibold"
                        style="background: var(--color-ink); color: var(--color-bg); padding: 8px 14px; font-size: 12.5px; border-radius: 9999px;"
                      >
                        Book → <ChevronRight className="h-3 w-3 mirror-x" />
                      </a>
                    </td>
                  ))}
                </tr>
              </tbody>
            </table>
          </div>
        )}

        <div class="mt-10 p-6" style="background: var(--color-accent-mist); border: 1px solid var(--color-accent-soft); border-radius: var(--radius-lg); max-width: 720px;">
          <div class="mono" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase;">
            How we recommend choosing
          </div>
          <p class="serif mt-2" style="font-size: 15.5px; line-height: 1.55; color: var(--color-ink);">
            Volume beats credentials. A surgeon doing 200+ cases/year of your specific procedure outperforms one doing 30, regardless of titles. Combine volume + rating + expertise match. Consultation fees are often a poor proxy — surgeon volume and hospital program depth matter more.
          </p>
        </div>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
