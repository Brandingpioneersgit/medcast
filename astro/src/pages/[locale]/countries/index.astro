---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { isLocale, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { getTranslator } from "@/lib/messages";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect("/en/countries", 308);
const locale = rawLocale as Locale;

const tc = getTranslator(locale, "common");
const seoTitle = "Medical tourism destinations";
const seoDescription = "Compare top medical tourism destinations — hospitals, doctors, costs, and visa info per country.";
const path = "/countries";

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Destinations", url: localeUrl(locale, path) },
]);

Astro.response.headers.set("Cache-Control", "public, s-maxage=600, stale-while-revalidate=3600");
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />
    <section class="mx-auto max-w-7xl px-6 pt-10 pb-16">
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-ink-subtle">Compare</p>
      <h1 class="mt-2 font-display text-3xl md:text-5xl leading-[1.05]">Destinations</h1>
      <p class="lede mt-4">Discover countries leading in medical tourism — quality, cost, and accessibility.</p>
      {/* TODO: country cards grid */}
    </section>
    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
