---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import LastUpdated from "@/components/LastUpdated.astro";
import Price from "@/components/Price.astro";
import PriceRange from "@/components/PriceRange.astro";
import { getCostOfTreatment } from "@/lib/queries";
import {
  getContent,
  applyTranslated,
} from "@/lib/translate";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl, treatmentJsonLd, withProvenance } from "@/lib/seo";
import { ChevronRight, Check, X } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
const slug = Astro.params.slug;
if (!isLocale(rawLocale)) return Astro.redirect(`/en/cost/${slug}`, 308);
if (!slug) return new Response("Not found", { status: 404 });

const locale = rawLocale as Locale;
const data = await getCostOfTreatment(slug);
if (!data) return new Response(`Not found: ${slug}`, { status: 404 });

const tc = getTranslator(locale, "common");

const treatmentMap = await getContent("treatment", data.treatment.id, locale);
const treatment = applyTranslated(data.treatment, treatmentMap, ["name", "description"]);

const cheapest = data.byCountry[0];
const mostExpensive = data.byCountry[data.byCountry.length - 1];

const specialty = data.treatment.specialty
  ? applyTranslated(
      data.treatment.specialty,
      await getContent("specialty", data.treatment.specialty.id, locale),
      ["name"],
    )
  : null;

const totalHospitals = data.byCountry.reduce((s, c) => s + c.hospital_count, 0);
const loPrice = cheapest?.lo ? Number(cheapest.lo) : null;
const hiPrice = mostExpensive?.hi ? Number(mostExpensive.hi) : null;
const maxCountryLo = data.byCountry.reduce((m, c) => Math.max(m, Number(c.lo ?? 0)), 0);
// Approximate US-reference savings. US cost ≈ 2.2× highest sampled destination hi (rough heuristic).
const usRef = hiPrice ? hiPrice * 2.2 : null;
const savingsPct = usRef && loPrice ? Math.round((1 - loPrice / usRef) * 100) : null;

const FLAG_MAP: Record<string, string> = {
  india: "🇮🇳", turkey: "🇹🇷", thailand: "🇹🇭", uae: "🇦🇪",
  germany: "🇩🇪", singapore: "🇸🇬", "south-korea": "🇰🇷",
  malaysia: "🇲🇾", "saudi-arabia": "🇸🇦",
};
function countryFlag(s: string): string { return FLAG_MAP[s] ?? "🌐"; }
function firstWord(s: string) { const i = s.indexOf(" "); return i === -1 ? s : s.slice(0, i); }
function restOfName(s: string) { const i = s.indexOf(" "); return i === -1 ? "" : s.slice(i + 1); }

const currentYear = new Date().getFullYear();

const stats = [
  loPrice ? { l: "Starts from", v: `$${(loPrice / 1000).toFixed(1)}k` } : null,
  hiPrice ? { l: "Tops out", v: `$${(hiPrice / 1000).toFixed(1)}k` } : null,
  { l: "Destinations", v: data.byCountry.length.toString() },
  { l: "Hospitals priced", v: totalHospitals.toLocaleString() },
].filter(Boolean) as Array<{ l: string; v: string }>;

const COST_FACTORS = [
  { title: "Surgeon seniority", body: "Senior consultants with 20+ years and high procedure counts command 20-40% above junior attendings for the same operation." },
  { title: "Hospital tier", body: "Flagship JCI-accredited facilities cost more than local tier-2 hospitals, even for identical procedures. The gap is usually 30-60%." },
  { title: "Room category", body: "Private-room vs twin-share vs deluxe suite can shift total package cost by 10-25% on longer admissions." },
  { title: "Implant or device brand", body: "For joint replacement, cardiac valves, or dental implants, the device brand alone can change the bill by $1,500-$4,000." },
  { title: "Length of stay", body: "Complications or unplanned ICU days are the biggest variance driver. Ask for the per-diem overage rate upfront." },
  { title: "Pre-op workup", body: "Imaging and labs done overseas aren't always re-done locally. If they are, budget 8-15% extra." },
];

const INCLUDED = [
  "Surgery + anaesthesia fees",
  "Standard private or twin-share room",
  "Standard implants / consumables",
  "Routine post-op imaging and labs",
  "Discharge medications for the admission period",
  "Case coordinator during admission",
];
const NOT_INCLUDED = [
  "International flights + visa fees",
  "Hotel before admission / after discharge",
  "Complications or extended ICU days",
  "Premium implants (e.g. branded heart valves)",
  "Long-term medications",
  "Follow-up teleconsults after the first 30 days",
];

const FAQS = [
  { question: `Is ${treatment.name.toLowerCase()} safe in these countries?`, answer: `Yes — at JCI-accredited facilities. The variable isn't country; it's surgeon and hospital. Ask for surgeon-specific procedure volume (aim for 100+ per year for elective work) before booking.` },
  { question: `How long do I need to stay?`, answer: treatment.hospitalStayDays ? `${treatment.hospitalStayDays} inpatient days is typical${treatment.recoveryDays ? `, plus ~${treatment.recoveryDays} days local recovery before you're cleared to fly.` : "."} Build in a few buffer days in case labs or imaging flag something.` : "Stay length varies by case. Plan around the typical inpatient window plus 3-7 recovery days before your flight home." },
  { question: `Does my insurance cover treatment abroad?`, answer: `Some international policies (Cigna, Bupa, Allianz, AXA) reimburse at overseas JCI hospitals. Most domestic insurance doesn't. We confirm cashless vs reimbursement before admission — share your policy and we'll verify.` },
  { question: `What's included in the package price?`, answer: `Typically: surgery fee, anaesthesia, standard room, standard implants, routine post-op imaging. Not typically included: airport transfer, hotel, complications, premium implants, extended ICU days. Quotes always show the split.` },
  { question: `How do I choose between countries?`, answer: `For routine procedures, go on price + your visa ease. For complex cases, go on surgeon-specific volume and outcome data — which we request from each hospital before presenting quotes.` },
  { question: `Can I travel home right after?`, answer: `Commercial air travel post-surgery depends on the procedure and the airline's medical-clearance policy. Most cardiac patients fly 10-14 days post-op; orthopedic patients 7-10 days; cosmetic 5-7 days. Your case manager will flag the specifics.` },
];

const currentYearStr = currentYear.toString();
const seoTitle = cheapest && loPrice
  ? `${treatment.name} Cost Abroad: $${Math.round(loPrice).toLocaleString()}+ (${currentYearStr})`
  : `${treatment.name} Cost`;
const seoDescription = cheapest && loPrice
  ? `${treatment.name} costs from $${Math.round(loPrice).toLocaleString()} in ${cheapest.country_name}. Compare ${data.byCountry.length} destinations, ${totalHospitals.toLocaleString()} hospitals. Updated ${currentYearStr}.`.slice(0, 160)
  : `${treatment.name} cost comparison across international medical destinations. Updated ${currentYearStr}.`;

const path = `/cost/${slug}`;
const url = localeUrl(locale, path);

const jsonLd = withProvenance(
  treatmentJsonLd({
    name: `${treatment.name} Cost`,
    description: treatment.description,
    costMinUsd: cheapest?.lo ?? undefined,
    costMaxUsd: mostExpensive?.hi ?? undefined,
    url,
    hospitalStayDays: treatment.hospitalStayDays,
    successRatePercent: treatment.successRatePercent ? Number(treatment.successRatePercent) : null,
  }),
  { dateModified: data.treatment.updatedAt, dateCreated: data.treatment.createdAt },
);

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: FAQS.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
};

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: tc("treatments"), url: localeUrl(locale, "/treatments") },
  { name: `${treatment.name} Cost`, url },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <div style="background: var(--color-paper); border-bottom: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8 py-4">
        <nav class="mono text-[12px]" style="color: var(--color-ink-subtle);" aria-label="Breadcrumb">
          <a href={localizedPath(locale, "/")} class="hover:text-ink">{tc("home")}</a>
          <span class="mx-1.5">/</span>
          <a href={localizedPath(locale, `/treatment/${slug}`)} class="hover:text-ink">{treatment.name}</a>
          <span class="mx-1.5">/</span>
          <span style="color: var(--color-ink);">Cost</span>
        </nav>
      </div>
    </div>

    <section class="pt-12 md:pt-16">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8">
        {specialty && (
          <p class="mono uppercase" style="font-size: 11px; letter-spacing: 0.14em; color: var(--color-accent);">
            {specialty.name} · Updated {currentYearStr}
          </p>
        )}
        <div class="grid gap-10 lg:grid-cols-[1.5fr,1fr] lg:gap-14 mt-3">
          <div>
            <h1
              class="display display-tight"
              style="font-size: clamp(2.25rem, 5vw, 4.5rem); line-height: 0.98; font-weight: 400; letter-spacing: -0.03em;"
            >
              Cost of <span class="italic-display">{firstWord(treatment.name)}{restOfName(treatment.name) ? ` ${restOfName(treatment.name)}` : ""}</span> abroad
            </h1>
            {cheapest && loPrice ? (
              <p class="serif mt-5 max-w-[44rem]" style="font-size: 19px; line-height: 1.5; color: var(--color-ink-muted);">
                Starts at <span class="display tnum" style="color: var(--color-ink);"><Price usd={loPrice} /></span> in {cheapest.country_name}. {data.byCountry.length} destinations, {totalHospitals.toLocaleString()} hospital packages tracked. Bands below reflect what's quoted — final amounts shift on surgeon choice, room, and stay length.
              </p>
            ) : (
              <p class="serif mt-5 max-w-[44rem]" style="font-size: 19px; line-height: 1.5; color: var(--color-ink-muted);">
                No hospital pricing is in our system yet for this procedure. Request a quote and we'll source three from our partner network within 48 hours.
              </p>
            )}
            <LastUpdated updated={data.treatment.updatedAt} locale={locale} class="mt-5" />

            {stats.length > 0 && (
              <div
                class="mt-8 grid grid-cols-2 sm:grid-cols-4"
                style="border-top: 1px solid var(--color-ink); border-bottom: 1px solid var(--color-border);"
              >
                {stats.map((s, i) => (
                  <div
                    class="px-4 md:px-5 py-5"
                    style={i > 0 ? "border-inline-start: 1px solid var(--color-border);" : ""}
                  >
                    <div class="mono uppercase" style="font-size: 9.5px; letter-spacing: 0.1em; color: var(--color-ink-subtle);">
                      {s.l}
                    </div>
                    <div class="display tnum mt-1.5" style="font-size: 28px;">{s.v}</div>
                  </div>
                ))}
              </div>
            )}

            {savingsPct && savingsPct > 0 && (
              <p class="mt-5 mono text-[11px] uppercase" style="letter-spacing: 0.12em; color: var(--color-accent);">
                Up to {savingsPct}% savings vs US average for this procedure
              </p>
            )}
          </div>

          <aside class="lg:sticky lg:top-32 lg:self-start">
            <div class="paper" style="padding: 22px;">
              <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle);">
                Free quote · 48 hours
              </div>
              <div class="display mt-2" style="font-size: 26px; line-height: 1.1; letter-spacing: -0.015em;">
                Three itemised options, <span class="italic-display">matched to you.</span>
              </div>
              <ul class="mt-4 space-y-2.5 text-[13.5px]" style="color: var(--color-ink-muted);">
                <li class="flex gap-2"><span style="color: var(--color-accent);">→</span><span>Share imaging + case history</span></li>
                <li class="flex gap-2"><span style="color: var(--color-accent);">→</span><span>We route to 3 surgeons matching your case</span></li>
                <li class="flex gap-2"><span style="color: var(--color-accent);">→</span><span>Itemised quotes in 48 hours, no fee</span></li>
              </ul>
              <a
                href={localizedPath(locale, `/contact?treatment=${slug}`)}
                class="mt-5 block w-full text-center font-semibold"
                style="background: var(--color-ink); color: var(--color-bg); padding: 12px; border-radius: 9999px;"
              >
                Request quotes
              </a>
              <a
                href={localizedPath(locale, `/treatment/${slug}`)}
                class="mt-2.5 block w-full text-center font-semibold"
                style="border: 1px solid var(--color-border); color: var(--color-ink); padding: 11px; border-radius: 9999px;"
              >
                See hospitals ranked
              </a>
            </div>
            <p class="mt-3 mono text-[10px] uppercase tracking-wider text-center" style="color: var(--color-ink-subtle);">
              Coordinators online · avg reply 9 min
            </p>
          </aside>
        </div>
      </div>
    </section>

    {/* Country pricing ranked list */}
    {data.byCountry.length > 0 && (
      <section style="padding: 72px 0; border-top: 1px solid var(--color-border-soft); margin-top: 56px;">
        <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
          <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
            <div>
              <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                01 · Country breakdown
              </div>
              <h2 class="display mt-3" style="font-size: 32px; letter-spacing: -0.02em;">
                {firstWord(treatment.name)} cost, ranked by destination
              </h2>
            </div>
          </div>

          <div class="paper overflow-hidden" style="padding: 0;">
            {data.byCountry.map((c, i) => {
              const widthPct = maxCountryLo > 0 ? Math.max(14, ((Number(c.lo ?? 0)) / maxCountryLo) * 100) : 50;
              return (
                <a
                  href={localizedPath(locale, `/treatment/${slug}/${c.country_slug}`)}
                  class="grid items-center gap-4 p-5 md:p-6 hover:bg-[var(--color-paper)] transition-colors"
                  style={`grid-template-columns: 36px 28px 1.2fr 1.5fr 1fr auto; ${i > 0 ? "border-top: 1px solid var(--color-border-soft);" : ""}`}
                >
                  <div class="display tnum" style="font-size: 22px; color: var(--color-ink-subtle);">
                    {String(i + 1).padStart(2, "0")}
                  </div>
                  <span aria-hidden="true" style="font-size: 22px;">{countryFlag(c.country_slug)}</span>
                  <div class="min-w-0">
                    <div class="serif" style="font-size: 17px; letter-spacing: -0.005em; color: var(--color-ink);">{c.country_name}</div>
                    <div class="mono text-[10.5px] uppercase tracking-wider mt-0.5" style="color: var(--color-ink-subtle);">
                      {c.hospital_count} hospitals
                    </div>
                  </div>
                  <div>
                    <div class="h-1 rounded-full" style={`background: var(--color-accent); opacity: 0.85; width: ${widthPct}%;`} />
                  </div>
                  <div class="display tnum" style="font-size: 17px; color: var(--color-ink);">
                    <PriceRange min={c.lo ?? "0"} max={c.hi} />
                  </div>
                  <ChevronRight className="h-4 w-4 mirror-x text-[var(--color-ink-subtle)]" />
                </a>
              );
            })}
          </div>
          <p class="mt-4 mono text-[10.5px] uppercase tracking-wider" style="color: var(--color-ink-subtle);">
            USD · Excludes flights, hotel, follow-up imaging after discharge
          </p>
        </div>
      </section>
    )}

    {/* What affects the cost */}
    <section style="padding: 72px 0; border-top: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="mb-8">
          <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
            02 · What moves the price
          </div>
          <h2 class="display mt-3" style="font-size: 32px; letter-spacing: -0.02em;">
            Six levers that shift the quote
          </h2>
          <p class="serif mt-3 max-w-[48rem]" style="font-size: 16px; line-height: 1.55; color: var(--color-ink-muted);">
            Two quotes from the same hospital can differ by 40% once you drill into the details below. Ask your case manager to break out each line.
          </p>
        </div>
        <ul class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {COST_FACTORS.map((f, i) => (
            <li class="paper" style="padding: 22px;">
              <div class="mono tnum" style="font-size: 11px; letter-spacing: 0.1em; color: var(--color-ink-subtle);">
                {String(i + 1).padStart(2, "0")}
              </div>
              <div class="serif mt-2" style="font-size: 18px; line-height: 1.25; letter-spacing: -0.005em; color: var(--color-ink);">
                {f.title}
              </div>
              <p class="mt-2 serif" style="font-size: 14.5px; line-height: 1.55; color: var(--color-ink-muted);">
                {f.body}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    {/* Inclusions / exclusions */}
    <section style="padding: 72px 0; border-top: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="mb-8">
          <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
            03 · What's in the package
          </div>
          <h2 class="display mt-3" style="font-size: 32px; letter-spacing: -0.02em;">
            Included, and what isn't
          </h2>
        </div>
        <div class="grid md:grid-cols-2 gap-5">
          <div class="paper" style="padding: 26px 28px;">
            <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-accent);">
              Usually included
            </div>
            <ul class="mt-4 space-y-3">
              {INCLUDED.map((line) => (
                <li class="flex items-start gap-2.5 serif" style="font-size: 15px; line-height: 1.5; color: var(--color-ink);">
                  <Check className="h-4 w-4 mt-1 shrink-0" style={{color: "var(--color-accent)"}} />
                  <span>{line}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="paper" style="padding: 26px 28px;">
            <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-coral);">
              Usually extra
            </div>
            <ul class="mt-4 space-y-3">
              {NOT_INCLUDED.map((line) => (
                <li class="flex items-start gap-2.5 serif" style="font-size: 15px; line-height: 1.5; color: var(--color-ink);">
                  <X className="h-4 w-4 mt-1 shrink-0" style={{color: "var(--color-coral)"}} />
                  <span>{line}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section style="padding: 64px 0; border-top: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.35fr,1fr]">
          <div>
            <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
              04 · FAQ
            </div>
            <h2 class="display mt-3" style="font-size: 28px; line-height: 1.1; letter-spacing: -0.015em;">
              Questions that come up a lot
            </h2>
          </div>
          <div class="divide-y divide-[var(--color-border-soft)]">
            {FAQS.map((f) => (
              <details class="group py-5">
                <summary class="flex cursor-pointer items-start justify-between gap-6 list-none" style="color: var(--color-ink);">
                  <span class="serif" style="font-size: 18px; line-height: 1.4; font-weight: 500;">{f.question}</span>
                  <span class="mt-1 shrink-0 transition-transform group-open:rotate-45" style="color: var(--color-ink-subtle); font-size: 20px; line-height: 1;" aria-hidden="true">+</span>
                </summary>
                <p class="mt-3 serif" style="color: var(--color-ink-muted); font-size: 16px; line-height: 1.6;">{f.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* Dark CTA */}
    <section style="background: var(--color-ink); color: var(--color-bg); padding: 72px 0;">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="grid gap-8 lg:grid-cols-[1.5fr,1fr] items-end">
          <div>
            <div class="mono uppercase" style="font-size: 11px; letter-spacing: 0.16em; color: rgba(246,241,230,0.55);">
              Need a number tied to your case
            </div>
            <h2 class="display mt-3" style="font-size: clamp(2rem, 4vw, 3.25rem); line-height: 1.02; letter-spacing: -0.02em; color: var(--color-bg);">
              Three itemised <span class="italic-display">{firstWord(treatment.name)}</span> quotes in 48 hours.
            </h2>
            <p class="serif mt-4 max-w-[42rem]" style="font-size: 17px; line-height: 1.5; color: rgba(246,241,230,0.75);">
              Share recent imaging and reports. Within 48 hours we come back with 3 line-itemised quotes from hospitals matching your budget and timing. No fee, no obligation.
            </p>
          </div>
          <div class="flex flex-wrap gap-3 lg:justify-end">
            <a
              href={localizedPath(locale, `/contact?treatment=${slug}`)}
              class="inline-flex items-center gap-2 font-semibold"
              style="background: var(--color-bg); color: var(--color-ink); padding: 14px 22px; border-radius: 9999px;"
            >
              Request quotes
              <ChevronRight className="h-4 w-4 mirror-x" />
            </a>
            <a
              href={localizedPath(locale, "/calculator")}
              class="inline-flex items-center gap-2 font-semibold"
              style="border: 1px solid rgba(246,241,230,0.35); color: var(--color-bg); padding: 13px 22px; border-radius: 9999px;"
            >
              Open price calculator
            </a>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
