---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { TrendingUp, Globe, Users, ChevronRight, CheckCircle2 } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect(`/en/for-hospitals`, 308);
const locale = rawLocale as Locale;
const tc = getTranslator(locale, "common");

const path = "/for-hospitals";
const url = localeUrl(locale, path);

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "For Hospitals", url },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=86400, stale-while-revalidate=604800",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title="MedCasts for Hospitals — Partnership Program"
      description="Pre-qualified international leads, 8-language patient communication, visa + travel handled, commission only on admission. No retainer, no ad spend."
      path={path}
      locale={locale}
    />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <section class="mx-auto max-w-7xl px-6 pt-12 md:pt-20 pb-12">
      <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-accent">For hospitals</p>
      <h1 class="mt-4 font-display text-4xl md:text-6xl leading-[1.02] max-w-3xl">
        Another ad won't fill your international beds. This might.
      </h1>
      <p class="lede mt-6 max-w-2xl">
        Patients reach your IPD coordinator with reports, budget, and visa paperwork already done. You bill on admission, not on a lead. If the patient doesn't fly, we don't bill — so we pre-qualify hard on our side, not yours.
      </p>
    </section>

    <section class="border-t border-border bg-surface-muted py-12">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="font-display text-2xl md:text-3xl mb-8">What partner hospitals get</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div class="rounded-xl border border-border bg-surface p-6">
            <TrendingUp className="h-6 w-6 text-accent" />
            <h3 class="mt-4 font-display text-lg">Pre-qualified leads</h3>
            <p class="mt-2 text-sm text-ink-muted">
              Only patients with a real diagnosis, budget, and travel intent reach your IPD desk.
              Average lead → admission conversion: 34%.
            </p>
          </div>
          <div class="rounded-xl border border-border bg-surface p-6">
            <Globe className="h-6 w-6 text-accent" />
            <h3 class="mt-4 font-display text-lg">8-language front desk</h3>
            <p class="mt-2 text-sm text-ink-muted">
              Arabic, Russian, French, Portuguese, Bengali, Turkish, Hindi, English — we handle patient communication in-language, not your staff.
            </p>
          </div>
          <div class="rounded-xl border border-border bg-surface p-6">
            <Users className="h-6 w-6 text-accent" />
            <h3 class="mt-4 font-display text-lg">End-to-end patient coordination</h3>
            <p class="mt-2 text-sm text-ink-muted">
              Visa, airport transfer, hotel, post-op follow-up — handled by our case managers. Your team sees a ready-to-admit patient.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-border py-12">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="font-display text-2xl md:text-3xl mb-8">How the partnership works</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {[
            { step: "01", title: "Hospital onboarding", body: "We collect specialties, pricing ranges, doctor profiles, accreditations, and capacity constraints. Your profile goes live in 7 days." },
            { step: "02", title: "Lead routing", body: "Patients who match your specialties and pricing bracket are routed to you within 6 hours of inquiry. You receive full case files, imaging, and budget." },
            { step: "03", title: "Quote + acceptance", body: "You return an itemized quote via the hospital portal. We present it to the patient in their language. Acceptance triggers travel booking." },
            { step: "04", title: "Admission + care", body: "Patient arrives with all paperwork pre-done. Your team delivers care. We handle check-ins, translation, post-op follow-up, and insurance claims." },
            { step: "05", title: "Commission settled", body: "Transparent fee billed monthly per successful admission. No success, no fee. Standard rate: 10-15% depending on specialty and volume." },
            { step: "06", title: "Performance review", body: "Monthly dashboard shows lead quality, conversion, patient NPS, and reimbursement timing. Quarterly strategy review with your IPD head." },
          ].map((c) => (
            <div class="rounded-xl border border-border bg-surface p-6">
              <p class="font-display text-2xl text-accent">{c.step}</p>
              <h3 class="mt-3 font-display text-lg">{c.title}</h3>
              <p class="mt-2 text-sm text-ink-muted">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-border bg-surface-muted py-12">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="font-display text-2xl md:text-3xl mb-8">What qualifies a hospital</h2>
        <ul class="space-y-3 max-w-3xl">
          {[
            "JCI, NABH, or equivalent national accreditation",
            "Active international patient department with dedicated coordinator",
            "Published pricing for at least 10 core treatments in our catalog",
            "Digital records (DICOM imaging, PDF reports exportable)",
            "Responsive quote turnaround (24-48h typical)",
            "Transparent inclusion / exclusion line items",
          ].map((q) => (
            <li class="flex items-start gap-3">
              <CheckCircle2 className="h-5 w-5 text-accent shrink-0 mt-0.5" />
              <span class="text-ink-muted">{q}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="border-t border-border py-12">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-display text-2xl md:text-3xl mb-3">
          Ready to explore partnership?
        </h2>
        <p class="text-ink-muted mb-6">
          30-min intro call with our growth team. No commitment — we share market data for your destination + specialties first.
        </p>
        <a
          href={localizedPath(locale, "/contact?type=partnership")}
          class="inline-flex items-center gap-2 rounded-lg bg-accent text-white font-semibold px-6 py-3 hover:bg-accent-hover transition"
        >
          Request an intro call
          <ChevronRight className="h-4 w-4 mirror-x" />
        </a>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
