---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl, faqJsonLd } from "@/lib/seo";
import { Shield, CheckCircle2, AlertTriangle, ChevronRight, FileText } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect(`/en/insurance`, 308);
const locale = rawLocale as Locale;
const tc = getTranslator(locale, "common");

const path = "/insurance";
const url = localeUrl(locale, path);

const partners = [
  { name: "Cigna Global", accepted: true, cashless: true, note: "Pre-authorization required for planned surgeries" },
  { name: "Bupa International", accepted: true, cashless: true, note: "Direct billing for Tier-1 network hospitals" },
  { name: "Allianz Worldwide Care", accepted: true, cashless: "partial", note: "Cashless for select India / Thailand partners" },
  { name: "AXA — Global Healthcare", accepted: true, cashless: "partial", note: "Reimbursement model for most facilities" },
  { name: "Aetna International", accepted: true, cashless: true, note: "Pre-auth via PPO network" },
  { name: "IMG (International Medical Group)", accepted: true, cashless: false, note: "Patient pays, we help claim" },
  { name: "GeoBlue / Blue Cross Blue Shield", accepted: true, cashless: "partial", note: "Direct pay at JCI-accredited partners" },
  { name: "WellAway", accepted: true, cashless: false, note: "Reimbursement model" },
];

const faqs = [
  { question: "Can I use my international insurance at MedCasts partner hospitals?", answer: "Yes — we work with 20+ international insurers. Cashless settlement depends on the insurer and destination hospital; we handle pre-authorization paperwork on your behalf." },
  { question: "What if my policy requires reimbursement rather than cashless?", answer: "We provide all itemized invoices, discharge summaries, diagnostic reports, and claim-ready documentation in English within 5 business days of discharge." },
  { question: "Does overseas medical tourism affect my premium?", answer: "No. MedCasts pricing is typically 60-80% below US / UK standards, so insurers often encourage overseas treatment for planned procedures." },
  { question: "What isn't covered by standard international policies?", answer: "Cosmetic procedures, fertility treatment, and experimental therapies are usually out-of-pocket. Dental is covered only with dental add-ons. We flag these upfront in your quote." },
];

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Insurance", url },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=86400, stale-while-revalidate=604800",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title="International Health Insurance — Cashless + Reimbursement Support"
      description="Cigna, Bupa, Allianz, AXA, Aetna, BCBS — 20+ international insurers processed. Pre-auth handled, claim-ready paperwork, single claims manager per case."
      path={path}
      locale={locale}
    />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd(faqs))} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <section class="mx-auto max-w-7xl px-6 pt-12 md:pt-20 pb-12">
      <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-accent">Insurance</p>
      <h1 class="mt-4 font-display text-4xl md:text-5xl leading-[1.05]">
        Your international policy probably works here.
      </h1>
      <p class="lede mt-5 max-w-3xl">
        Whether your insurer pays the hospital directly (cashless) or reimburses you after discharge depends on the policy and the destination. We confirm which applies to your case before you fly — so the surprise doesn't come at the billing desk.
      </p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-5 max-w-4xl">
        <div class="rounded-xl border border-border bg-surface p-5">
          <Shield className="h-5 w-5 text-accent" />
          <p class="mt-3 font-medium">Pre-authorization handled</p>
          <p class="mt-1 text-sm text-ink-muted">We coordinate with your insurer before admission.</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-5">
          <FileText className="h-5 w-5 text-accent" />
          <p class="mt-3 font-medium">Claim-ready documentation</p>
          <p class="mt-1 text-sm text-ink-muted">Itemized invoices, discharge summaries, reports — all in English.</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-5">
          <CheckCircle2 className="h-5 w-5 text-accent" />
          <p class="mt-3 font-medium">Dedicated claims manager</p>
          <p class="mt-1 text-sm text-ink-muted">Single point of contact from admission to settlement.</p>
        </div>
      </div>
    </section>

    <section class="border-t border-border bg-surface-muted py-12">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="font-display text-2xl md:text-3xl mb-2">Insurers we work with</h2>
        <p class="text-sm text-ink-muted mb-8">Cashless coverage depends on your policy + destination hospital. We confirm before admission.</p>
        <div class="rounded-xl border border-border bg-surface overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-surface-muted border-b border-border">
              <tr>
                <th class="text-start px-5 py-3 font-medium">Insurer</th>
                <th class="text-start px-5 py-3 font-medium">Cashless</th>
                <th class="text-start px-5 py-3 font-medium">Note</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              {partners.map((p) => (
                <tr>
                  <td class="px-5 py-4 font-medium">{p.name}</td>
                  <td class="px-5 py-4">
                    {p.cashless === true && <span class="inline-flex items-center gap-1.5 text-accent"><CheckCircle2 className="h-4 w-4" /> Yes</span>}
                    {p.cashless === "partial" && <span class="inline-flex items-center gap-1.5 text-ink-muted"><CheckCircle2 className="h-4 w-4" /> Partial</span>}
                    {p.cashless === false && <span class="inline-flex items-center gap-1.5 text-ink-subtle"><AlertTriangle className="h-4 w-4" /> Reimburse</span>}
                  </td>
                  <td class="px-5 py-4 text-ink-muted">{p.note}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="mt-5 text-xs text-ink-subtle">
          Don't see your insurer? Contact us — new partnerships added monthly.
        </p>
      </div>
    </section>

    <section class="border-t border-border py-12">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="font-display text-2xl md:text-3xl mb-8">Insurance FAQ</h2>
        <div class="space-y-2">
          {faqs.map((f) => (
            <details class="group rounded-lg border border-border bg-surface p-5">
              <summary class="cursor-pointer font-medium text-ink list-none flex items-center justify-between">
                {f.question}
                <ChevronRight className="h-4 w-4 text-ink-subtle transition-transform group-open:rotate-90 mirror-x" />
              </summary>
              <p class="mt-3 text-ink-muted text-sm">{f.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-border bg-surface-muted py-12">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-display text-2xl md:text-3xl mb-3">Verify my coverage</h2>
        <p class="text-ink-muted mb-6">
          Share your policy card + a treatment estimate. We'll confirm cashless eligibility within 24 hours.
        </p>
        <a
          href={localizedPath(locale, "/contact?type=insurance")}
          class="inline-flex items-center gap-2 rounded-lg bg-accent text-white font-semibold px-6 py-3 hover:bg-accent-hover transition"
        >
          Check my policy
          <ChevronRight className="h-4 w-4 mirror-x" />
        </a>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
