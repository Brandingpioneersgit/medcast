---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import EntityListingHero from "@/components/EntityListingHero.astro";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl, faqJsonLd } from "@/lib/seo";
import { ChevronRight, Check } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect(`/en/insurance`, 308);
const locale = rawLocale as Locale;
const tc = getTranslator(locale, "common");

const path = "/insurance";
const url = localeUrl(locale, path);

const partners = [
  { name: "Cigna Global", cashless: "yes" as const, note: "Pre-authorization required for planned surgeries" },
  { name: "Bupa International", cashless: "yes" as const, note: "Direct billing for Tier-1 network hospitals" },
  { name: "Allianz Worldwide Care", cashless: "partial" as const, note: "Cashless for select India / Thailand partners" },
  { name: "AXA — Global Healthcare", cashless: "partial" as const, note: "Reimbursement model for most facilities" },
  { name: "Aetna International", cashless: "yes" as const, note: "Pre-auth via PPO network" },
  { name: "IMG (International Medical Group)", cashless: "reimburse" as const, note: "Patient pays, we help claim" },
  { name: "GeoBlue / Blue Cross Blue Shield", cashless: "partial" as const, note: "Direct pay at JCI-accredited partners" },
  { name: "WellAway", cashless: "reimburse" as const, note: "Reimbursement model" },
];

const faqs = [
  { question: "Can I use my international insurance at MedCasts partner hospitals?", answer: "Yes — we work with 20+ international insurers. Cashless settlement depends on the insurer and destination hospital; we handle pre-authorization paperwork on your behalf." },
  { question: "What if my policy requires reimbursement rather than cashless?", answer: "We provide all itemised invoices, discharge summaries, diagnostic reports, and claim-ready documentation in English within 5 business days of discharge." },
  { question: "Does overseas medical tourism affect my premium?", answer: "No. MedCasts pricing is typically 60-80% below US / UK standards, so insurers often encourage overseas treatment for planned procedures." },
  { question: "What isn't covered by standard international policies?", answer: "Cosmetic procedures, fertility treatment, and experimental therapies are usually out-of-pocket. Dental is covered only with dental add-ons. We flag these upfront in your quote." },
];

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Insurance", url },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=86400, stale-while-revalidate=604800",
);

const stats = [
  { l: "Insurers", v: `${partners.length}+` },
  { l: "Cashless coverage", v: "On eligible policies" },
  { l: "Pre-auth SLA", v: "24 h" },
  { l: "Claim docs", v: "English PDF" },
];
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title="International Health Insurance — Cashless + Reimbursement Support"
      description="Cigna, Bupa, Allianz, AXA, Aetna, BCBS — 20+ international insurers processed. Pre-auth handled, claim-ready paperwork, single claims manager per case."
      path={path}
      locale={locale}
    />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd(faqs))} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <div style="background: var(--color-paper); border-bottom: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[90rem] px-5 md:px-8 py-4">
        <nav class="mono text-[12px]" style="color: var(--color-ink-subtle);" aria-label="Breadcrumb">
          <a href={localizedPath(locale, "/")} class="hover:text-ink">{tc("home")}</a>
          <span class="mx-1.5">/</span>
          <span style="color: var(--color-ink);">Insurance</span>
        </nav>
      </div>
    </div>

    <EntityListingHero
      eyebrow="Insurance · International policies"
      h1First="Your policy"
      h1Italic="probably works here."
      lede="Whether your insurer pays the hospital directly (cashless) or reimburses you after discharge depends on the policy and destination. We confirm which applies to your case before you fly — so the surprise doesn't come at the billing desk."
      stats={stats}
    />

    <section style="padding: 72px 0; border-top: 1px solid var(--color-border-soft); margin-top: 24px;">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
          <div>
            <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
              01 · Insurers we work with
            </div>
            <h2 class="display mt-3" style="font-size: 32px; letter-spacing: -0.02em;">
              Coverage, <span class="italic-display">by policy.</span>
            </h2>
          </div>
          <p class="mono uppercase max-w-[24rem]" style="font-size: 10.5px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-align: end;">
            Cashless eligibility depends on policy + destination · We confirm before admission
          </p>
        </div>

        <div class="paper overflow-x-auto" style="padding: 0;">
          <table class="w-full" style="border-collapse: collapse;">
            <thead>
              <tr style="border-bottom: 1px solid var(--color-ink);">
                <th class="text-start mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); padding: 16px 20px; font-weight: normal;">Insurer</th>
                <th class="text-start mono uppercase whitespace-nowrap" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); padding: 16px 20px; font-weight: normal;">Settlement</th>
                <th class="text-start mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle); padding: 16px 20px; font-weight: normal;">Notes</th>
              </tr>
            </thead>
            <tbody>
              {partners.map((p, i) => {
                const tone = p.cashless === "yes" ? "var(--color-accent)" : p.cashless === "partial" ? "var(--color-saffron)" : "var(--color-ink-muted)";
                const label = p.cashless === "yes" ? "Cashless" : p.cashless === "partial" ? "Partial cashless" : "Reimburse";
                return (
                  <tr style={i > 0 ? "border-top: 1px dashed var(--color-border);" : ""}>
                    <td class="serif" style="font-size: 16px; letter-spacing: -0.005em; color: var(--color-ink); padding: 16px 20px;">
                      {p.name}
                    </td>
                    <td style="padding: 16px 20px;">
                      <span
                        class="mono uppercase inline-flex items-center gap-1.5"
                        style={`font-size: 9.5px; letter-spacing: 0.14em; padding: 4px 10px; border-radius: 9999px; border: 1px solid color-mix(in srgb, ${tone} 50%, transparent); color: ${tone}; background: color-mix(in srgb, ${tone} 12%, transparent);`}
                      >
                        <span class="h-1.5 w-1.5 rounded-full" style={`background: ${tone};`} aria-hidden="true" />
                        {label}
                      </span>
                    </td>
                    <td class="serif" style="font-size: 14px; line-height: 1.5; color: var(--color-ink-muted); padding: 16px 20px;">
                      {p.note}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>

        <p class="mt-4 mono uppercase" style="font-size: 10.5px; letter-spacing: 0.12em; color: var(--color-ink-subtle);">
          Don't see your insurer · Email us, new partnerships added monthly
        </p>
      </div>
    </section>

    <section style="padding: 72px 0; border-top: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="mb-8">
          <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
            02 · Claims support
          </div>
          <h2 class="display mt-3" style="font-size: 32px; letter-spacing: -0.02em;">
            What we handle, <span class="italic-display">end-to-end.</span>
          </h2>
        </div>
        <ul class="grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { eyebrow: "01", t: "Pre-authorization", d: "We coordinate with your insurer before admission — pre-auth letters, medical necessity justification, cost estimates." },
            { eyebrow: "02", t: "Claim-ready docs", d: "Itemised invoices, discharge summaries, imaging reports, diagnostic tests — all in English PDF, within 5 business days." },
            { eyebrow: "03", t: "Dedicated manager", d: "One named person from admission to settlement. They follow up with your insurer on reimbursement delays." },
          ].map((x) => (
            <li class="paper" style="padding: 26px 28px;">
              <div class="display tnum" style="font-size: 40px; line-height: 0.95; color: var(--color-accent); letter-spacing: -0.02em;">{x.eyebrow}</div>
              <div class="serif mt-3" style="font-size: 19px; line-height: 1.25; letter-spacing: -0.005em; color: var(--color-ink);">{x.t}</div>
              <p class="mt-2 serif" style="font-size: 14.5px; line-height: 1.55; color: var(--color-ink-muted);">{x.d}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section style="padding: 64px 0; border-top: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.35fr,1fr]">
          <div>
            <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
              03 · FAQ
            </div>
            <h2 class="display mt-3" style="font-size: 28px; line-height: 1.1; letter-spacing: -0.015em;">
              Insurance questions, answered
            </h2>
          </div>
          <div class="divide-y divide-[var(--color-border-soft)]">
            {faqs.map((f) => (
              <details class="group py-5">
                <summary class="flex cursor-pointer items-start justify-between gap-6 list-none" style="color: var(--color-ink);">
                  <span class="serif" style="font-size: 18px; line-height: 1.4; font-weight: 500;">{f.question}</span>
                  <span class="mt-1 shrink-0 transition-transform group-open:rotate-45" style="color: var(--color-ink-subtle); font-size: 20px; line-height: 1;" aria-hidden="true">+</span>
                </summary>
                <p class="mt-3 serif" style="color: var(--color-ink-muted); font-size: 16px; line-height: 1.6;">{f.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section style="background: var(--color-ink); color: var(--color-bg); padding: 72px 0;">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="grid gap-8 lg:grid-cols-[1.5fr,1fr] items-end">
          <div>
            <div class="mono uppercase" style="font-size: 11px; letter-spacing: 0.16em; color: rgba(246,241,230,0.55);">
              Confirm coverage
            </div>
            <h2 class="display mt-3" style="font-size: clamp(2rem, 4vw, 3.25rem); line-height: 1.02; letter-spacing: -0.02em; color: var(--color-bg);">
              Share your policy card. <span class="italic-display">We confirm in 24 hours.</span>
            </h2>
          </div>
          <div class="flex flex-wrap gap-3 lg:justify-end">
            <a
              href={localizedPath(locale, "/contact?type=insurance")}
              class="inline-flex items-center gap-2 font-semibold"
              style="background: var(--color-bg); color: var(--color-ink); padding: 14px 22px; border-radius: 9999px;"
            >
              Check my policy
              <ChevronRight className="h-4 w-4 mirror-x" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
