---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { db } from "@/lib/db";
import { hospitals, cities, countries } from "../../../../src/lib/db/schema";
import { and, desc, eq, sql } from "drizzle-orm";
import { isLocale, type Locale, localizedPath } from "@/lib/i18n";
import { hospitalCover } from "@/lib/images";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect("/en", 308);
const locale = rawLocale as Locale;

type Row = {
  id: number;
  name: string;
  slug: string;
  coverImageUrl: string | null;
  rating: string | null;
  reviewCount: number | null;
  bedCapacity: number | null;
  cityName: string | null;
  countryName: string | null;
  countrySlug: string | null;
};

let featured: Row[] = [];
let totalHospitals = 0;
let totalCountries = 0;
let dbError: string | null = null;

try {
  featured = await db
    .select({
      id: hospitals.id,
      name: hospitals.name,
      slug: hospitals.slug,
      coverImageUrl: hospitals.coverImageUrl,
      rating: hospitals.rating,
      reviewCount: hospitals.reviewCount,
      bedCapacity: hospitals.bedCapacity,
      cityName: cities.name,
      countryName: countries.name,
      countrySlug: countries.slug,
    })
    .from(hospitals)
    .innerJoin(cities, eq(hospitals.cityId, cities.id))
    .innerJoin(countries, eq(cities.countryId, countries.id))
    .where(and(eq(hospitals.isActive, true), eq(hospitals.isFeatured, true)))
    .orderBy(desc(hospitals.rating), desc(hospitals.reviewCount))
    .limit(8);

  const counts = await db.execute<{ hospitals: number; countries: number }>(sql`
    SELECT
      (SELECT COUNT(*)::int FROM hospitals WHERE is_active = true) AS hospitals,
      (SELECT COUNT(*)::int FROM countries WHERE is_destination = true) AS countries
  `);
  const row = Array.from(counts)[0];
  totalHospitals = row?.hospitals ?? 0;
  totalCountries = row?.countries ?? 0;
} catch (err) {
  dbError = err instanceof Error ? err.message : String(err);
}
---

<BaseLayout
  title="MedCasts — Planned medical treatment abroad, coordinated end-to-end"
  description="Second opinions, surgical packages, and full-travel coordination across 9,000+ accredited hospitals. Book on price and fit, not on a brochure."
  locale={locale}
>
  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <section class="mx-auto max-w-7xl px-6 py-20">
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-accent">
        For patients travelling across borders for care
      </p>
      <h1 class="mt-4 font-display text-[2.5rem] md:text-[4rem] leading-[1.05] tracking-[-0.02em]">
        Treatment abroad, <span class="italic text-ink-muted">without the brochure-speak.</span>
      </h1>
      <p class="lede mt-5">
        Searching
        <span class="text-ink">{totalHospitals > 0 ? totalHospitals.toLocaleString() : "—"} accredited hospitals</span>
        in {totalCountries > 0 ? totalCountries : "—"} countries.
      </p>

      {dbError && (
        <div class="mt-8 rounded-lg border border-danger bg-danger-soft p-4 text-sm text-danger">
          <strong>DB error:</strong> {dbError}
          <p class="mt-1 text-xs opacity-80">
            Ensure <code>astro/.env.local</code> exists (symlink from repo root works).
          </p>
        </div>
      )}
    </section>

    <section class="mx-auto max-w-7xl px-6 pb-24">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-ink-subtle">
            Top-rated hospitals
          </p>
          <h2 class="mt-2 font-display text-3xl">Hand-picked, continuously vetted.</h2>
        </div>
        <a
          href={localizedPath(locale, "/hospitals")}
          class="text-sm text-accent hover:text-accent-hover"
        >
          All hospitals →
        </a>
      </div>

      {featured.length === 0 ? (
        <p class="text-ink-muted">No featured hospitals found.</p>
      ) : (
        <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {featured.map((h) => (
            <li>
              <a
                href={localizedPath(locale, `/hospital/${h.slug}`)}
                class="group block h-full overflow-hidden rounded-2xl border border-border bg-surface transition hover:-translate-y-0.5 hover:border-border-strong hover:shadow-md"
              >
                <div class="relative aspect-[4/3] overflow-hidden bg-subtle">
                  <img
                    src={hospitalCover({ coverImageUrl: h.coverImageUrl })}
                    alt={h.name}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                  {h.rating && Number(h.rating) > 0 && (
                    <div class="absolute left-3 top-3 rounded-full bg-surface/95 px-2 py-1 text-[11px] font-semibold text-ink backdrop-blur">
                      ★ {Number(h.rating).toFixed(1)}
                    </div>
                  )}
                </div>
                <div class="p-5">
                  <p class="text-xs text-ink-subtle uppercase tracking-wider">
                    {h.cityName}, {h.countryName}
                  </p>
                  <h3 class="mt-1 font-display text-lg leading-snug text-ink group-hover:text-accent transition-colors">
                    {h.name}
                  </h3>
                  <div class="mt-3 flex gap-3 text-xs text-ink-muted">
                    {h.bedCapacity && <span>{h.bedCapacity.toLocaleString()} beds</span>}
                    {h.reviewCount && h.reviewCount > 0 && (
                      <span>{h.reviewCount.toLocaleString()} reviews</span>
                    )}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
