---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { getTranslator } from "@/lib/messages";
import { ChevronRight } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect("/en/portal", 308);
const locale = rawLocale as Locale;
const tc = getTranslator(locale, "common");

const url = new URL(Astro.request.url);
const codeAttempt = url.searchParams.get("code")?.trim();
let redirectUrl: string | null = null;
if (codeAttempt && /^[A-Z0-9-]{6,24}$/i.test(codeAttempt)) {
  redirectUrl = localizedPath(locale, `/portal/${codeAttempt.toUpperCase()}`);
}

const seoTitle = "Patient portal — track your case";
const seoDescription = "Look up your case by the 10-character tracking code your coordinator sent. See journey stage, upcoming appointments, and messages.";
const path = "/portal";

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Patient portal", url: localeUrl(locale, path) },
]);

if (redirectUrl) return Astro.redirect(redirectUrl, 303);

Astro.response.headers.set("Cache-Control", "private, no-store");
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} noindex />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh" style="background: var(--color-bg); color: var(--color-ink);">
    <SiteHeader locale={locale} />

    <div style="padding: 18px 28px; border-bottom: 1px solid var(--color-border-soft); background: var(--color-paper);">
      <nav class="mono mx-auto max-w-[1440px]" style="font-size: 12px; color: var(--color-ink-subtle);" aria-label="Breadcrumb">
        <a href={localizedPath(locale, "/")} class="hover:text-ink">{tc("home")}</a>
        <span class="mx-1.5">/</span>
        <span style="color: var(--color-ink);">Patient portal</span>
      </nav>
    </div>

    <section style="padding: 64px 28px;">
      <div class="mx-auto" style="max-width: 540px;">
        <div class="mono" style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-accent); text-align: center;">Case lookup</div>
        <h1 class="display display-tight mt-3 text-center" style="font-size: clamp(2rem, 4.5vw, 3rem); line-height: 1; font-weight: 400; letter-spacing: -0.03em;">
          Enter your <span class="italic-display">tracking code</span>
        </h1>
        <p class="serif mt-5 text-center" style="font-size: 17px; line-height: 1.5; color: var(--color-ink-muted);">
          Your coordinator sent a 10-character code by email and WhatsApp when your case opened. Enter it below to see stage, appointments, and messages.
        </p>

        <form method="get" class="paper mt-8" style="padding: 24px; box-shadow: var(--shadow-md);">
          <label class="block">
            <span class="mono block mb-2" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle); text-transform: uppercase;">Tracking code</span>
            <input
              name="code"
              placeholder="MC-A1B2C3D4"
              required
              pattern="[A-Za-z0-9\-]{6,24}"
              class="w-full"
              style="padding: 14px 16px; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface-elevated); font-size: 17px; color: var(--color-ink); font-family: var(--font-mono); letter-spacing: 0.05em; text-transform: uppercase;"
              autofocus
            />
          </label>
          <button
            type="submit"
            class="inline-flex items-center justify-center gap-2 w-full mt-4 font-semibold"
            style="background: var(--color-ink); color: var(--color-bg); padding: 14px 22px; font-size: 15px; border-radius: 9999px;"
          >
            Look up my case <ChevronRight className="h-3.5 w-3.5 mirror-x" />
          </button>
        </form>

        <div class="mt-6 text-center" style="font-size: 13.5px; color: var(--color-ink-muted);">
          Lost your code?
          <a href={localizedPath(locale, "/contact?topic=code-recovery")} class="underline" style="color: var(--color-accent);">Ask your coordinator</a>
        </div>
      </div>
    </section>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
