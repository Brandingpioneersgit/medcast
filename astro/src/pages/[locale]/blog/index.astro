---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import Pagination from "@/components/Pagination.astro";
import { listBlogPosts } from "@/lib/queries";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { ChevronRight, Calendar } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
if (!isLocale(rawLocale)) return Astro.redirect(`/en/blog`, 308);
const locale = rawLocale as Locale;
const tc = getTranslator(locale, "common");

const url = new URL(Astro.request.url);
const page = Number(url.searchParams.get("page") ?? 1);

const { rows, total, totalPages } = await listBlogPosts({ page });

const path = "/blog";
const canonicalUrl = localeUrl(locale, path);

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Blog", url: canonicalUrl },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=600, stale-while-revalidate=3600",
);

function fmtDate(d: Date | null): string {
  if (!d) return "";
  try {
    return new Date(d).toLocaleDateString(locale, { year: "numeric", month: "short", day: "numeric" });
  } catch {
    return new Date(d).toISOString().slice(0, 10);
  }
}
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta
      title="Medical Travel Blog"
      description="Patient stories, treatment guides, and destination research for international medical travel. Written by our case-management and clinical teams."
      path={path}
      locale={locale}
    />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <section class="mx-auto max-w-7xl px-6 pt-12 md:pt-16 pb-6">
      <h1 class="font-display text-3xl md:text-5xl leading-[1.05]">Medical travel blog</h1>
      <p class="lede mt-4 max-w-3xl">
        Patient stories, treatment guides, and destination research — written by our case-management and clinical teams.
      </p>
    </section>

    {rows.length === 0 ? (
      <section class="mx-auto max-w-7xl px-6 py-20 text-center">
        <p class="text-ink-muted">New posts coming soon. Check back next week.</p>
      </section>
    ) : (
      <section class="mx-auto max-w-7xl px-6 py-10">
        <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {rows.map((p) => (
            <li>
              <a
                href={localizedPath(locale, `/blog/${p.slug}`)}
                class="group flex flex-col h-full rounded-xl border border-border bg-surface overflow-hidden transition hover:border-border-strong hover:shadow-sm"
              >
                {p.coverImageUrl ? (
                  <img src={p.coverImageUrl} alt={p.title} class="h-48 w-full object-cover" loading="lazy" />
                ) : (
                  <div class="h-48 w-full bg-accent-soft" />
                )}
                <div class="p-5 flex-1 flex flex-col">
                  {p.category && (
                    <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-accent">
                      {p.category}
                    </p>
                  )}
                  <h2 class="mt-2 font-display text-lg text-ink group-hover:text-accent transition-colors">
                    {p.title}
                  </h2>
                  {p.excerpt && (
                    <p class="mt-3 text-sm text-ink-muted line-clamp-3 flex-1">{p.excerpt}</p>
                  )}
                  <div class="mt-4 flex items-center justify-between text-xs text-ink-subtle">
                    <span class="inline-flex items-center gap-1.5">
                      <Calendar className="h-3 w-3" />
                      {fmtDate(p.publishedAt)}
                    </span>
                    {p.authorName && <span>{p.authorName}</span>}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>

        {totalPages > 1 && (
          <div class="mt-10">
            <Pagination page={page} totalPages={totalPages} basePath={localizedPath(locale, "/blog")} />
          </div>
        )}
      </section>
    )}

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
