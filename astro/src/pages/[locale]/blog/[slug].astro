---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { getBlogPostBySlug } from "@/lib/queries";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl } from "@/lib/seo";
import { Calendar, ChevronRight, User } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
const slug = Astro.params.slug;
if (!isLocale(rawLocale)) return Astro.redirect(`/en/blog/${slug}`, 308);
if (!slug) return new Response("Not found", { status: 404 });

const locale = rawLocale as Locale;
const data = await getBlogPostBySlug(slug);
if (!data) return new Response(`Not found: ${slug}`, { status: 404 });

const tc = getTranslator(locale, "common");
const { post, related } = data;

const seoTitle = post.metaTitle ?? post.title;
const seoDescription = post.metaDescription ?? post.excerpt ?? post.title;

const path = `/blog/${slug}`;
const url = localeUrl(locale, path);

function fmtDate(d: Date | null): string {
  if (!d) return "";
  try {
    return new Date(d).toLocaleDateString(locale, { year: "numeric", month: "long", day: "numeric" });
  } catch {
    return new Date(d).toISOString().slice(0, 10);
  }
}

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description: seoDescription,
  image: post.coverImageUrl,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt,
  author: post.authorName
    ? { "@type": "Person", name: post.authorName }
    : { "@type": "Organization", name: "MedCasts" },
  publisher: {
    "@type": "Organization",
    name: "MedCasts",
    logo: { "@type": "ImageObject", url: `${localeUrl(locale, "/")}logo.svg` },
  },
  mainEntityOfPage: url,
};

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Blog", url: localeUrl(locale, "/blog") },
  { name: post.title, url },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} />
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <div class="border-b border-border bg-bg">
      <div class="mx-auto max-w-4xl px-6 py-3.5 text-sm text-ink-muted">
        <a href={localizedPath(locale, "/")} class="hover:text-accent">{tc("home")}</a>
        <span class="mx-2 text-ink-subtle">/</span>
        <a href={localizedPath(locale, "/blog")} class="hover:text-accent">Blog</a>
      </div>
    </div>

    <article class="mx-auto max-w-3xl px-6 py-12">
      {post.category && (
        <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-accent">{post.category}</p>
      )}
      <h1 class="mt-3 font-display text-3xl md:text-5xl leading-[1.1]">{post.title}</h1>
      {post.excerpt && (
        <p class="lede mt-5">{post.excerpt}</p>
      )}
      <div class="mt-8 flex flex-wrap gap-5 text-sm text-ink-muted">
        {post.authorName && (
          <span class="inline-flex items-center gap-1.5">
            <User className="h-4 w-4" />
            {post.authorName}
          </span>
        )}
        {post.publishedAt && (
          <span class="inline-flex items-center gap-1.5">
            <Calendar className="h-4 w-4" />
            {fmtDate(post.publishedAt)}
          </span>
        )}
      </div>

      {post.coverImageUrl && (
        <img src={post.coverImageUrl} alt={post.title} class="mt-10 rounded-xl w-full" loading="lazy" />
      )}

      <div class="prose prose-editorial mt-10" set:html={post.content} />
    </article>

    {related.length > 0 && (
      <section class="border-t border-border bg-surface-muted py-12">
        <div class="mx-auto max-w-5xl px-6">
          <h2 class="font-display text-2xl mb-6">Related reading</h2>
          <ul class="grid grid-cols-1 md:grid-cols-3 gap-5">
            {related.map((r) => (
              <li>
                <a
                  href={localizedPath(locale, `/blog/${r.slug}`)}
                  class="group flex flex-col h-full rounded-xl border border-border bg-surface overflow-hidden transition hover:border-border-strong"
                >
                  {r.coverImageUrl ? (
                    <img src={r.coverImageUrl} alt={r.title} class="h-32 w-full object-cover" loading="lazy" />
                  ) : (
                    <div class="h-32 w-full bg-accent-soft" />
                  )}
                  <div class="p-4 flex-1">
                    <p class="font-medium text-ink group-hover:text-accent transition-colors line-clamp-2">{r.title}</p>
                    {r.excerpt && (
                      <p class="mt-2 text-sm text-ink-muted line-clamp-2">{r.excerpt}</p>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
