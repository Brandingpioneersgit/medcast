---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeadMeta from "@/components/HeadMeta.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import PhotoBlock from "@/components/PhotoBlock.astro";
import { getBlogPostBySlug, listLinkableEntities } from "@/lib/queries";
import { linkifyBlogHtml } from "@/lib/content-linker";
import { getTranslator } from "@/lib/messages";
import { isLocale, localizedPath, type Locale } from "@/lib/i18n";
import { breadcrumbJsonLd, localeUrl, SITE_URL } from "@/lib/seo";
import { Calendar, ChevronRight, User } from "lucide-react";

export const prerender = false;

const rawLocale = Astro.params.locale ?? "en";
const slug = Astro.params.slug;
if (!isLocale(rawLocale)) return Astro.redirect(`/en/blog/${slug}`, 308);
if (!slug) return new Response("Not found", { status: 404 });

const locale = rawLocale as Locale;
const data = await getBlogPostBySlug(slug);
if (!data) return new Response(`Not found: ${slug}`, { status: 404 });

const tc = getTranslator(locale, "common");
const { post, related } = data;

const linkables = await listLinkableEntities().catch(() => []);
const { html: linkedHtml, linked: mentioned } = linkifyBlogHtml(
  post.content ?? "",
  linkables,
  (p) => localizedPath(locale, p),
);
const groupedMentions = {
  treatment: mentioned.filter((e) => e.kind === "treatment"),
  hospital: mentioned.filter((e) => e.kind === "hospital"),
  specialty: mentioned.filter((e) => e.kind === "specialty"),
  condition: mentioned.filter((e) => e.kind === "condition"),
  glossary: mentioned.filter((e) => e.kind === "glossary"),
};
const mentionGroupLabels: Record<string, string> = {
  treatment: "Treatments",
  hospital: "Hospitals",
  specialty: "Specialties",
  condition: "Conditions",
  glossary: "Glossary",
};
const mentionKindOrder: Array<keyof typeof groupedMentions> = [
  "treatment",
  "hospital",
  "specialty",
  "condition",
  "glossary",
];

const seoTitle = post.metaTitle ?? post.title;
const seoDescription = post.metaDescription ?? post.excerpt ?? post.title;

const path = `/blog/${slug}`;
const url = localeUrl(locale, path);

function fmtDate(d: Date | null): string {
  if (!d) return "";
  try {
    return new Date(d).toLocaleDateString(locale, { year: "numeric", month: "long", day: "numeric" });
  } catch {
    return new Date(d).toISOString().slice(0, 10);
  }
}

const wordCount = post.content
  ? post.content.replace(/<[^>]*>/g, " ").split(/\s+/).filter(Boolean).length
  : undefined;
const readingMinutes = wordCount ? Math.max(2, Math.round(wordCount / 220)) : undefined;
const keywordList: string[] | undefined = (() => {
  const raw = post.tags;
  if (!raw) return undefined;
  try {
    const parsed = JSON.parse(raw);
    if (Array.isArray(parsed)) return parsed.filter((x) => typeof x === "string");
  } catch {
    /* fall through */
  }
  return raw.split(",").map((k) => k.trim()).filter(Boolean);
})();

function firstWord(s: string) { const i = s.indexOf(" "); return i === -1 ? s : s.slice(0, i); }
function lastWord(s: string) {
  const parts = s.trim().split(/\s+/);
  return parts.length > 1 ? parts[parts.length - 1] : "";
}
function withoutLastWord(s: string) {
  const parts = s.trim().split(/\s+/);
  return parts.length > 1 ? parts.slice(0, -1).join(" ") : s;
}

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description: seoDescription,
  ...(post.coverImageUrl ? { image: post.coverImageUrl } : {}),
  ...(post.publishedAt ? { datePublished: post.publishedAt } : {}),
  ...(post.updatedAt ? { dateModified: post.updatedAt } : {}),
  ...(wordCount ? { wordCount } : {}),
  ...(post.category ? { articleSection: post.category } : {}),
  ...(keywordList && keywordList.length > 0 ? { keywords: keywordList } : {}),
  author: post.authorName
    ? { "@type": "Person", name: post.authorName }
    : { "@type": "Organization", name: "MedCasts" },
  publisher: {
    "@type": "Organization",
    name: "MedCasts",
    logo: { "@type": "ImageObject", url: `${SITE_URL}/logo.svg` },
  },
  mainEntityOfPage: url,
  inLanguage: "en",
};

const crumbs = breadcrumbJsonLd([
  { name: tc("home"), url: localeUrl(locale, "/") },
  { name: "Blog", url: localeUrl(locale, "/blog") },
  { name: post.title, url },
]);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<BaseLayout locale={locale}>
  <Fragment slot="head">
    <HeadMeta title={seoTitle} description={seoDescription} path={path} locale={locale} image={post.coverImageUrl ?? undefined} translatedLocales={["en"]} noindex={locale !== "en"} />
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
  </Fragment>

  <main class="min-h-dvh bg-bg text-ink">
    <SiteHeader locale={locale} />

    <div style="background: var(--color-paper); border-bottom: 1px solid var(--color-border-soft);">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8 py-4">
        <nav class="mono text-[12px]" style="color: var(--color-ink-subtle);" aria-label="Breadcrumb">
          <a href={localizedPath(locale, "/")} class="hover:text-ink">{tc("home")}</a>
          <span class="mx-1.5">/</span>
          <a href={localizedPath(locale, "/blog")} class="hover:text-ink">Blog</a>
          <span class="mx-1.5">/</span>
          <span style="color: var(--color-ink);">{post.category ?? "Article"}</span>
        </nav>
      </div>
    </div>

    {/* Hero — editorial title block */}
    <section style="padding: 56px 0 40px;">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        {post.category && (
          <p class="mono uppercase" style="font-size: 11px; letter-spacing: 0.14em; color: var(--color-accent);">
            {post.category}{readingMinutes ? ` · ${readingMinutes} min read` : ""}
          </p>
        )}
        <h1
          class="display display-tight mt-4"
          style="font-size: clamp(2.25rem, 5.2vw, 4.5rem); line-height: 1.02; font-weight: 400; letter-spacing: -0.03em; max-width: 58rem;"
        >
          {withoutLastWord(post.title)}{" "}<span class="italic-display">{lastWord(post.title)}</span>
        </h1>
        {post.excerpt && (
          <p class="serif mt-6 max-w-[48rem]" style="font-size: 20px; line-height: 1.5; color: var(--color-ink-muted);">
            {post.excerpt}
          </p>
        )}

        {/* Byline strip */}
        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3" style="border-top: 1px solid var(--color-ink); border-bottom: 1px solid var(--color-border); padding: 14px 0;">
          {post.authorName && (
            <div class="flex items-center gap-2">
              <div class="flex h-9 w-9 items-center justify-center rounded-full" style="background: var(--color-accent-soft); color: var(--color-accent);">
                <User className="h-4 w-4" />
              </div>
              <div class="min-w-0">
                <div class="mono uppercase" style="font-size: 9.5px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">Author</div>
                <div class="serif" style="font-size: 14px; color: var(--color-ink);">{post.authorName}</div>
              </div>
            </div>
          )}
          {post.publishedAt && (
            <div>
              <div class="mono uppercase" style="font-size: 9.5px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">Published</div>
              <div class="serif tnum" style="font-size: 14px; color: var(--color-ink);">{fmtDate(post.publishedAt)}</div>
            </div>
          )}
          {post.updatedAt && post.updatedAt !== post.publishedAt && (
            <div>
              <div class="mono uppercase" style="font-size: 9.5px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">Updated</div>
              <div class="serif tnum" style="font-size: 14px; color: var(--color-ink);">{fmtDate(post.updatedAt)}</div>
            </div>
          )}
          {wordCount && (
            <div>
              <div class="mono uppercase" style="font-size: 9.5px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">Length</div>
              <div class="serif tnum" style="font-size: 14px; color: var(--color-ink);">{wordCount.toLocaleString()} words</div>
            </div>
          )}
        </div>
      </div>
    </section>

    {post.coverImageUrl && (
      <section style="padding-bottom: 48px;">
        <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
          <PhotoBlock
            aspect="16/9"
            rounded
            imgUrl={post.coverImageUrl}
            alt={post.title}
            priority
          />
        </div>
      </section>
    )}

    {/* Body + TOC-aligned layout */}
    <section style="padding-bottom: 72px;">
      <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
        <div class="grid gap-12 lg:grid-cols-[1fr,0.3fr]">
          <article class="min-w-0">
            <div class="blog-prose prose-editorial" set:html={linkedHtml} />
          </article>

          <aside class="hidden lg:block">
            <div class="lg:sticky lg:top-28 lg:self-start space-y-6">
              <div style="padding: 18px 0; border-top: 1px solid var(--color-ink);">
                <div class="mono uppercase" style="font-size: 9.5px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                  Reviewer desk
                </div>
                <div class="serif mt-2" style="font-size: 15px; line-height: 1.4; color: var(--color-ink);">
                  Reviewed by MedCasts editorial
                </div>
                <p class="mono uppercase mt-1" style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-ink-subtle);">
                  Named-physician review before publish
                </p>
                <a
                  href={localizedPath(locale, "/editorial-policy")}
                  class="mono uppercase mt-3 inline-flex items-center gap-1 hover:text-accent transition-colors"
                  style="font-size: 10.5px; letter-spacing: 0.12em; color: var(--color-ink-muted);"
                >
                  Editorial policy →
                </a>
              </div>

              <a
                href={localizedPath(locale, "/second-opinion")}
                class="paper group block transition hover:-translate-y-0.5"
                style="padding: 18px 20px;"
              >
                <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-accent);">
                  Free second opinion
                </div>
                <div class="serif mt-2" style="font-size: 16px; line-height: 1.3; color: var(--color-ink);">
                  Send reports, receive <span class="italic-display">clarity</span>.
                </div>
                <div class="mt-3 mono uppercase inline-flex items-center gap-1 group-hover:text-accent transition-colors" style="font-size: 10.5px; letter-spacing: 0.14em; color: var(--color-ink-muted);">
                  48 hours · $0
                  <ChevronRight className="h-3 w-3 mirror-x" />
                </div>
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    {mentioned.length > 0 && (
      <section style="padding: 48px 0 72px; border-top: 1px solid var(--color-border-soft);">
        <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
          <div class="mb-6">
            <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
              Mentioned in this piece
            </div>
            <h2 class="display mt-3" style="font-size: 24px; letter-spacing: -0.015em;">
              Open any of the <span class="italic-display">{mentioned.length}</span> references
            </h2>
          </div>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {mentionKindOrder
              .filter((k) => groupedMentions[k].length > 0)
              .map((k) => (
                <div class="paper" style="padding: 20px 22px;">
                  <p class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-accent);">
                    {mentionGroupLabels[k]}
                  </p>
                  <ul class="mt-3 flex flex-wrap gap-1.5">
                    {groupedMentions[k].map((e) => {
                      const base =
                        k === "hospital" ? "/hospital" :
                        k === "treatment" ? "/treatment" :
                        k === "specialty" ? "/specialty" :
                        k === "condition" ? "/condition" :
                        "/glossary";
                      return (
                        <li>
                          <a
                            href={localizedPath(locale, `${base}/${e.slug}`)}
                            class="serif inline-flex items-center hover:text-accent transition-colors"
                            style="font-size: 13.5px; color: var(--color-ink); border-bottom: 1px dashed var(--color-border); padding-bottom: 1px;"
                          >
                            {e.name}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              ))}
          </div>
        </div>
      </section>
    )}

    {related.length > 0 && (
      <section style="padding: 56px 0 88px; border-top: 1px solid var(--color-border-soft);">
        <div class="mx-auto w-full max-w-[80rem] px-5 md:px-8">
          <div class="mb-6 flex items-end justify-between flex-wrap gap-4">
            <div>
              <div class="mono uppercase" style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-subtle);">
                Related reading
              </div>
              <h2 class="display mt-3" style="font-size: 28px; letter-spacing: -0.02em;">
                More from the <span class="italic-display">desk</span>
              </h2>
            </div>
            <a
              href={localizedPath(locale, "/blog")}
              class="mono uppercase text-[11px] hover:text-accent"
              style="letter-spacing: 0.14em; color: var(--color-ink-subtle);"
            >
              All posts →
            </a>
          </div>
          <ul class="grid grid-cols-1 md:grid-cols-3 gap-5">
            {related.map((r) => (
              <li>
                <a
                  href={localizedPath(locale, `/blog/${r.slug}`)}
                  class="paper group flex flex-col h-full overflow-hidden transition hover:-translate-y-0.5"
                  style="padding: 0;"
                >
                  <PhotoBlock aspect="16/10" rounded={false} imgUrl={r.coverImageUrl} alt={r.title} />
                  <div class="p-5 flex-1 flex flex-col">
                    <p class="serif group-hover:text-accent transition-colors line-clamp-2" style="font-size: 17px; line-height: 1.3; letter-spacing: -0.005em; color: var(--color-ink);">
                      {r.title}
                    </p>
                    {r.excerpt && (
                      <p class="mt-2 serif line-clamp-2" style="font-size: 13.5px; line-height: 1.55; color: var(--color-ink-muted);">
                        {r.excerpt}
                      </p>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <style is:global>
      /* Drop-cap on first paragraph of the article body */
      .blog-prose > p:first-of-type::first-letter {
        font-family: var(--font-display);
        font-weight: 300;
        font-size: 5.4em;
        line-height: 0.92;
        float: inline-start;
        margin-inline-end: 10px;
        margin-block-start: 0.08em;
        color: var(--color-ink);
      }

      /* Autolinks */
      .mc-autolink {
        color: var(--color-accent);
        text-decoration: underline;
        text-decoration-color: color-mix(in oklab, var(--color-accent) 40%, transparent);
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
        transition: color 120ms ease, text-decoration-color 120ms ease;
      }
      .mc-autolink:hover {
        color: var(--color-accent-hover, var(--color-accent));
        text-decoration-color: currentColor;
      }
    </style>

    <SiteFooter locale={locale} />
  </main>
</BaseLayout>
