---
import "../styles/global.css";
import { isRtl, defaultLocale, type Locale } from "@/lib/i18n";
import { organizationJsonLd, webSiteJsonLd } from "@/lib/seo";
import CommandPalette from "@/components/CommandPalette.astro";

interface Props {
  locale?: Locale;
  /** Page title — shown in a fallback <title> when no head slot is provided */
  title?: string;
  description?: string;
}

const { locale = defaultLocale, title, description } = Astro.props;
const dir = isRtl(locale) ? "rtl" : "ltr";
const hasHeadSlot = Astro.slots.has("head");
const orgLd = organizationJsonLd();
const siteLd = webSiteJsonLd();
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    {/* Fonts are self-hosted in /public/fonts — @font-face declared in global.css.
        Preloading the two most critical woff2 (Fraunces display + Inter body) gives
        the browser a head start, so text paints before parsing external CSS. */}
    <link rel="preload" href="/fonts/fraunces-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />
    {hasHeadSlot ? (
      <slot name="head" />
    ) : (
      <>
        {title && <title>{title}</title>}
        {description && <meta name="description" content={description} />}
      </>
    )}
  </head>
  <body>
    <slot />
    <CommandPalette locale={locale} />
  </body>
</html>
