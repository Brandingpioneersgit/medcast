---
import "../styles/global.css";
import { isRtl, defaultLocale, type Locale } from "@/lib/i18n";

interface Props {
  locale?: Locale;
  /** Page title — shown in a fallback <title> when no head slot is provided */
  title?: string;
  description?: string;
}

const { locale = defaultLocale, title, description } = Astro.props;
const dir = isRtl(locale) ? "rtl" : "ltr";
const hasHeadSlot = Astro.slots.has("head");
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&display=swap"
      rel="stylesheet"
    />
    {hasHeadSlot ? (
      <slot name="head" />
    ) : (
      <>
        {title && <title>{title}</title>}
        {description && <meta name="description" content={description} />}
      </>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
